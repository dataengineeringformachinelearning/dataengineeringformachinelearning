# Django settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*
FRONTEND_URL=http://localhost:4200

# Database Settings
DATABASE_URL=sqlite:///db.sqlite3

# CORS & CSRF Settings
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8000,https://dataengineeringformachinelearning.com
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://localhost:8000,https://dataengineeringformachinelearning.com

# Redpanda message queue broker
REDPANDA_BROKERS=localhost:19092

# Firebase admin credentials
FIREBASE_SERVICE_ACCOUNT_JSON=

# Integrations / APIs
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/system-status/integrations/google/callback

# Security & Observability APIs
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
IPINFO_API_KEY=your_ipinfo_api_key_here
CISA_TAXII_ENDPOINT=your_cisa_taxii_endpoint_here
ISAC_API_KEY=your_isac_api_key_here
OTX_API_KEY=your_otx_api_key_here
RESEND_API_KEY=your_resend_api_key_here
ALERT_EMAIL_TARGET=your_target_email@example.com
ALERT_EMAIL_FROM=notifications@dataengineeringformachinelearning.com
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
SENTRY_DSN=your_sentry_dsn_here

# Google Cloud KMS (Envelope Encryption)
GCP_KMS_PROJECT_ID=
GCP_KMS_LOCATION=global
GCP_KMS_KEY_RING=compliance-keyring
GCP_KMS_KEY_NAME=database-kek

# Centralized Logging (SIEM)
GCP_LOGGING_ENABLED=False
GOOGLE_APPLICATION_CREDENTIALS=
GCP_SERVICE_ACCOUNT_JSON=

# Vulnerability Ledger Pipeline
CPE_GUESSER_URL=http://cpe-guesser:1323/unique
CVE_DICT_DB_URL=postgresql://<USER>:<PASSWORD>@localhost:5432/go_cve_dict
CLICKHOUSE_URI=postgresql://<USER>:<PASSWORD>@localhost:9005/default
