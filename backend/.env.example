# =============================================================================
# DEML Backend (Django) - .env.example
# Copy to .env and fill values. Never commit real secrets.
# Use this as the source of truth for Railway variables and local dev.
# =============================================================================

# --- Core Django ---
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend.deml.app,backend.dataengineeringformachinelearning.com
FRONTEND_URL=https://deml.app
BACKEND_URL=https://backend.deml.app

# Database (Neon serverless Postgres in prod, sqlite local fallback).
# Production rejects connections that do not verify the database certificate.
DATABASE_URL=postgresql://neondb_owner:password@ep-purple-cherry-atyukewv-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=verify-full&sslrootcert=system # pragma: allowlist secret
# deml-daemon adds pgbouncer=true on the same pooler URL.
# Local: DATABASE_URL=sqlite:///db.sqlite3

# --- CORS / CSRF (MUST include all frontends + marketing + local) ---
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=https://deml.app,https://dataengineeringformachinelearning.com,https://backend.deml.app,https://backend.dataengineeringformachinelearning.com,http://localhost:4200,http://localhost:8000
CSRF_TRUSTED_ORIGINS=https://deml.app,https://dataengineeringformachinelearning.com,https://backend.deml.app,https://backend.dataengineeringformachinelearning.com,http://localhost:4200,http://localhost:8000

# --- Event Bus (Redpanda/Kafka) ---
# INTERNAL (backend, workers, outbox_relay) — always use the private Railway address.
REDPANDA_BROKERS=deml-queue.railway.internal:9092
REDPANDA_SECURITY_PROTOCOL=SSL
# Optional private CA / mTLS identity. Paths must be readable inside the container.
REDPANDA_SSL_CA_B64=base64-of-ca-pem
REDPANDA_SSL_CERT_B64=base64-of-client-certificate-pem
REDPANDA_SSL_KEY_B64=base64-of-client-private-key-pem

# Authenticated application-layer encryption for durable internode messages.
DEML_TRANSPORT_SECURITY=required
DEML_INTERNODE_ENCRYPTION=required
DEML_INTERNODE_ACTIVE_KID=2026-07
# Base64url, no padding; retain the previous key during rolling rotation.
DEML_INTERNODE_KEYS={"2026-07":"replace-with-43-character-base64url-key"}
DEML_NODE_ID=deml-backend
# Local dev (docker-compose): REDPANDA_BROKERS=localhost:19092
# Rust roles own probe and schedule loops in production. Set to 1 only during
# an explicit rollback after stopping deml-probe and deml-scheduler.
PYTHON_EMBEDDED_SCHEDULERS_ENABLED=0

# For Firebase Cloud Functions (ingestEvent) — use the PUBLIC authenticated endpoint
# (fast direct publish, no polling). The public endpoint MUST be a Railway TCP Proxy
# (raw TCP), NOT an HTTP custom domain like queue.deml.app — an HTTP domain cannot
# carry the raw Kafka protocol and the function will time out and fall back to Firestore.
# In Railway: deml-queue service -> Settings -> Networking -> add a TCP Proxy for
# container port 9093. Railway returns a host:port like xxxx.proxy.rlwy.net:34567.
# Then on the deml-queue service set PUBLIC_REDPANDA_HOST + PUBLIC_REDPANDA_PORT to
# that proxy host/port so the broker advertises the reachable address.
# On the Firebase function set:
# REDPANDA_BROKERS=xxxx.proxy.rlwy.net:34567
# REDPANDA_SASL_USERNAME=deml-func
# REDPANDA_SASL_PASSWORD=long-random-password-here
# REDPANDA_SSL=true
# A plaintext TCP proxy is not supported in production. Terminate verified TLS at
# Redpanda or at an authenticated TCP edge before enabling this producer.

# (The SASL user + public listener are configured on the Redpanda service itself.)

# --- Dragonfly (Redis-compatible) for Channels + rate limiting ---
DRAGONFLY_HOST=deml-dragonfly.railway.internal
REDIS_URL=rediss://deml-dragonfly.example.net:6379
REDIS_SSL_CA_B64=base64-of-dragonfly-ca-pem
# Local: DRAGONFLY_HOST=localhost

# --- Firebase (for Auth + Functions + fallback projections) ---
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # full JSON or use file
FIREBASE_PROJECT_ID=demldotcom
GOOGLE_CLOUD_PROJECT=demldotcom

# --- Google / OAuth / AI ---
GOOGLE_API_KEY=your_google_api_key
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-secret
# Google Analytics (GA4) OAuth — must match Google Cloud Console exactly
# (APIs & Services → Credentials → OAuth 2.0 Client → Authorized redirect URIs).
# Error 400 redirect_uri_mismatch means this URI is missing from the Console list.
# Production value (copy into Console if connecting GA4 fails):
#   https://backend.deml.app/api/v1/system-status/integrations/google/callback
# Defaults to BACKEND_URL + /api/v1/system-status/integrations/google/callback when unset.
GOOGLE_OAUTH_REDIRECT_URI=https://backend.deml.app/api/v1/system-status/integrations/google/callback

# --- Security / Threat Intel ---
ABUSEIPDB_API_KEY=your-abuseipdb-key
IPINFO_API_KEY=your-ipinfo-key
OTX_API_KEY=your-otx-key
ISAC_API_KEY=your-isac-key
CISA_TAXII_ENDPOINT=

# --- Email / Notifications / Observability ---
RESEND_API_KEY=your-resend-key
ALERT_EMAIL_TARGET=notifications@deml.app
ALERT_EMAIL_FROM=notifications@dataengineeringformachinelearning.com
DISCORD_WEBHOOK_URL=your-discord-webhook
SENTRY_DSN=your-sentry-dsn
SENTRY_SEND_PII=false
STRUCTURED_LOGS=true

# --- Stripe Billing ---
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Hugging Face (ML model sync) ---
HF_TOKEN=your-hf-token
HF_REPO_ID=your-org/deml-models

# --- Google Cloud KMS (envelope encryption) ---
GCP_KMS_PROJECT_ID=demldotcom
GCP_KMS_LOCATION=us-central1
GCP_KMS_KEY_RING=compliance-keyring
GCP_KMS_KEY_NAME=database-kek
GCP_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Centralized logging
GCP_LOGGING_ENABLED=True

# --- Marketing / Cross-site handoff (env-driven, no hardcodes) ---
MARKETING_URL=https://dataengineeringformachinelearning.com
# FRONTEND_URL already above (used for some redirects)

# --- Vulnerability / CVE pipeline (optional workers) ---
CPE_GUESSER_URL=https://cpe-internal.deml.app/unique
SCANNER_SERVICE_URL=https://scanner-internal.deml.app
TOR_PROXY_URL=socks5h://deml-tor-proxy.railway.internal:9050
CLICKHOUSE_URI=clickhouse://default:password@clickhouse:8123/default # pragma: allowlist secret
CVE_DICT_DB_URL=postgresql://admin:password@postgres:5432/machinelearning # pragma: allowlist secret
REDISHOST=
REDISPORT=6379

# --- Railway auto-injected (do not override in most cases) ---
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PRIVATE_DOMAIN=deml-backend.railway.internal
# RAILWAY_PUBLIC_DOMAIN=backend.deml.app
# PORT= (Railway sets)

# Notes:
# - Workers (telemetry, ml, security) share most of these (DB, REDPANDA, DRAGONFLY, FIREBASE, API keys).
# - Marketing site build (separate host): same trio — FRONTEND_URL, BACKEND_URL, MARKETING_URL
# - Outbox + Event Projections require no extra top-level envs; rely on above + Postgres.
# - Use Railway "Variables" per-service. Backend and workers need nearly identical sets.
