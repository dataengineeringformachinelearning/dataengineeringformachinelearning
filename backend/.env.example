# DEML user-focused Django control plane
# Primary PaaS: Fly.io (docs/FLY.md, backend/fly.toml). Railway remains optional standby.
SECRET_KEY=replace-with-a-strong-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend.deml.app,deml-backend.fly.dev
FRONTEND_URL=https://deml.app
BACKEND_URL=https://backend.deml.app
MARKETING_URL=https://dataengineeringformachinelearning.com

# Supabase pooler + DATABASE_SEARCH_PATH=partner_control,public (docs/FLY.md;
# FORJD docs/NEON_TO_SUPABASE_ETL.md — never restore DEML into FORJD public schema).
DATABASE_URL=postgresql://user:password@host/database?sslmode=verify-full # pragma: allowlist secret
# DATABASE_SEARCH_PATH=partner_control,public

CORS_ALLOW_CREDENTIALS=True
# Include Vercel app origin(s): https://deml.app, https://deml.vercel.app, previews as needed
CORS_ALLOWED_ORIGINS=https://deml.app,https://dataengineeringformachinelearning.com,https://deml.vercel.app,http://localhost:4200
CSRF_TRUSTED_ORIGINS=https://deml.app,https://dataengineeringformachinelearning.com,http://localhost:4200

# Firebase identity
FIREBASE_PROJECT_ID=demldotcom
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# FORJD is the exclusive intake, processing, analytics, and ML data plane.
FORJD_API_URL=https://backend.forjd.co
# Tenant-scoped opaque credential returned once by FORJD service-account provisioning.
FORJD_SERVICE_TOKEN=fjsvc_0123abcd_replace-with-one-time-secret # pragma: allowlist secret
FORJD_TENANT_ID=<forjd-tenant-uuid>
# FORJD read/write modes (docs/FORJD_INTEGRATION.md). Phase 2 = production steady state.
# FORJD_CUTOVER_PHASE=2
# FORJD_WRITE_MODE=forjd
# FORJD_READ_MODE=forjd
# Headless SIEM/SOAR compatibility and bounded HTTP-client controls.
FORJD_REQUIRED_CONTRACT_VERSION=1.0
FORJD_CONNECT_TIMEOUT_SECONDS=5
FORJD_REQUEST_TIMEOUT_SECONDS=20
FORJD_LONG_REQUEST_TIMEOUT_SECONDS=45
FORJD_RESPONSE_MAX_BYTES=2097152
FORJD_READ_RETRY_ATTEMPTS=3
FORJD_RETRY_BASE_SECONDS=0.1
FORJD_RETRY_MAX_SECONDS=2
DEML_HEADLESS_RATE_LIMIT_ENABLED=true
DEML_HEADLESS_INGEST_RPM=120
DEML_HEADLESS_WRITE_RPM=300
DEML_HEADLESS_READ_RPM=1200
DEML_PUBLIC_STATUS_RPM=60

# Live updates (SSE bridge over FORJD's Supabase-Realtime-backed cursor feed)
DEML_LIVE_UPDATES_ENABLED=true
DEML_LIVE_POLL_SECONDS=10
DEML_LIVE_STREAM_MAX_SECONDS=300

# Optional Redis (rate-limit only). Sessions/handoff use Postgres — leave unset.
# REDIS_URL=rediss://user:pass@cache.example:6379/0  # pragma: allowlist secret
# REDIS_SSL_CA_B64=

# Billing and user communications
STRIPE_PUBLIC_KEY=pk_live_replace
STRIPE_SECRET_KEY=sk_live_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_PRICE_ID=price_1TlgG2Er73F9pBqwItcWHIJf
RESEND_API_KEY=re_replace
ALERT_EMAIL_TARGET=notifications@deml.app
ALERT_EMAIL_FROM=notifications@dataengineeringformachinelearning.com

# Observability
SENTRY_DSN=
SENTRY_SEND_PII=false
STRUCTURED_LOGS=true
