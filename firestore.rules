rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User-owned docs: only the authenticated owner can read/write their stats and subdocs.
    // Admin SDK (Cloud Functions, Django worker) bypasses these rules.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Events collection (written by functions fallback) - client should not read directly
    match /events/{eventId} {
      allow read, write: if false;
    }

    // Default: deny all other access from clients
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
