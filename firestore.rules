rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User-owned docs: only the authenticated owner can read/write their stats and subdocs.
    // The Django control plane (Admin SDK) bypasses these rules.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all other access from clients
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
