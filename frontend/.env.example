# =============================================================================
# DEML Frontend (Angular) - .env.example
# These are consumed at build time by set-env.js (which generates src/environments/environment*.ts)
# and also used for runtime resolution where applicable.
# Copy to .env (never commit real values).
# =============================================================================

# Firebase (required for auth)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=demldotcom
FIREBASE_APP_ID=1:...
FIREBASE_AUTH_DOMAIN=demldotcom.firebaseapp.com
FIREBASE_STORAGE_BUCKET=demldotcom.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=870072971206

# Sanity CMS (for docs/content)
SANITY_PROJECT_ID=hj5wtuct
SANITY_DATASET=production

# Backend (used for API calls; dynamic fallback in getBackendUrl() for Railway)
BACKEND_URL=https://backend.deml.app
# Local: BACKEND_URL=http://localhost:8000

# Marketing site (used for cross-domain auth state handoff + links)
# CRITICAL: prevents hard-coded domains causing cross-site issues
MARKETING_URL=https://dataengineeringformachinelearning.com
# Local dev (Astro): MARKETING_URL=http://localhost:4321

# Notes:
# - set-env.js reads these + injects into built environment.ts
# - Railway: set MARKETING_URL and BACKEND_URL on the frontend service for build
# - No PUBLIC_* here (those are Astro-only for marketing site hosting)
