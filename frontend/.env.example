# =============================================================================
# DEML Frontend (Angular) — .env.example
# Consumed at build time by set-env.js (generates src/environments/environment*.ts).
# On Vercel (project: deml), set these as Project Environment Variables (Production).
# Copy to .env for local (never commit real values).
# =============================================================================

# Firebase (auth only — no Firestore/Storage/Functions) — baked into the CSR bundle
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=demldotcom
FIREBASE_APP_ID=1:...
FIREBASE_AUTH_DOMAIN=demldotcom.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=870072971206

# Sanity CMS (docs/content)
SANITY_PROJECT_ID=hj5wtuct
SANITY_DATASET=production

# Cross-site URLs
# Angular API base = DEML Django BFF (Railway). Do NOT point at FORJD from the browser.
FRONTEND_URL=https://deml.app
BACKEND_URL=https://backend.deml.app
MARKETING_URL=https://dataengineeringformachinelearning.com
# Local: FRONTEND_URL=http://localhost:4200  BACKEND_URL=http://localhost:8000  MARKETING_URL=http://localhost:4321

# FORJD (informational in the client env; data plane is Django → FORJD → Supabase)
# Django uses FORJD_SERVICE_TOKEN server-side. Browser never calls FORJD with Firebase tokens.
FORJD_API_URL=https://backend.forjd.co
# Deprecated plaintext endpoint telemetry. Keep false; use sealed `/api/v1/ingest`.
ENABLE_LEGACY_PLAINTEXT_TELEMETRY=false

# Observability (optional — omit to disable client Sentry)
SENTRY_DSN=

# Notes:
# - Vercel project name: deml  |  Root Directory: frontend
# - Output: dist/frontend/browser  |  see docs/VERCEL.md
# - After changing FRONTEND_URL, add the origin to Django CORS_ALLOWED_ORIGINS
