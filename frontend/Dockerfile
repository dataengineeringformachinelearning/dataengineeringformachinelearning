# Build stage
FROM node:22-alpine AS builder

# Install build dependencies
RUN apk add --no-cache git

# Set working directory
WORKDIR /app

# Copy package files for better caching
COPY package*.json ./

# Install dependencies (including dev dependencies for build)
RUN npm install --legacy-peer-deps && npm cache clean --force

# Copy source code
COPY . .

# Set build arguments for Firebase (supplied by Railway during build time)
ARG FIREBASE_API_KEY
ARG FIREBASE_AUTH_DOMAIN
ARG FIREBASE_PROJECT_ID
ARG FIREBASE_STORAGE_BUCKET
ARG FIREBASE_MESSAGING_SENDER_ID
ARG FIREBASE_APP_ID
ARG FRONTEND_URL
ARG BACKEND_URL
ARG MARKETING_URL
ARG SANITY_PROJECT_ID
ARG SANITY_DATASET

ENV FIREBASE_API_KEY=$FIREBASE_API_KEY
ENV FIREBASE_AUTH_DOMAIN=$FIREBASE_AUTH_DOMAIN
ENV FIREBASE_PROJECT_ID=$FIREBASE_PROJECT_ID
ENV FIREBASE_STORAGE_BUCKET=$FIREBASE_STORAGE_BUCKET
ENV FIREBASE_MESSAGING_SENDER_ID=$FIREBASE_MESSAGING_SENDER_ID
ENV FIREBASE_APP_ID=$FIREBASE_APP_ID
ENV FRONTEND_URL=$FRONTEND_URL
ENV BACKEND_URL=$BACKEND_URL
ENV MARKETING_URL=$MARKETING_URL
ENV SANITY_PROJECT_ID=$SANITY_PROJECT_ID
ENV SANITY_DATASET=$SANITY_DATASET

# Fail fast when required build-time configuration is missing (no silent placeholders).
RUN test -n "$FIREBASE_API_KEY" && test -n "$FIREBASE_PROJECT_ID" && test -n "$FIREBASE_APP_ID" \
  && test -n "$FIREBASE_AUTH_DOMAIN" && test -n "$FIREBASE_STORAGE_BUCKET" \
  && test -n "$FIREBASE_MESSAGING_SENDER_ID" && test -n "$FRONTEND_URL" \
  && test -n "$BACKEND_URL" && test -n "$MARKETING_URL" \
  && test -n "$SANITY_PROJECT_ID" && test -n "$SANITY_DATASET" \
  || (echo "ERROR: Missing required build ARGs. Set Firebase, cross-site URLs, and Sanity vars on deml-frontend." && exit 1)

# Validate mobile responsiveness and mobile-first styles
RUN npm run check:mobile-first

# Build the application (set-env.js validates env and fails if anything is missing)
RUN npm run build --prod

# firebase-config.js is generated by set-env.js during build — copy into dist assets
RUN mkdir -p /app/dist/frontend/browser/assets \
  && cp /app/src/assets/firebase-config.js /app/dist/frontend/browser/assets/firebase-config.js

# Production stage (Secure Distroless Node.js)
FROM gcr.io/distroless/nodejs22-debian12

# Re-declare ARGs for runtime envs (Railway build args)
ARG BACKEND_URL
ARG MARKETING_URL

WORKDIR /app

# Copy built application from builder stage
COPY --chown=nonroot:nonroot --from=builder /app/dist/frontend /app/dist/frontend

# Set runtime envs for the SSR proxy (server.ts uses process.env.BACKEND_URL for /api proxy)
ENV PORT=4000 \
    BACKEND_URL=$BACKEND_URL \
    MARKETING_URL=$MARKETING_URL

EXPOSE 4000

USER nonroot

# Run the Angular SSR server
CMD ["dist/frontend/server/server.mjs"]
