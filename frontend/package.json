{
  "name": "frontend",
  "version": "2.0.1",
  "scripts": {
    "ng": "ng",
    "prebuild": "npm run build:sitemap",
    "build:sitemap": "node scripts/build_sitemap.mjs",
    "prestart": "npm run build:sitemap",
    "clean:cache": "rm -rf .angular/cache dist/viking-ui dist/frontend out-tsc",
    "start": "node set-env.js && ng serve",
    "build": "node set-env.js && ng build",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run build:sitemap",
    "test": "node set-env.js && vitest run",
    "test:viking-ui": "vitest run --config vitest.viking-ui.config.ts",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs",
    "lint": "ng lint",
    "build:viking-ui": "echo \"Using installed @dataengineeringformachinelearning/viking-ui package (no local workspace rebuild).\"",
    "build:viking-ui:local": "if [ -f ../packages/viking-ui/ng-package.json ]; then node scripts/sync_lucide_icons.mjs && ng build viking-ui; else echo \"Skipping local viking-ui rebuild: ../packages/viking-ui is unavailable.\"; fi",
    "build:viking-ui-css": "echo \"Static CSS is generated from the viking-ui package in repo root. Run from workspace root: npm run build:viking-ui:package\"",
    "sync:lucide-icons": "node scripts/sync_lucide_icons.mjs",
    "build:site-drakkar": "node scripts/build_site_drakkar.mjs",
    "build:viking-ui-system": "npm run build:viking-ui:local && npm run build:viking-ui-docs --prefix ../viking-ui-docs",
    "check:viking-upstream": "node scripts/check_viking_upstream.mjs",
    "check:mobile-first": "node scripts/check_mobile_first.js",
    "generate:api": "openapi-generator-cli generate -i ./openapi.json -g typescript-angular -o src/app/api --skip-validate-spec"
  },
  "private": true,
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@dataengineeringformachinelearning/viking-ui": "^4.0.0",
    "@sanity/client": "^7.22.1",
    "@sentry/angular": "^10.57.0",
    "canvas-confetti": "^1.9.4",
    "express": "^5.1.0",
    "firebase": "^12.14.0",
    "leaflet": "^1.9.4",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.2",
    "@analogjs/vitest-angular": "^2.6.1",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.39.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^5.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.17.19",
    "angular-eslint": "22.0.0",
    "cypress": "^15.0.0",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "lucide": "^1.23.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "typescript": "~6.0.3"
  }
}
