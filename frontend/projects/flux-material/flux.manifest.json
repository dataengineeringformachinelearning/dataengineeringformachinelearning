{
  "$schema": "https://json-schema.org/draft-07/schema",
  "name": "@deml/flux-material",
  "description": "Tracks which Flux UI (fluxui.dev) components this package mirrors, so upstream additions/renames are detectable via `npm run check:flux-upstream`.",
  "upstream": {
    "site": "https://fluxui.dev",
    "componentsIndex": "https://fluxui.dev/components",
    "lastAudited": "2026-07-01",
    "notes": "Flux UI is a Livewire/Blade + Tailwind library; flux-material re-implements the free component styles as zero-dependency Angular standalone components themed with DEML Material tokens (THEME.md)."
  },
  "components": {
    "app-header": {
      "upstream": "https://fluxui.dev/components/navbar",
      "exports": ["FluxAppHeader"],
      "notes": "DEML app shell — sticky header with mobile menu slots."
    },
    "app-sidebar": {
      "upstream": "https://fluxui.dev/components/navbar",
      "exports": ["FluxAppSidebar"],
      "notes": "DEML app shell — collapsible dashboard sidebar."
    },
    "footer": {
      "upstream": "https://fluxui.dev/components/card",
      "exports": ["FluxFooter"],
      "notes": "DEML site-wide footer chrome."
    },
    "hud-panel": {
      "upstream": "https://fluxui.dev/components/card",
      "exports": ["FluxHudPanel"],
      "notes": "DEML dashboard panel with icon header."
    },
    "metric-card": {
      "upstream": "https://fluxui.dev/components/card",
      "exports": ["FluxMetricRow", "FluxMetricCard"],
      "notes": "DEML HUD KPI metric tiles."
    },
    "page-header": {
      "upstream": "https://fluxui.dev/components/navbar",
      "exports": ["FluxPageHeader"],
      "notes": "DEML unified page header (HUD + sidebar topbar)."
    },
    "fab": {
      "upstream": "https://fluxui.dev/components/button",
      "exports": ["FluxFab"],
      "notes": "DEML floating action button."
    },
    "search-palette": {
      "upstream": "https://fluxui.dev/components/command",
      "exports": ["FluxSearchPalette"],
      "notes": "DEML search overlay (command-palette pattern)."
    },
    "accordion": {
      "upstream": "https://fluxui.dev/components/accordion",
      "exports": ["FluxAccordion", "FluxAccordionItem"]
    },
    "autocomplete": {
      "upstream": "https://fluxui.dev/components/autocomplete",
      "exports": ["FluxAutocomplete"]
    },
    "avatar": { "upstream": "https://fluxui.dev/components/avatar", "exports": ["FluxAvatar"] },
    "badge": { "upstream": "https://fluxui.dev/components/badge", "exports": ["FluxBadge"] },
    "brand": { "upstream": "https://fluxui.dev/components/brand", "exports": ["FluxBrand"] },
    "button": {
      "upstream": "https://fluxui.dev/components/button",
      "exports": ["FluxButton", "FluxButtonGroup"]
    },
    "breadcrumbs": {
      "upstream": "https://fluxui.dev/components/breadcrumbs",
      "exports": ["FluxBreadcrumbs"]
    },
    "calendar": {
      "upstream": "https://fluxui.dev/components/calendar",
      "exports": ["FluxCalendar"]
    },
    "callout": { "upstream": "https://fluxui.dev/components/callout", "exports": ["FluxCallout"] },
    "card": {
      "upstream": "https://fluxui.dev/components/card",
      "exports": ["FluxCard", "FluxCardHeader", "FluxCardFooter"]
    },
    "carousel": {
      "upstream": "https://fluxui.dev/components/carousel",
      "exports": ["FluxCarousel", "FluxCarouselSlide"]
    },
    "chart": { "upstream": "https://fluxui.dev/components/chart", "exports": ["FluxChart"] },
    "checkbox": {
      "upstream": "https://fluxui.dev/components/checkbox",
      "exports": ["FluxCheckbox"]
    },
    "color-picker": {
      "upstream": "https://fluxui.dev/components/color-picker",
      "exports": ["FluxColorPicker"]
    },
    "command": { "upstream": "https://fluxui.dev/components/command", "exports": ["FluxCommand"] },
    "context": { "upstream": "https://fluxui.dev/components/context", "exports": ["FluxContext"] },
    "composer": {
      "upstream": "https://fluxui.dev/components/composer",
      "exports": ["FluxComposer"]
    },
    "date-picker": {
      "upstream": "https://fluxui.dev/components/date-picker",
      "exports": ["FluxDatePicker"]
    },
    "dropdown": {
      "upstream": "https://fluxui.dev/components/dropdown",
      "exports": ["FluxDropdown", "FluxMenuItem"]
    },
    "editor": { "upstream": "https://fluxui.dev/components/editor", "exports": ["FluxEditor"] },
    "field": { "upstream": "https://fluxui.dev/components/field", "exports": ["FluxField"] },
    "file-upload": {
      "upstream": "https://fluxui.dev/components/file-upload",
      "exports": ["FluxFileUpload"]
    },
    "heading": { "upstream": "https://fluxui.dev/components/heading", "exports": ["FluxHeading"] },
    "icon": { "upstream": "https://fluxui.dev/components/icon", "exports": ["FluxIcon"] },
    "input": { "upstream": "https://fluxui.dev/components/input", "exports": ["FluxInput"] },
    "kanban": { "upstream": "https://fluxui.dev/components/kanban", "exports": ["FluxKanban"] },
    "modal": { "upstream": "https://fluxui.dev/components/modal", "exports": ["FluxModal"] },
    "navbar": {
      "upstream": "https://fluxui.dev/components/navbar",
      "exports": ["FluxNavbar", "FluxNavbarItem"]
    },
    "otp-input": {
      "upstream": "https://fluxui.dev/components/otp-input",
      "exports": ["FluxOtpInput"]
    },
    "pagination": {
      "upstream": "https://fluxui.dev/components/pagination",
      "exports": ["FluxPagination"]
    },
    "pillbox": { "upstream": "https://fluxui.dev/components/pillbox", "exports": ["FluxPillbox"] },
    "popover": { "upstream": "https://fluxui.dev/components/popover", "exports": ["FluxPopover"] },
    "profile": { "upstream": "https://fluxui.dev/components/profile", "exports": ["FluxProfile"] },
    "progress": {
      "upstream": "https://fluxui.dev/components/progress",
      "exports": ["FluxProgress"]
    },
    "radio": { "upstream": "https://fluxui.dev/components/radio", "exports": ["FluxRadioGroup"] },
    "select": { "upstream": "https://fluxui.dev/components/select", "exports": ["FluxSelect"] },
    "separator": {
      "upstream": "https://fluxui.dev/components/separator",
      "exports": ["FluxSeparator"]
    },
    "skeleton": {
      "upstream": "https://fluxui.dev/components/skeleton",
      "exports": ["FluxSkeleton"]
    },
    "slider": { "upstream": "https://fluxui.dev/components/slider", "exports": ["FluxSlider"] },
    "switch": { "upstream": "https://fluxui.dev/components/switch", "exports": ["FluxSwitch"] },
    "text": { "upstream": "https://fluxui.dev/components/text", "exports": ["FluxText"] },
    "textarea": {
      "upstream": "https://fluxui.dev/components/textarea",
      "exports": ["FluxTextarea"]
    },
    "time-picker": {
      "upstream": "https://fluxui.dev/components/time-picker",
      "exports": ["FluxTimePicker"]
    },
    "timeline": {
      "upstream": "https://fluxui.dev/components/timeline",
      "exports": ["FluxTimeline", "FluxTimelineItem"]
    },
    "toast": {
      "upstream": "https://fluxui.dev/components/toast",
      "exports": ["FluxToastService", "FluxToaster"]
    },
    "tooltip": { "upstream": "https://fluxui.dev/components/tooltip", "exports": ["FluxTooltip"] }
  }
}
