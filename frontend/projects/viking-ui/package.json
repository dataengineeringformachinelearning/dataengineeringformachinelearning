{
  "name": "@dataengineeringformachinelearning/viking-ui",
  "version": "2.0.0",
  "description": "Viking-UI: framework-agnostic DEML design system — CSS tokens, Web Components, and Angular wrappers.",
  "keywords": [
    "angular",
    "web-components",
    "ui",
    "viking-ui",
    "design-system",
    "deml",
    "a11y",
    "css-variables"
  ],
  "license": "Apache-2.0",
  "author": "Joe Alongi <support@dataengineeringformachinelearning.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning.git",
    "directory": "frontend/projects/viking-ui"
  },
  "homepage": "https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/tree/main/frontend/projects/viking-ui#readme",
  "bugs": {
    "url": "https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/public-api.ts",
      "default": "./src/public-api.ts"
    },
    "./tokens.css": "./dist/css/design-tokens.css",
    "./components.css": "./dist/css/viking-components.css",
    "./viking-ui.css": "./dist/css/viking-ui.css",
    "./elements": "./dist/viking-ui-elements.js",
    "./elements.js": "./dist/viking-ui-elements.js"
  },
  "files": [
    "dist/css",
    "dist/viking-ui-elements.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:css": "npm run build:static-css --prefix ../../viking-ui-docs",
    "build:elements": "node scripts/build-web-components.mjs"
  },
  "peerDependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/forms": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": [
    "./dist/viking-ui-elements.js"
  ]
}
