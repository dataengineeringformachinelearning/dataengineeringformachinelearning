{
  "$schema": "./viking-tokens.schema.json",
  "meta": {
    "name": "viking-ui",
    "version": "2.1.0",
    "description": "Canonical DEML design tokens — single source of truth for all properties",
    "canonicalScss": "../styles/_variables.scss",
    "documentation": "../../../THEME.md"
  },
  "color": {
    "charcoal": {
      "950": "#0a0a0a",
      "900": "#111111",
      "800": "#1a1a1a",
      "700": "#2a2a2a",
      "600": "#333333",
      "500": "#444444"
    },
    "metallic": {
      "600": "#555555",
      "500": "#666666",
      "400": "#777777",
      "300": "#999999",
      "200": "#aaaaaa",
      "100": "#bbbbbb"
    },
    "teal": {
      "700": "#0a5c5f",
      "600": "#0d7377",
      "500": "#109094",
      "400": "#14a3a8",
      "300": "#2db8bd"
    },
    "crimson": {
      "700": "#7a2231",
      "600": "#922b3e",
      "500": "#a83344",
      "400": "#c44355"
    },
    "green": { "500": "#2a9d8f" },
    "gold": { "500": "#c4a035" },
    "blue": { "500": "#14a3a8" },
    "white": "#f5f5f5",
    "whitePure": "#ffffff",
    "black": "#000000"
  },
  "series": {
    "1": { "hex": "#0d7377", "token": "--viking-series-1", "role": "Primary series, default selection" },
    "2": { "hex": "#922b3e", "token": "--viking-series-2", "role": "Secondary / comparison series" },
    "3": { "hex": "#2a9d8f", "token": "--viking-series-3", "role": "Success / stable metrics" },
    "4": { "hex": "#c4a035", "token": "--viking-series-4", "role": "Warning / threshold proximity" },
    "5": { "hex": "#a83344", "token": "--viking-series-5", "role": "Critical / anomaly series" },
    "6": { "hex": "#14a3a8", "token": "--viking-series-6", "role": "Info / auxiliary series" },
    "7": { "hex": "#2a2a2a", "token": "--viking-series-7", "role": "Baseline / muted series" },
    "8": { "hex": "#666666", "token": "--viking-series-8", "role": "Disabled / archived series" },
    "default": "#0d7377"
  },
  "semantic": {
    "dark": {
      "bg": "charcoal.900",
      "surface": "charcoal.800",
      "surfaceAlt": "charcoal.700",
      "surfaceRaised": "charcoal.600",
      "text": "white",
      "textMuted": "metallic.200",
      "accent": "teal.600",
      "accentSecondary": "crimson.600",
      "ring": "teal.400"
    },
    "light": {
      "bg": "whitePure",
      "surface": "whitePure",
      "surfaceAlt": "#f7f7f7",
      "surfaceRaised": "#efefef",
      "text": "charcoal.900",
      "textMuted": "metallic.500",
      "accent": "teal.700",
      "accentSecondary": "crimson.700",
      "ring": "teal.600"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
      "mono": "ui-monospace, 'JetBrains Mono', 'SF Mono', 'Cascadia Code', Consolas, monospace"
    },
    "fontSize": {
      "2xs": "11px",
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "md": "18px",
      "lg": "20px",
      "xl": "24px",
      "2xl": "30px",
      "3xl": "36px",
      "4xl": "48px"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "snug": 1.375,
      "normal": 1.5,
      "relaxed": 1.625,
      "loose": 1.75
    },
    "letterSpacing": {
      "tighter": "-0.03em",
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.025em",
      "wider": "0.05em",
      "caps": "0.08em"
    }
  },
  "spacing": {
    "gridUnit": "4px",
    "0": "0",
    "px": "1px",
    "half": "4px",
    "1": "8px",
    "1.5": "12px",
    "2": "16px",
    "3": "24px",
    "4": "32px",
    "5": "40px",
    "6": "48px",
    "7": "56px",
    "8": "64px",
    "9": "80px",
    "10": "96px"
  },
  "radius": {
    "xs": "4px",
    "sm": "6px",
    "DEFAULT": "8px",
    "md": "10px",
    "lg": "12px",
    "xl": "16px",
    "pill": "999px"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(0, 0, 0, 0.2)",
    "sm": "0 1px 2px rgba(0,0,0,0.18), 0 1px 3px rgba(0,0,0,0.12), inset 0 1px 0 rgba(255,255,255,0.04)",
    "md": "0 2px 4px rgba(0,0,0,0.16), 0 4px 8px rgba(0,0,0,0.12), inset 0 1px 0 rgba(255,255,255,0.05)",
    "lg": "0 4px 8px rgba(0,0,0,0.14), 0 12px 24px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.06)",
    "inner": "inset 0 1px 2px rgba(0, 0, 0, 0.14)",
    "hover": "0 8px 16px rgba(0,0,0,0.14), 0 4px 8px rgba(0,0,0,0.1), inset 0 1px 0 rgba(255,255,255,0.06)"
  },
  "motion": {
    "ease": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "duration": {
      "fast": "150ms",
      "DEFAULT": "250ms",
      "slow": "350ms"
    },
    "state": {
      "hoverLift": "-1px",
      "activeScale": "0.985",
      "disabledOpacity": "0.48"
    }
  },
  "layout": {
    "containerMaxWidth": "1260px",
    "navbarHeight": "64px",
    "sidebarWidth": "256px",
    "controlHeight": "40px",
    "controlHeightSm": "32px",
    "controlHeightXs": "24px",
    "btnMinWidth": "120px",
    "touchTargetMin": "44px",
    "pageGutter": "16px",
    "pageGutterLg": "24px",
    "pageStackGap": "24px",
    "pageSectionGap": "32px",
    "cardPadding": "24px",
    "cardPaddingCompact": "16px",
    "panelPadding": "24px",
    "formMaxWidth": "42rem",
    "formNarrowMaxWidth": "28rem",
    "contentReadableMaxWidth": "48rem"
  },
  "zIndex": {
    "overlay": 1000,
    "toast": 1100,
    "tooltip": 1200
  }
}
