  "name": "@dataengineeringformachinelearning/viking-ui",
  "description": "Tracks Viking UI component coverage for npm run check:viking-upstream.",
  "upstream": {
    "site": "viking-ui",
    "componentsIndex": "components",
    "lastAudited": "2026-07-01",
    "notes": "Internal manifest for DEML @deml/viking-ui \u2014 zero-dependency Angular components themed with THEME.md."
