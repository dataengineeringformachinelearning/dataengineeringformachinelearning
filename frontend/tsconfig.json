/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@dataengineeringformachinelearning/viking-ui": ["../packages/viking-ui"],
      "@dataengineeringformachinelearning/viking-ui/angular": ["../packages/viking-ui"],
      "@dataengineeringformachinelearning/viking-ui/icons": ["../packages/viking-ui/dist/icons.js"],
      "@dataengineeringformachinelearning/viking-ui/manifest": [
        "../packages/viking-ui/dist/viking.manifest.json"
      ],
      "@dataengineeringformachinelearning/viking-ui/site-drakkar": [
        "../packages/viking-ui/dist/site-drakkar.js"
      ],
      "@dataengineeringformachinelearning/viking-ui/tokens.json": [
        "../packages/viking-ui/dist/viking-tokens.json"
      ]
    },
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
