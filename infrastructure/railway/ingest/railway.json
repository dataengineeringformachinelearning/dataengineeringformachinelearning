{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "rust/deml-daemon/Dockerfile",
    "watchPatterns": ["rust/**"]
  },
  "deploy": {
    "healthcheckPath": "/ready",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
