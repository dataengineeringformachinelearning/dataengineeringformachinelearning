{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "rust/deml-daemon/Dockerfile",
    "watchPatterns": ["rust/**"]
  },
  "deploy": {
    "startCommand": "sh -c 'export DEML_ROLE=probe PORT=\"${PORT:-8080}\"; exec /usr/local/bin/deml-daemon'",
    "healthcheckPath": "/ready",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
