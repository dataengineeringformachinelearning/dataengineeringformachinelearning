{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Transitional DEML user-plane topology. FORJD owns every data-plane workload.",
  "project": "deml",
  "environment": "production",
  "retired": [
    "deml-workers",
    "deml-telemetry-worker",
    "deml-relay",
    "deml-scheduler",
    "deml-probe",
    "deml-normalizer",
    "deml-ingest",
    "deml-cpe",
    "deml-scanner",
    "deml-queue",
    "deml-clickhouse",
    "deml-rustfs",
    "deml-tor-proxy",
    "deml-dragonfly"
  ],
  "services": {
    "deml-backend": {
      "class": "django-user-control-plane",
      "configDir": "infrastructure/railway/backend",
      "dockerfile": "backend/Dockerfile",
      "requiredEnv": [
        "DATABASE_URL",
        "SECRET_KEY",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_SERVICE_ACCOUNT_JSON",
        "FORJD_API_URL",
        "FORJD_SERVICE_TOKEN",
        "FORJD_TENANT_ID"
      ],
      "envDefaults": {
        "FORJD_CUTOVER_PHASE": "2",
        "FORJD_WRITE_MODE": "forjd",
        "FORJD_READ_MODE": "forjd"
      },
      "forbiddenEnv": [
        "DEML_ROLE",
        "REDPANDA_BROKERS",
        "CLICKHOUSE_HOST",
        "RUSTFS_ENDPOINT",
        "CPE_GUESSER_URL",
        "SCANNER_SERVICE_URL",
        "FORJD_TOKEN_URL",
        "FORJD_SERVICE_ACCOUNT_ID",
        "FORJD_SERVICE_ACCOUNT_SECRET",
        "FORJD_SERVICE_ACCOUNT_AUDIENCE",
        "DRAGONFLY_HOST",
        "REDIS_URL",
        "REDISHOST",
        "REDISPORT",
        "REDIS_SSL_CA",
        "REDIS_SSL_CA_B64"
      ]
    },
    "deml-frontend": {
      "class": "learning-frontend",
      "configDir": "infrastructure/railway/frontend",
      "dockerfile": "frontend/Dockerfile",
      "requiredEnv": ["BACKEND_URL", "FRONTEND_URL"]
    }
  }
}
