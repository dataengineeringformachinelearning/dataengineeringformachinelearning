# =============================================================================
# DEML Marketing Site (Astro) - .env.example
# Astro exposes PUBLIC_* vars to client (import.meta.env.PUBLIC_*)
# and all vars to server build.
# Set these in your marketing hosting provider (Railway service, Cloudflare Pages, Vercel, etc.)
# at build time. Never commit real .env.
# =============================================================================

# Backend API base for auth handoff + other API calls from marketing
PUBLIC_API_BASE=https://backend.deml.app

# Main application (Angular SPA) for sign-in state sharing + navigation
PUBLIC_MAIN_APP_URL=https://deml.app

# (Optional) Explicit app URL override used in widgets / scripts
PUBLIC_APP_URL=https://deml.app

# Shared Design System CSS (one stylesheet for 100% visual cohesion with the main app)
# Served from the Angular app. Set this for local dev to point at running frontend (http://localhost:4200/assets/design-system.css)
# PUBLIC_DESIGN_SYSTEM_URL=https://deml.app/assets/design-system.css

# Marketing site itself (rarely needed as PUBLIC_MARKETING_URL)
# PUBLIC_MARKETING_URL=https://dataengineeringformachinelearning.com

# Local dev (astro dev)
# PUBLIC_API_BASE=http://localhost:8000
# PUBLIC_MAIN_APP_URL=http://localhost:4200
# PUBLIC_APP_URL=http://localhost:4200

# Notes:
# - These replace all previous hard-coded domains for https://dataengineeringformachinelearning.com <-> https://deml.app sharing.
# - The Navbar.astro and handoff logic (iframe postMessage + verify) rely on these.
# - If marketing is hosted outside Railway, set them in that platform's build env.
