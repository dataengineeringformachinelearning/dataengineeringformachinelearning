# =============================================================================
# DEML Marketing Site (Astro) - .env.example
# Same cross-site URL names as backend + frontend (Vercel/Fly production hosts).
# Set at build time on your marketing host (Firebase Hosting, Cloudflare, etc.).
# =============================================================================

FRONTEND_URL=https://deml.app
BACKEND_URL=https://backend.deml.app
MARKETING_URL=https://dataengineeringformachinelearning.com

# Algolia Experiences site search (search-only API key; safe for public embed)
ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_API_KEY=your-algolia-search-only-api-key
ALGOLIA_EXPERIENCE_ID=your-algolia-experience-id
ALGOLIA_ENV=prod

# Local dev (astro dev)
# FRONTEND_URL=http://localhost:4200
# BACKEND_URL=http://localhost:8000
# MARKETING_URL=http://localhost:4321

# Legacy names (still accepted during migration; prefer the trio above):
# PUBLIC_MAIN_APP_URL, PUBLIC_API_BASE, PUBLIC_APP_URL
