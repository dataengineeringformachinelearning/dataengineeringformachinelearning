---
const currentYear = new Date().getFullYear();
import { siteEnv } from '../lib/site-env';
import {
  SITE_FOOTER_COLUMNS,
  resolveFooterHref,
} from '../../../frontend/packages/viking-ui/src/lib/site-drakkar/site-drakkar.config';

const { FRONTEND_URL, MARKETING_URL } = siteEnv();
const urls = { app: FRONTEND_URL, marketing: MARKETING_URL, backend: '' };
---

<footer class="mega-footer">
  <div class="footer-content">
    <nav class="footer-directory" aria-label="Footer Directory">
      {SITE_FOOTER_COLUMNS.map(column => (
        <div class="footer-column">
          <h3 class="footer-column-title">{column.title}</h3>
          <ul class="footer-list">
            {column.links.map(link => (
              <li>
                {link.action === 'cookie-settings' ? (
                  <a
                    href="#"
                    onclick="event.preventDefault(); if(window.DemlWidgets) window.DemlWidgets.openCookieSettings();"
                  >
                    {link.label}
                  </a>
                ) : link.action === 'bug-report' ? (
                  <a href={resolveFooterHref(link, 'marketing', urls)}>{link.label}</a>
                ) : (
                  <a href={resolveFooterHref(link, 'marketing', urls)}>{link.label}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

    <section class="footer-bottom">
      <div class="footer-badges-top">
        <span class="usa-badge" id="usa-badge">
          <span class="usa-badge-icon" aria-hidden="true">🇺🇸</span>
          <span>Made in the U.S.A</span>
        </span>
      </div>

        <div class="footer-compliance-row">
          <div class="copyright-info">
            <span class="copyright-text">
              Copyright © {currentYear} Data Engineering for Machine Learning by{' '}
              <a href="https://joealongi.dev/" target="_blank" rel="noopener noreferrer">Joe Alongi</a>.
              All rights reserved.
            </span>
          </div>
        </div>
    </section>
  </div>
</footer>

<script>
  import confetti from 'canvas-confetti';

  const USA_CONFETTI_COLORS = ['#ff0000', '#ffffff', '#0000ff'];

  const fireUsaConfetti = (target: HTMLElement) => {
    const rect = target.getBoundingClientRect();
    confetti({
      particleCount: 50,
      spread: 60,
      colors: USA_CONFETTI_COLORS,
      disableForReducedMotion: true,
      zIndex: 9999,
      origin: {
        x: (rect.left + rect.width / 2) / window.innerWidth,
        y: (rect.top + rect.height / 2) / window.innerHeight,
      },
    });
  };

  const bindUsaBadgeConfetti = () => {
    const usaBadge = document.getElementById('usa-badge');
    if (!usaBadge || usaBadge.dataset.confettiBound === 'true') return;
    usaBadge.dataset.confettiBound = 'true';
    usaBadge.addEventListener('mouseenter', () => fireUsaConfetti(usaBadge));
  };

  bindUsaBadgeConfetti();
  document.addEventListener('astro:page-load', bindUsaBadgeConfetti);
</script>
