---
import { siteEnv } from '../lib/site-env';

const { FRONTEND_URL, BACKEND_URL, MARKETING_URL } = siteEnv();
const currentYear = new Date().getFullYear();
---

<viking-site-footer
  context="marketing"
  app-url={FRONTEND_URL}
  backend-url={BACKEND_URL}
  marketing-url={MARKETING_URL}
  year={currentYear}
/>
