---
import VikingIcon from './VikingIcon.astro';
import { isIntegrationBrandIcon } from '../../../frontend/projects/viking-ui/src/lib/core/integration-brand-icons.ts';

export interface Props {
  icon: string;
  title: string;
  headingLevel?: 'h2' | 'h3';
  size?: 'md' | 'lg';
}

const { icon, title, headingLevel = 'h3', size = 'md' } = Astro.props;
const HeadingTag = headingLevel;
const isProductBrand = isIntegrationBrandIcon(icon);
---

<div class:list={['viking-icon-heading', size === 'lg' && 'viking-icon-heading--lg']}>
  <span
    class:list={['viking-icon-heading__icon', isProductBrand && 'viking-icon-heading__icon--brand']}
    aria-hidden="true"
  >
    <VikingIcon name={icon} size={24} color={isProductBrand ? 'inherit' : 'accent'} />
  </span>
  <HeadingTag class="viking-icon-heading__title">{title}</HeadingTag>
</div>
