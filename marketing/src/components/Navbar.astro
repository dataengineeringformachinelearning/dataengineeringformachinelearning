---
import VikingIcon from './VikingIcon.astro';
import { siteEnv } from '../lib/site-env';
import {
  SITE_NAV_LINKS,
  resolveNavHref,
  resolveBrandHref,
} from '../../../frontend/projects/viking-ui/src/lib/site-chrome/site-chrome.config';

const { FRONTEND_URL, BACKEND_URL, MARKETING_URL } = siteEnv();
const urls = { app: FRONTEND_URL, marketing: MARKETING_URL, backend: BACKEND_URL };
const navLinks = SITE_NAV_LINKS;
const brandHref = resolveBrandHref('marketing', urls);
---

<script define:vars={{ FRONTEND_URL, BACKEND_URL, MARKETING_URL }}>
  window.__DEML = { FRONTEND_URL, BACKEND_URL, MARKETING_URL };
</script>

<header class="navbar">
  <div class="navbar-content">
    <div class="navbar-left">
      <a href={brandHref} class="navbar-brand" aria-label="Go to homepage" id="navbar-brand-link">
        <VikingIcon name="deml" size={28} class="brand-icon navbar-logo glowing-icon-sm" />
      </a>
    </div>

    <nav class="navbar-center desktop-nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={resolveNavHref(link, 'marketing', urls)} class="nav-btn">
          <VikingIcon name={link.icon} size={16} />
          <span>{link.label}</span>
        </a>
      ))}
    </nav>

    <div class="navbar-right">
      <div class="navbar-search" role="search">
        <div id="autocomplete" class="algolia-autocomplete-host"></div>
        <button
          type="button"
          class="navbar-search-mobile-btn"
          aria-label="Open search"
          onclick="if(window.DemlWidgets) window.DemlWidgets.openSearch()"
        >
          <VikingIcon name="search" size={20} />
        </button>
      </div>

      <div class="desktop-auth">
        <a href={`${FRONTEND_URL}/login`} class="auth-btn" id="auth-btn-desktop">
          <span id="auth-icon-desktop"><VikingIcon name="arrow-right" size={16} /></span>
          <span id="auth-text-desktop">Sign In</span>
        </a>
      </div>

      <button type="button" class="theme-toggle-btn" aria-label="Toggle light and dark theme" id="theme-toggle-btn">
        <span id="theme-icon"><VikingIcon name="sun" size={24} /></span>
      </button>

      <button
        type="button"
        class="menu-toggle-btn"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        id="mobile-menu-btn"
      >
        <span id="menu-icon"><VikingIcon name="menu" size={24} /></span>
      </button>
    </div>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation">
    {navLinks.map(link => (
      <a href={resolveNavHref(link, 'marketing', urls)} class="mobile-nav-btn">
        <VikingIcon name={link.icon} size={16} />
        <span>{link.label}</span>
      </a>
    ))}

    <div class="mobile-divider"></div>

    <a href={`${FRONTEND_URL}/login`} class="mobile-auth-btn" id="auth-btn-mobile">
      <span id="auth-icon-mobile"><VikingIcon name="arrow-right" size={16} /></span>
      <span id="auth-text-mobile">Sign In</span>
    </a>
  </nav>
</header>

<script is:inline src="/assets/widgets/navbar.js" defer></script>
