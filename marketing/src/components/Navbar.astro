---
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? '';
const MAIN_APP = import.meta.env.PUBLIC_MAIN_APP_URL ?? '';
---

<script>
  (window as any).__DEML = {
    API_BASE: import.meta.env.PUBLIC_API_BASE ?? '',
    MAIN_APP: import.meta.env.PUBLIC_MAIN_APP_URL ?? '',
  };
</script>
<header class="navbar">
  <div class="navbar-content">
    <div class="navbar-left">
      <a href="/" class="navbar-brand" aria-label="Go to homepage" id="navbar-brand-link">
        <span class="material-icons brand-icon navbar-logo glowing-icon-sm" aria-hidden="true">analytics</span>
      </a>
    </div>

    <!-- Centered Nav Links -->
    <div class="navbar-center desktop-nav">
      <a href={MAIN_APP + '/explore'} class="nav-btn">
        <span class="material-icons">explore</span>
        <span>Explore</span>
      </a>
      <a href="/documentation" class="nav-btn">
        <span class="material-icons">description</span>
        <span>Documentation</span>
      </a>
    </div>

    <div class="navbar-right">
      <div class="desktop-auth">
        <a href={MAIN_APP + '/login'} class="auth-btn" id="auth-btn-desktop">
          <span class="material-icons" id="auth-icon-desktop">login</span>
          <span id="auth-text-desktop">Sign In</span>
        </a>
      </div>

      <!-- Theme Switch Button -->
      <button class="theme-toggle-btn" aria-label="Toggle light and dark theme" id="theme-toggle-btn">
        <span class="material-icons" id="theme-icon">light_mode</span>
      </button>

      <!-- Hamburger Menu Toggle Button (Mobile) -->
      <button class="menu-toggle-btn" aria-label="Toggle navigation menu" aria-expanded="false" id="mobile-menu-btn">
        <span class="material-icons" id="menu-icon">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Collapsible Menu Dropdown -->
  <div class="mobile-menu" id="mobile-menu">
    <a href={MAIN_APP + '/explore'} class="mobile-nav-btn">
      <span class="material-icons">explore</span>
      <span>Explore</span>
    </a>
    <a href="/documentation" class="mobile-nav-btn">
      <span class="material-icons">description</span>
      <span>Documentation</span>
    </a>

    <div class="mobile-divider"></div>

    <a href={MAIN_APP + '/login'} class="mobile-auth-btn" id="auth-btn-mobile">
      <span class="material-icons" id="auth-icon-mobile">login</span>
      <span id="auth-text-mobile">Sign In</span>
    </a>
  </div>
</header>

<style lang="scss">
.navbar {
  position: sticky;
  top: 0;
  z-index: 50;
  width: 100%;
  height: 64px;
  background-color: var(--navbar-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border-layout);
  display: flex;
  align-items: center;
  padding: 0 24px;
  box-sizing: border-box;
}

.navbar-brand {
  margin-right: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
}

.navbar-logo {
  font-size: 32px;
  width: 32px;
  height: 32px;
  color: var(--color-primary);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: none;
  margin: 0;
}

.navbar-left {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.navbar-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
}

.navbar-center {
  display: flex;
  justify-content: center;
}

.desktop-nav {
  display: none;
  align-items: center;
  gap: 8px;
}

.desktop-auth {
  display: none;
  align-items: center;
  gap: 8px;
}

.nav-btn {
  font-size: 1rem !important;
  color: var(--text-muted) !important;
  font-weight: 600 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.08em !important;
  transition: var(--transition-smooth) !important;
  border-radius: var(--border-radius-sm) var(--border-radius-sm) 0 0 !important;
  padding: 0 16px !important;
  height: 40px !important;
  line-height: 40px !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  text-decoration: none;

  .material-icons {
    margin: 0;
    font-size: var(--base-font-size);
    width: 16px;
    height: 16px;
  }

  &:hover {
    color: var(--text-color) !important;
    background-color: rgba(33, 118, 255, 0.05) !important;
  }
}

.theme-toggle-btn {
  color: var(--text-muted) !important;
  transition: color 0.2s, transform 0.2s;
  background: transparent;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;

  &:hover {
    color: var(--text-color) !important;
    transform: rotate(15deg);
  }
}

.menu-toggle-btn {
  display: inline-flex !important;
  color: var(--text-muted) !important;
  transition: color 0.2s;
  background: transparent;
  border: none;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;

  &:hover {
    color: var(--text-color) !important;
  }
}

.auth-btn {
  background: var(--color-dark-grey-btn-bg) !important;
  color: var(--color-dark-grey-btn-text) !important;
  font-weight: 600 !important;
  border-radius: 96px !important; // Pill shape
  padding: 0 16px !important;
  box-shadow: var(--shadow-sm) !important;
  text-transform: uppercase !important;
  letter-spacing: 0.1em !important;
  border: 1px solid var(--border) !important;
  transition: var(--transition-smooth) !important;
  height: 40px !important;
  line-height: 40px !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  white-space: nowrap !important;
  text-decoration: none;
  cursor: pointer;

  .material-icons {
    margin: 0;
    font-size: var(--base-font-size);
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  &:hover {
    transform: translateY(-2px) !important;
    background-color: var(--hover-color) !important;
    border-color: var(--crayola-blue) !important;
    color: var(--text-color) !important;
    box-shadow: var(--shadow-md) !important;

    .material-icons {
      transform: translateX(2px);
    }
  }
}

.mobile-menu {
  display: none;
  flex-direction: column;
  position: absolute;
  top: 64px;
  left: 0;
  right: 0;
  width: auto;
  background-color: var(--card-bg);
  box-shadow: var(--shadow-md);
  border-bottom: 1px solid var(--border);
  padding: 24px;
  box-sizing: border-box;
  z-index: 49;
  gap: 8px;
  transform: translateY(-10px);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease;

  &.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
    display: flex;
  }
}

.mobile-nav-btn {
  width: 100% !important;
  justify-content: flex-start !important;
  font-size: 1rem !important;
  color: var(--text-muted) !important;
  height: 40px !important;
  line-height: 40px !important;
  border-radius: var(--border-radius-sm) !important;
  padding: 0 16px !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  text-decoration: none;
  box-sizing: border-box;

  .material-icons {
    margin: 0;
    font-size: 20px;
    width: 16px;
    height: 16px;
  }

  &:hover {
    color: var(--text-color) !important;
    background-color: rgba(33, 118, 255, 0.05) !important;
  }
}

.mobile-divider {
  height: 0px;
  background-color: var(--border);
  margin: 8px 0;
}

.mobile-auth-btn {
  width: 100% !important;
  height: 40px !important;
  line-height: 40px !important;
  justify-content: center !important;
  border-radius: 96px !important; // Pill shape
  background: var(--color-dark-grey-btn-bg) !important;
  color: var(--color-dark-grey-btn-text) !important;
  font-weight: 600 !important;
  border: none !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  white-space: nowrap !important;
  text-decoration: none;
  cursor: pointer;
  box-sizing: border-box;
}

@media (min-width: 768px) {
  .desktop-nav {
    display: flex;
  }

  .desktop-auth {
    display: flex;
  }

  .menu-toggle-btn {
    display: none !important;
  }

  .mobile-menu {
    display: none !important;
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Theme logic
    const themeBtn = document.getElementById('theme-toggle-btn');
    const themeIcon = document.getElementById('theme-icon');

    function updateThemeIcon() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      themeIcon.textContent = isDark ? 'light_mode' : 'dark_mode';
    }

    updateThemeIcon();

    themeBtn.addEventListener('click', () => {
      let currentTheme = document.documentElement.getAttribute('data-theme');
      let newTheme = currentTheme === 'dark' ? 'light' : 'dark';

      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);

      if (newTheme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      updateThemeIcon();
    });

    // Mobile menu logic
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuIcon = document.getElementById('menu-icon');
    const mobileMenu = document.getElementById('mobile-menu');

    menuBtn.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.contains('open');
      if (isOpen) {
        mobileMenu.classList.remove('open');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuIcon.textContent = 'menu';
      } else {
        mobileMenu.classList.add('open');
        menuBtn.setAttribute('aria-expanded', 'true');
        menuIcon.textContent = 'close';
      }
    });

    // Auth Handoff Logic - informs this marketing site of sign-in state from the main app.
    // Triggered when navigating from the signed-in Angular app via authService.navigateToMarketingSite()
    // which generates a short-lived one-time token and redirects here with ?session_handoff=TOKEN
    // This sets a localStorage flag so UI can reflect logged-in state (e.g. show Dashboard instead of Sign In).

    const config = (window as any).__DEML ?? {};
    const API_BASE = config.API_BASE ?? '';
    const MAIN_APP = config.MAIN_APP ?? '';

    async function checkAuthHandoff() {
      const urlParams = new URLSearchParams(window.location.search);
      const handoffToken = urlParams.get('session_handoff');

      if (handoffToken) {
        try {
          const res = await fetch(`${API_BASE}/api/v1/auth/handoff/verify`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ token: handoffToken })
          });

          if (res.ok) {
            const data = await res.json();
            if (data.status === 'success') {
              // Set for backward compat and expiry
              const expiry = Date.now() + (24 * 60 * 60 * 1000);
              localStorage.setItem('deml_session_active', JSON.stringify({ active: true, expires: expiry, user: data.user }));
              // Update UI using the status
              updateAuthUIFromStatus({ isAuthenticated: true, ...data });
            }
          }
        } catch (e) {
          console.error('Failed to verify handoff token', e);
        }

        // Clean URL to remove the token (one-time use)
        const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.replaceState({path: cleanUrl}, '', cleanUrl);
      }

      // Update UI based on cached flag if no iframe response yet
      const flag = localStorage.getItem('deml_session_active');
      if (flag) {
        try {
          const parsed = JSON.parse(flag);
          if (parsed.active && (!parsed.expires || Date.now() < parsed.expires)) {
            updateAuthUIFromStatus({ isAuthenticated: true, user: parsed.user });
          } else {
            localStorage.removeItem('deml_session_active');
          }
        } catch (e) {
          // legacy
          if (flag === 'true') {
            updateAuthUIFromStatus({ isAuthenticated: true });
          } else {
            localStorage.removeItem('deml_session_active');
          }
        }
      }
    }

    checkAuthHandoff();

    // Shared auth status via iframe postMessage (cross-domain browser context sharing)
    // This allows the marketing site to detect login state on deml.app without explicit redirect/handoff.
    // The iframe loads a page on the main app domain that can access its own Firebase/auth state.
    function checkAuthViaIframe() {
      // Check cached status first (with 5 min TTL to avoid constant loads)
      const cached = localStorage.getItem('deml_auth_status');
      if (cached) {
        try {
          const parsed = JSON.parse(cached);
          if (parsed.timestamp && (Date.now() - parsed.timestamp) < 5 * 60 * 1000) {
            updateAuthUIFromStatus(parsed);
            return;
          }
        } catch (e) {}
      }

      const iframe = document.createElement('iframe');
      iframe.style.display = 'none';
      iframe.style.width = '0';
      iframe.style.height = '0';
      iframe.src = `${MAIN_APP}/auth-status`;
      document.body.appendChild(iframe);

      // Listen for response from the iframe (strict origin check)
      const listener = (event: MessageEvent) => {
        // Accept from main app domain (computed from env, fallback for dev)
        try {
          const mainOrigin = new URL(MAIN_APP).origin;
          if (event.origin !== mainOrigin && !event.origin.includes('localhost') && !event.origin.includes('127.0.0.1')) return;
        } catch (e) {
          // ENV-driven only. If MAIN_APP not set, be conservative and only trust localhost origins.
          if (!event.origin.includes('localhost') && !event.origin.includes('127.0.0.1')) return;
        }
        if (event.data && event.data.type === 'AUTH_STATUS') {
          window.removeEventListener('message', listener);

          // Cache it with short TTL
          const statusWithTime = { ...event.data, timestamp: Date.now() };
          localStorage.setItem('deml_auth_status', JSON.stringify(statusWithTime));

          updateAuthUIFromStatus(event.data);

          // Remove iframe after use
          if (iframe.parentNode) iframe.parentNode.removeChild(iframe);
        }
      };
      window.addEventListener('message', listener);

      // Fallback: remove iframe after timeout if no response
      setTimeout(() => {
        if (iframe.parentNode) iframe.parentNode.removeChild(iframe);
        window.removeEventListener('message', listener);
      }, 10000);
    }

    function updateAuthUIFromStatus(status: any) {
      const isLoggedIn = status.isAuthenticated === true;

      const desktopBtn = document.getElementById('auth-btn-desktop');
      const desktopIcon = document.getElementById('auth-icon-desktop');
      const desktopText = document.getElementById('auth-text-desktop');

      const mobileBtn = document.getElementById('auth-btn-mobile');
      const mobileIcon = document.getElementById('auth-icon-mobile');
      const mobileText = document.getElementById('auth-text-mobile');

      if (isLoggedIn) {
        if (desktopBtn && desktopIcon && desktopText) {
          desktopBtn.href = `${MAIN_APP}/dashboard`;
          desktopIcon.textContent = 'dashboard';
          desktopText.textContent = 'Dashboard';
        }
        if (mobileBtn && mobileIcon && mobileText) {
          mobileBtn.href = `${MAIN_APP}/dashboard`;
          mobileIcon.textContent = 'dashboard';
          mobileText.textContent = 'Dashboard';
        }
      } else {
        // Optionally clear stale flag
        localStorage.removeItem('deml_session_active');
        localStorage.removeItem('deml_auth_status');
        if (desktopBtn && desktopIcon && desktopText) {
          desktopBtn.href = `${MAIN_APP}/login`;
          desktopIcon.textContent = 'login';
          desktopText.textContent = 'Sign In';
        }
        if (mobileBtn && mobileIcon && mobileText) {
          mobileBtn.href = `${MAIN_APP}/login`;
          mobileIcon.textContent = 'login';
          mobileText.textContent = 'Sign In';
        }
      }
    }

    // Run the iframe check on load (in addition to handoff)
    checkAuthViaIframe();
  });
</script>
