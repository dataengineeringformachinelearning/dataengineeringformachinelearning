---
import {
  VIKING_FILLED_ICON_NAMES,
  VIKING_ICON_FILLED_PATHS,
  VIKING_ICON_PATHS,
  VIKING_INTEGRATION_BRAND_SVGS,
  isIntegrationBrandIcon,
  resolveVikingIcon,
  type VikingIntegrationBrandName,
  vikingIconViewBox,
} from '@dataengineeringformachinelearning/viking-ui/icons';

export interface Props {
  name: string;
  size?: number;
  class?: string;
  variant?: 'outline' | 'filled';
  color?: 'accent' | 'muted' | 'inherit';
}

const { name, size = 16, class: className = '', variant = 'outline', color = 'inherit' } =
  Astro.props;
const resolved = resolveVikingIcon(name);
const isBrandIntegration = isIntegrationBrandIcon(resolved);
const isFilled =
  !isBrandIntegration &&
  (variant === 'filled' || (VIKING_FILLED_ICON_NAMES as readonly string[]).includes(resolved));
const paths =
  isFilled && VIKING_ICON_FILLED_PATHS[resolved]
    ? VIKING_ICON_FILLED_PATHS[resolved]
    : (VIKING_ICON_PATHS[resolved] ?? VIKING_ICON_PATHS.info);
const viewBox = vikingIconViewBox(resolved);
const iconColor =
  color === 'accent'
    ? 'var(--viking-accent)'
    : color === 'muted'
      ? 'var(--viking-text-muted)'
      : 'currentColor';
const brandSvg = isBrandIntegration
  ? VIKING_INTEGRATION_BRAND_SVGS[resolved as VikingIntegrationBrandName]
  : null;
---

{isBrandIntegration ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    class={`viking-icon-inline viking-icon-integration-brand ${className}`.trim()}
    aria-hidden="true"
    set:html={brandSvg ?? ''}
  />
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox={viewBox}
    fill={isFilled ? iconColor : 'none'}
    stroke={isFilled ? 'none' : iconColor}
    stroke-width={isFilled ? undefined : '1.8'}
    stroke-linecap={isFilled ? undefined : 'round'}
    stroke-linejoin={isFilled ? undefined : 'round'}
    width={size}
    height={size}
    class={`viking-icon-inline ${className}`.trim()}
    aria-hidden="true"
    set:html={paths}
  />
)}
