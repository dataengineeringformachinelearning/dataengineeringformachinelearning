---
import {
  VIKING_ICON_PATHS,
  VIKING_FILLED_ICON_NAMES,
  resolveVikingIcon,
  vikingIconViewBox,
} from '../../../frontend/projects/viking-ui/src/lib/core/icons.ts';

export interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 16, class: className = '' } = Astro.props;
const resolved = resolveVikingIcon(name);
const paths = VIKING_ICON_PATHS[resolved] ?? VIKING_ICON_PATHS.info;
const filled = (VIKING_FILLED_ICON_NAMES as readonly string[]).includes(resolved);
const viewBox = vikingIconViewBox(resolved);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  fill={filled ? 'currentColor' : 'none'}
  stroke={filled ? 'none' : 'currentColor'}
  stroke-width={filled ? undefined : '1.8'}
  stroke-linecap={filled ? undefined : 'round'}
  stroke-linejoin={filled ? undefined : 'round'}
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
  set:html={paths}
/>
