---
const barHeights = [72, 45, 88, 56, 91, 38, 67, 82, 49, 76, 58, 94];

export interface Props {
  tag?: string;
  title?: string;
  description?: string;
  buttonLabel?: string;
  href?: string;
}

const {
  tag = 'Research & Architecture',
  title = 'The Whitepaper',
  description = 'Defendable architecture for the digital battlefield — event projections, ML-forecasted SLAs, and automated STIX 2.1 threat federation.',
  buttonLabel = 'Read the Specification',
  href = '/whitepaper',
} = Astro.props;
---

<section class="viking-whitepaper-cta" aria-labelledby="whitepaper-cta-title">
  <div class="viking-whitepaper-cta-bg" aria-hidden="true">
    <div class="viking-whitepaper-polars-grid">
{barHeights.map((height) => (
        <span
          class={`viking-bar viking-whitepaper-polars-bar viking-whitepaper-polars-bar-${height}`}
        />
      ))}
    </div>
  </div>

  <div class="viking-whitepaper-cta-content">
    <span class="viking-whitepaper-tag">{tag}</span>
    <h2 id="whitepaper-cta-title" class="viking-whitepaper-title">{title}</h2>
    <p class="viking-whitepaper-description">{description}</p>
    <a href={href} class="viking-btn viking-btn-primary viking-whitepaper-btn">
      {buttonLabel}
    </a>
  </div>
</section>
