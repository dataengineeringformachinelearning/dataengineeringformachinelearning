---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '@dataengineeringformachinelearning/viking-ui/viking-ui.css';
import '@dataengineeringformachinelearning/viking-ui/web-components.js';
import { algoliaEnv } from '../lib/site-env';
import {
	SITE_NAME,
	DEFAULT_OG_IMAGE,
	DEFAULT_OG_IMAGE_ALT,
	TWITTER_SITE,
	AUTHOR_NAME,
	canonicalHref,
} from '../lib/seo';

const algolia = algoliaEnv();

export interface Props {
	title: string;
	description?: string;
	keywords?: string;
	robots?: string;
	ogImage?: string;
	ogImageAlt?: string;
	ogType?: string;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title,
	description = 'Operational intelligence for the digital battlefield — interactive chapters, deployment specifications, and annotated architectural walkthroughs for Data Engineering for Machine Learning.',
	keywords,
	robots = 'index, follow',
	ogImage = DEFAULT_OG_IMAGE,
	ogImageAlt = DEFAULT_OG_IMAGE_ALT,
	ogType = 'website',
	jsonLd,
} = Astro.props;

const canonical = canonicalHref(Astro.url.pathname, Astro.site!);
const ogImageUrl = new URL(ogImage, Astro.site);
const jsonLdPayload = jsonLd
	? Array.isArray(jsonLd)
		? jsonLd
		: [jsonLd]
	: null;
---

<!doctype html>
<html lang="en" data-deml-context="marketing">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		<meta name="author" content={AUTHOR_NAME} />
		<meta name="robots" content={robots} />
		<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
		<meta name="algolia-site-verification" content="687B59B29612DE68" /> <!-- pragma: allowlist secret -->
		<meta name="format-detection" content="telephone=no" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<link rel="canonical" href={canonical} />

		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content="en_US" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonical} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		<meta name="twitter:site" content={TWITTER_SITE} />
		<meta name="twitter:creator" content={TWITTER_SITE} />

		{jsonLdPayload && (
			<script type="application/ld+json" set:html={JSON.stringify(jsonLdPayload.length === 1 ? jsonLdPayload[0] : jsonLdPayload)} />
		)}

		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />
		<meta name="color-scheme" content="light dark" />

		<link
			rel="preload"
			href="/assets/fonts/inter/InterVariable.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>



		<script is:inline>
			(function () {
				var savedTheme = localStorage.getItem('theme');
				var theme = 'dark';
				if (savedTheme === 'light' || savedTheme === 'dark') {
					theme = savedTheme;
				} else {
					var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
					theme = prefersDark ? 'dark' : 'light';
				}
				document.documentElement.setAttribute('data-theme', theme);
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			})();
		</script>

		<script is:inline define:vars={{ algolia }}>
			window.ALGOLIA_CONFIG = {
				appId: algolia.APP_ID,
				apiKey: algolia.API_KEY,
				experienceId: algolia.EXPERIENCE_ID,
				env: algolia.ENV,
				domains: [
					'https://deml.app',
					'https://dataengineeringformachinelearning.com',
					'https://backend.deml.app',
				],
				sitemaps: [
					'https://deml.app/sitemap.xml',
					'https://dataengineeringformachinelearning.com/sitemap-index.xml',
					'https://backend.deml.app/sitemap.xml',
				],
			};
		</script>
		<script is:inline src="/assets/widgets/cookie-consent.js" defer></script>
		<script is:inline src="/assets/widgets/command-palette.js" defer></script>

		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MH3M99CQ80"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-MH3M99CQ80');
		</script>
		<script type="text/javascript">
			(function(c,l,a,r,i,t,y){
				c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
				t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
				y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
			})(window, document, "clarity", "script", "xddv4klojn");
		</script>
	</head>
	<body class="viking-ui-body">
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<Navbar />
		<main id="main-content" tabindex="-1">
			<slot />
		</main>
		<Footer />

	</body>
</html>
