---
import Layout from '../../layouts/Layout.astro';
import VikingIcon from '../../components/VikingIcon.astro';
import { blueNoteHref, formatBlueNoteDate, getBlueNotes } from '../../lib/blue-notes';
import { canonicalHref, webPageJsonLd } from '../../lib/seo';
import { siteEnv } from '../../lib/site-env';

const notes = await getBlueNotes();
const featuredNotes = notes.filter(note => note.data.featured);
const otherNotes = notes.filter(note => !note.data.featured);
const pageTitle = 'Blue Notes — DEML Platform Changes';
const pageDescription =
  'A chronological field log of DEML platform releases, architectural changes, reliability work, and new operator capabilities.';
const { MARKETING_URL } = siteEnv();
const pageUrl = canonicalHref('/blog/', MARKETING_URL);
const pageJsonLd = [
  webPageJsonLd(pageTitle, pageDescription, pageUrl),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'DEML Blue Notes',
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: notes.length,
    itemListElement: notes.map((note, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: note.data.title,
      url: canonicalHref(blueNoteHref(note), MARKETING_URL),
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="DEML changelog, release notes, platform updates, product blog, data engineering, AI engineering, cybersecurity"
  ogType="website"
  jsonLd={pageJsonLd}
>
  <div class="blue-notes-wrapper">

    <!-- Hero Slider for Featured Notes -->
    <header class="blog-hero" aria-label="Featured updates">
      <div class="blog-hero-badge">
        <VikingIcon name="insights" size={20} color="accent" />
        <span>DEML field log</span>
      </div>
      <h1>Blue Notes</h1>
      <p>
        Platform milestones, architectural decisions, and operator capabilities — written in real time as features ship.
      </p>
    </header>

    {featuredNotes.length > 0 && (
    <section class="blog-slider-section" aria-label="Featured notes carousel">
      <div class="blog-slider">
        <div class="blog-slider-track" id="blog-slider-track">
          {featuredNotes.map((note, idx) => (
            <article class="blog-slider-slide" key={idx} aria-label={`Featured: ${note.data.title}`}>
              <a href={blueNoteHref(note)} class="blog-slider-link">
                <div class="blog-slider-content">
                  <span class="viking-badge viking-badge-accent">{note.data.note}</span>
                  <time datetime={note.data.publishedAt.toISOString()}>
                    {formatBlueNoteDate(note.data.publishedAt)}
                  </time>
                  <h2 class="blog-slider-title">{note.data.title}</h2>
                  <p class="blog-slider-summary">{note.data.summary}</p>
                  <ul class="blog-slider-categories" aria-label="Categories">
                    {note.data.categories.map(category => <li>{category}</li>)}
                  </ul>
                </div>
              </a>
            </article>
          ))}
        </div>
        <div class="blog-slider-nav">
          <button
            type="button"
            class="viking-btn viking-btn-outline viking-btn-sm"
            id="blog-slider-prev"
            aria-label="Previous featured note"
          >
            <VikingIcon name="chevron-left" size={18} />
          </button>
          <div class="blog-slider-dots" id="blog-slider-dots">
            {featuredNotes.map((_, idx) => (
              <button
                type="button"
                class={"blog-slider-dot" + (idx === 0 ? " blog-slider-dot-active" : "")}
                aria-label={`Go to slide ${idx + 1}`}
                data-slide={idx}
              ></button>
            ))}
          </div>
          <button
            type="button"
            class="viking-btn viking-btn-outline viking-btn-sm"
            id="blog-slider-next"
            aria-label="Next featured note"
          >
            <VikingIcon name="chevron-right" size={18} />
          </button>
        </div>
      </div>
    </section>
    )}

      <section class="blue-notes-archive" aria-labelledby="notes-archive-title">
        <div class="blue-notes-section-heading">
          <div>
            <span class="section-tag">Chronological archive</span>
            <h2 id="notes-archive-title">Changes over time</h2>
          </div>
          <p>Newest first. Every note is sourced from a shipped platform milestone.</p>
        </div>

        <ol class="blue-notes-timeline">
          {otherNotes.map(note => (
            <li>
              <article class="viking-card blue-note-card">
                <div class="blue-note-timeline-marker" aria-hidden="true"></div>
                <div class="blue-note-card-meta">
                  <span>{note.data.note}</span>
                  <time datetime={note.data.publishedAt.toISOString()}>
                    {formatBlueNoteDate(note.data.publishedAt)}
                  </time>
                </div>
                <h3><a href={blueNoteHref(note)}>{note.data.title}</a></h3>
                <p>{note.data.summary}</p>
                <div class="blue-note-card-footer">
                  <ul class="blue-note-categories" aria-label="Categories">
                    {note.data.categories.map(category => <li>{category}</li>)}
                  </ul>
                  <a class="blue-note-read-link" href={blueNoteHref(note)} aria-label={`Read ${note.data.title}`}>
                    Read note <VikingIcon name="chevron_right" size={18} />
                  </a>
                </div>
              </article>
            </li>
          ))}
        </ol>
      </section>

      <div class="blog-actions">
        <a class="viking-btn viking-btn-outline" href="/blog/rss.xml">
          <VikingIcon name="send" size={18} />
          Follow the RSS feed
        </a>
        <a
          class="viking-btn viking-btn-ghost"
          href="https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning"
          target="_blank"
          rel="noopener noreferrer"
        >
          <VikingIcon name="terminal" size={18} />
          View the engineering record
        </a>
      </div>
    </div>
</Layout>
