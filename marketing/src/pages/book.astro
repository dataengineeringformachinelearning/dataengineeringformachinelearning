---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import fs from 'node:fs';
import { marked } from 'marked';
import { siteEnv } from '../lib/site-env';
import { bookJsonLd, canonicalHref } from '../lib/seo';

const { MARKETING_URL } = siteEnv();
const pageTitle = 'The Book - DEML Platform';
const pageDescription =
  'Interactive chapters, deployment notes, and annotated walkthroughs for Data Engineering for Machine Learning.';
const bookJsonLdPayload = bookJsonLd(pageTitle, pageDescription, canonicalHref('/book', MARKETING_URL));

// Read the markdown file
const pageMarkdownPath = process.cwd() + '/src/assets/content/page.md';
const rawMarkdown = fs.readFileSync(pageMarkdownPath, 'utf-8');

// Parse logic matching the original bookService
const rawChunks = rawMarkdown.split(
  /(?=^## (?:Chapter \d+:|Appendix|My Notes on Deployment & Release|Acknowledgements|Introduction))/m
);

const chapters = [
  {
    title: 'Cover',
    content: '',
  },
];

rawChunks.forEach(chunk => {
  const trimmed = chunk.trim();
  if (!trimmed) return;

  const lines = trimmed.split('\n');
  const firstLine = lines[0];
  const title = firstLine.startsWith('## ')
    ? firstLine.replace('## ', '').trim()
    : 'Introduction';

  chapters.push({
    title,
    content: marked.parse(trimmed),
  });
});

if (chapters.length === 1 && chapters[0].title === 'Cover') {
  chapters.push({
    title: 'Book Content',
    content: marked.parse(rawMarkdown),
  });
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="data engineering book, machine learning guide, MLOps deployment, DEML chapters, cloud run deployment"
  ogType="book"
  jsonLd={bookJsonLdPayload}
>
  <div class="dashboard-page-container dashboard-layout" id="book-app">
    <aside class="dashboard-sidebar no-print">
      <div class="sidebar-search sidebar-extracted-1 u-style-328aaa" tabindex="0" role="button" aria-label="Open search dialog"  onclick="if(window.DemlWidgets) window.DemlWidgets.openSearch()">
        <div class="search-wrapper">
          <VikingIcon name="search" size={20} class="u-style-315c1f" />
          <span class="sidebar-search-placeholder">Search...</span>
          <kbd class="search-shortcut">⌘K</kbd>
        </div>
      </div>

      <div class="sidebar-section">
        <h3 class="section-title">Chapters</h3>
        <div class="page-list" id="chapter-list">
          {chapters.map((chapter, index) => (
            <div
              class={`page-item ${index === 0 ? 'active' : ''}`}
              data-index={index}
              tabindex="0"
              role="button"
            >
              <span class="page-title">{chapter.title}</span>
            </div>
          ))}
        </div>
      </div>
    </aside>

    <div class="dashboard-main dashboard-content-area u-style-ef4080"  id="main-content">
      <div class="content-wrapper page-inner-wrapper">
        <div class="mobile-chapter-select no-print">
          <select id="mobile-chapter-dropdown"  class="u-style-685a53">
            {chapters.map((chapter, index) => (
              <option value={index}>{chapter.title}</option>
            ))}
          </select>
        </div>

        <div class="whitepaper-container">
          <div class="whitepaper-header">
            <div class="section-tag-row u-style-541ffc" >
              <span class="section-tag">The Book</span>
            </div>
            <h1 class="title">Data Engineering for Machine Learning</h1>
            <p class="subtitle">
              Building High-Throughput Event Platforms for Real-Time Detection and Response
            </p>

            <div class="author-meta u-style-17e119" >
              <span>Interactive Guides, Working Notes, & Reference Material for Security Engineers</span>
            </div>

            <div  class="u-style-87f7f1">
              <div class="progress-bar-header u-style-2b2c9a" >
                <span>Reading Progress</span>
                <span class="progress-percentage u-style-c3f737" id="progress-text" >0%</span>
              </div>
              <div class="progress-bar-container u-style-cf687c" >
                <div class="progress-bar-fill u-style-f9a078" id="progress-bar"></div>
              </div>
            </div>
          </div>

          <div id="chapter-contents">
            {chapters.map((chapter, index) => (
              <div class={`chapter-content-view${index === 0 ? ' is-visible-block' : ' is-hidden'}`} id={`chapter-content-${index}`}>
                {chapter.title === 'Cover' ? (
                  <div class="book-cover-page u-style-9c7405" >
                    <div  class="u-style-54df94">
                      <div  class="u-style-bdb450"></div>
                      <div  class="u-style-34ef33"></div>
                      <div  class="u-style-ec5da2">
                        <div  class="u-style-10c394">Interactive Guide</div>
                        <VikingIcon name="rocket_launch" size={20} class="u-style-5c1531" />
                        <h1  class="u-style-c46697">Data Engineering<br />for Machine Learning</h1>
                        <p  class="u-style-85912f">Building High-Throughput Event Platforms</p>
                        <div  class="u-style-fe3035">
                          <a href="https://joealongi.dev/" target="_blank" rel="noopener noreferrer" class="u-style-018404">Joe Alongi</a>
                          <span  class="u-style-19122e">VOL. I</span>
                        </div>
                      </div>
                    </div>
                  </div>
                ) : (
                  <div class="whitepaper-content">
                    <section class="paper-section">
                      <div class="page-transition-container" set:html={chapter.content}></div>
                    </section>
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="pagination-controls-outlined u-style-fef210" >
            <button class="pagination-btn" id="prev-btn" disabled>
              <VikingIcon name="chevron_left" size={20} /> Previous
            </button>
            <span class="page-counter" id="page-counter-text">
              Chapter 1 of {chapters.length}
            </span>
            <button class="pagination-btn" id="next-btn">
              Next <VikingIcon name="chevron_right" size={20} />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style lang="scss">
:global(:root) {
  --book-accent: var(--color-primary-container, var(--viking-teal-400));
  --book-active-gradient: linear-gradient(135deg, color-mix(in srgb, var(--color-surface) 25%, transparent) 0%, rgba(192, 197, 193, 0.08) 100%);
}

/* Book layout uses shared dashboard shell from global.scss */

.sidebar-section {
  padding: 24px 16px;
  overflow-y: auto;
  .section-title { font-size: 1rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin: 0 0 8px 8px; font-weight: 600; }
}

.sidebar-search {
  padding: 16px;
  display: flex; align-items: center; gap: 8px; border-bottom: 1px solid var(--border);
  .search-wrapper {
    width: 100%; display: flex; align-items: center; gap: 8px; background: rgba(0, 0, 0, 0.15); border: 1px solid var(--border); padding: 8px; border-radius: 16px;
  }
}

.page-list { display: flex; flex-direction: column; gap: 8px; }
.page-item {
  padding: 8px 16px; border-radius: 8px; cursor: pointer; transition: all 0.2s ease; border: 1px solid transparent;
  &:hover { background-color: var(--hover-color); border-color: var(--border); }
  &.active {
    background: var(--book-active-gradient); border-color: var(--book-accent); color: var(--book-accent);
    .page-title { color: var(--book-accent); font-weight: 600; }
  }
}

.dashboard-main { flex: 1; display: flex; flex-direction: column; min-width: 0; overflow-y: auto; }
.content-wrapper {
  padding: 24px 16px;
  max-width: 800px;
  margin: 0 auto;
  width: 100%;

  @media (min-width: 768px) {
    padding: 40px 24px;
  }
}

.whitepaper-header { text-align: center; border-bottom: 1px solid var(--border); padding-bottom: 32px; margin-bottom: 48px; }
.title { font-size: 2.25rem; font-weight: 800; line-height: 1.15; margin-bottom: 12px; }
.subtitle { font-size: 1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 24px; }

.whitepaper-content .paper-section {
  background: var(--card-bg); border: 1px solid var(--border); border-radius: 24px; padding: 32px; box-shadow: var(--shadow-sm);
  :global(h2) { font-size: 1.5rem; font-weight: 800; margin: 0 0 16px; color: var(--text-color); }
  :global(h3) { font-size: 1.25rem; font-weight: 700; margin: 24px 0 16px; color: var(--text-color); }
  :global(p) { font-size: 1.05rem; line-height: 1.6; margin: 0 0 16px; }
  :global(pre) { background: rgba(0,0,0,0.2); padding: 16px; border-radius: 8px; overflow-x: auto; margin-bottom: 16px; }
}

.pagination-controls-outlined {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 16px;
  padding: 16px;
  border: 1px solid var(--border);
  border-radius: 16px;
  background: var(--card-bg);

  @media (min-width: 600px) {
    justify-content: space-between;
    padding: 16px 32px;
    gap: 24px;
  }
}
.pagination-btn {
  background: var(--color-primary) !important; color: white !important; font-weight: 600; border-radius: 16px; border: none; padding: 8px 16px; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: opacity 0.2s;
  &[disabled] { opacity: 0.5; cursor: not-allowed; }
  &:not([disabled]):hover { opacity: 0.9; }
}
</style>

<script define:vars={{ totalChapters: chapters.length }}>
  document.addEventListener('DOMContentLoaded', () => {
    let currentIndex = 0;
    const pageItems = document.querySelectorAll('.page-item');
    const contentViews = document.querySelectorAll('.chapter-content-view');
    const mobileSelect = document.getElementById('mobile-chapter-dropdown');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const pageCounter = document.getElementById('page-counter-text');
    const progressBar = document.getElementById('progress-bar');
    const progressText = document.getElementById('progress-text');
    const mainContent = document.getElementById('main-content');

    function updateView() {
      // Sidebar
      pageItems.forEach((item, idx) => {
        if (idx === currentIndex) item.classList.add('active');
        else item.classList.remove('active');
      });

      // Dropdown
      if (mobileSelect) mobileSelect.value = currentIndex;

      // Contents
      contentViews.forEach((view, idx) => {
        if (idx === currentIndex) {
          view.classList.add('is-visible-block');
          view.classList.remove('is-hidden');
        } else {
          view.classList.add('is-hidden');
          view.classList.remove('is-visible-block');
        }
      });

      // Pagination
      if (prevBtn) prevBtn.disabled = currentIndex === 0;
      if (nextBtn) nextBtn.disabled = currentIndex === totalChapters - 1;
      if (pageCounter) pageCounter.textContent = `Chapter ${currentIndex + 1} of ${totalChapters}`;

      // Progress bar
      const pct = Math.round(((currentIndex + 1) / totalChapters) * 100);
      if (progressBar) progressBar.style.setProperty('--progress', `${pct}%`);
      if (progressText) progressText.textContent = pct + '%';

      if (mainContent) mainContent.scrollTo({ top: 0, behavior: 'smooth' });
    }

    pageItems.forEach(item => {
      item.addEventListener('click', (e) => {
        currentIndex = parseInt(e.currentTarget.getAttribute('data-index'));
        updateView();
      });
    });

    if (mobileSelect) {
      mobileSelect.addEventListener('change', (e) => {
        currentIndex = parseInt(e.target.value);
        updateView();
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) { currentIndex--; updateView(); }
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentIndex < totalChapters - 1) { currentIndex++; updateView(); }
      });
    }

    updateView(); // init
  });
</script>
