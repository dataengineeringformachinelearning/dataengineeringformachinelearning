---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import { loadBookChapters } from '../lib/book-chapters';
import { bookJsonLd, canonicalHref } from '../lib/seo';
import { siteEnv } from '../lib/site-env';

const chapters = loadBookChapters();
const { MARKETING_URL } = siteEnv();
const pageTitle = 'The Book - DEML Platform';
const pageDescription =
  'Interactive chapters, deployment notes, and annotated walkthroughs for Data Engineering for Machine Learning.';
const firstChapter = chapters.find(chapter => chapter.slug !== 'cover') ?? chapters[1] ?? chapters[0];
const bookJsonLdPayload = bookJsonLd(pageTitle, pageDescription, canonicalHref('/book', MARKETING_URL));
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="data engineering book, machine learning guide, MLOps deployment, DEML chapters, cloud run deployment"
  ogType="book"
  jsonLd={bookJsonLdPayload}
>
  <div class="dashboard-page-container dashboard-layout book-toc-page" id="main-content">
    <div class="content-wrapper page-inner-wrapper">
      <div class="whitepaper-container book-shell">
        <div class="whitepaper-header book-hero">
          <div class="hero-glow" aria-hidden="true"></div>
          <div class="section-tag-row u-style-541ffc">
            <span class="section-tag">Interactive Reference · {chapters.length - 1} Chapters</span>
          </div>
          <h1 class="title">Data Engineering for Machine Learning</h1>
          <p class="subtitle">
            Building High-Throughput Event Platforms for Real-Time Detection and Response
          </p>
          <div class="author-meta u-style-17e119">
            <span>Interactive Guides, Working Notes, & Reference Material for Security Engineers</span>
          </div>
        </div>

        <div class="book-toc-grid">
          {chapters.map(chapter => (
            <a href={`/book/${chapter.slug}/`} class="book-toc-card">
              <VikingIcon name="menu_book" size={20} />
              <span>{chapter.title}</span>
            </a>
          ))}
        </div>

        {firstChapter && (
          <div class="book-toc-cta">
            <a href={`/book/${firstChapter.slug}/`} class="pagination-btn">
              Start reading <VikingIcon name="chevron_right" size={20} />
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<style lang="scss">
.book-toc-page {
  background:
    radial-gradient(ellipse 60% 40% at 10% 0%, color-mix(in srgb, var(--viking-teal-600) 8%, transparent), transparent),
    var(--bg-color);
}

.book-shell {
  border-radius: 24px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--color-surface) 92%, transparent);
  backdrop-filter: blur(16px);
  padding: 0 0 32px;
  box-shadow: var(--shadow-sm);
}

.book-hero {
  position: relative;
  overflow: hidden;
  padding: 40px 24px 32px;
  border-radius: 24px 24px 0 0;
  border-bottom: 1px solid var(--border);
  text-align: center;

  .hero-glow {
    position: absolute;
    inset: -30% 0 auto;
    height: 200px;
    background: radial-gradient(circle, color-mix(in srgb, var(--viking-teal-600) 15%, transparent), transparent 70%);
    pointer-events: none;
  }

  .title, .subtitle, .author-meta { position: relative; }
}

.title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 12px;
}

.subtitle {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 640px;
  margin: 0 auto 20px;
  line-height: 1.6;
}

.content-wrapper {
  padding: 24px 16px;
  max-width: 900px;
  margin: 0 auto;
  width: 100%;
}

.book-toc-grid {
  display: grid;
  gap: 12px;
  padding: 24px;

  @media (min-width: 640px) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.book-toc-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--card-bg);
  color: var(--text-color);
  text-decoration: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;

  &:hover {
    border-color: color-mix(in srgb, var(--viking-teal-600) 35%, var(--border));
    box-shadow: var(--shadow-sm);
  }
}

.book-toc-cta {
  display: flex;
  justify-content: center;
  padding: 0 24px 8px;
}

.pagination-btn {
  background: var(--color-primary) !important;
  color: white !important;
  font-weight: 600;
  border-radius: 16px;
  border: none;
  padding: 10px 18px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
}
</style>