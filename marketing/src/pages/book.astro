---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import { loadBookChapters, SIDEBAR_GROUPS } from '../lib/book-chapters';
import { bookJsonLd, canonicalHref } from '../lib/seo';
import { siteEnv } from '../lib/site-env';

const chapters = loadBookChapters();
const { MARKETING_URL } = siteEnv();
const pageTitle = 'The Book — DEML Platform';
const pageDescription =
  'Authoritative build specification for operational intelligence on the digital battlefield — interactive chapters, deployment notes, and annotated architectural walkthroughs.';
const firstChapter = chapters.find(chapter => chapter.slug !== 'cover') ?? chapters[1] ?? chapters[0];
const bookJsonLdPayload = bookJsonLd(pageTitle, pageDescription, canonicalHref('/book', MARKETING_URL));
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="data engineering book, ai engineering guide, cybersecurity, MLOps deployment, DEML chapters, cloud run deployment"
  ogType="book"
  jsonLd={bookJsonLdPayload}
>
  <div class="dashboard-page-container book-toc-page" id="main-content">
    <div class="page-inner-wrapper book-toc-wrapper">
      <article class="publication-shell">
        <header class="publication-hero">
          <div class="hero-brand">
            <VikingIcon name="drakkar" size={36} color="accent" class="hero-brand-icon" />
          </div>
          <div class="section-tag-row">
            <span class="section-tag">Interactive Reference · {chapters.length - 1} Chapters</span>
          </div>
          <h1 class="hero-title">Data Engineering for Machine Learning</h1>
          <p class="hero-subtitle">
            Operational Intelligence for the New Digital Battlefield
          </p>
          <p class="hero-meta">
            Authoritative Specification · Interactive Chapters · Reference Material for Security Engineers
          </p>

          <div class="hero-meta-row">
            <a href="/documentation">Integration Guides</a>
            <span class="meta-dot">•</span>
            <a href="/whitepaper">The Whitepaper</a>
            <span class="meta-dot">•</span>
            <a
              href="https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/blob/main/THEME.md"
              target="_blank"
              rel="noopener noreferrer"
            >
              THEME.md
            </a>
          </div>
        </header>

        <nav class="publication-toc" aria-label="Book chapters">
          <h2 class="toc-heading">Contents</h2>
          {SIDEBAR_GROUPS.map(group => {
            const groupChapters = chapters.filter(chapter => chapter.group === group);
            if (groupChapters.length === 0) return null;
            return (
              <div class="book-toc-group">
                <div class="book-toc-group-title">{group}</div>
                <ol class="toc-list">
                  {groupChapters.map(chapter => (
                    <li>
                      <a href={`/book/${chapter.slug}/`} class="toc-item">
                        <span class="toc-num">{chapter.num || '—'}</span>
                        <span class="toc-label">{chapter.shortTitle}</span>
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            );
          })}
        </nav>

        {firstChapter && (
          <div class="book-toc-cta">
            <a href={`/book/${firstChapter.slug}/`} class="book-start-btn">
              Start reading <VikingIcon name="chevron_right" size={20} />
            </a>
          </div>
        )}
      </article>
    </div>
  </div>
</Layout>
