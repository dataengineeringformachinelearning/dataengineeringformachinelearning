---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import fs from 'node:fs';
import { marked } from 'marked';
import { siteEnv } from '../lib/site-env';
import { bookJsonLd, canonicalHref } from '../lib/seo';
import '../styles/publication.scss';

const { MARKETING_URL } = siteEnv();
const pageTitle = 'The Book - DEML Platform';
const pageDescription =
  'Interactive chapters, deployment notes, and annotated walkthroughs for Data Engineering for Machine Learning.';
const bookJsonLdPayload = bookJsonLd(pageTitle, pageDescription, canonicalHref('/book', MARKETING_URL));

type ChapterGroup = 'Front Matter' | 'Chapters' | 'Appendices' | 'Back Matter' | 'Reference';

interface ChapterEntry {
  title: string;
  content: string;
  group: ChapterGroup;
  num: string;
  shortTitle: string;
}

const getChapterMeta = (title: string, index: number): { group: ChapterGroup; num: string; shortTitle: string } => {
  if (title === 'Cover') {
    return { group: 'Front Matter', num: '', shortTitle: 'Cover' };
  }
  if (title === 'Introduction' || title.includes('CONOPS')) {
    return { group: 'Front Matter', num: String(index).padStart(2, '0'), shortTitle: title.replace(/^Concept of Operations \(CONOPS\)$/, 'CONOPS') };
  }
  const chapterMatch = title.match(/^Chapter (\d+):\s*(.+)/);
  if (chapterMatch) {
    return { group: 'Chapters', num: chapterMatch[1].padStart(2, '0'), shortTitle: chapterMatch[2] };
  }
  if (title.startsWith('Appendix')) {
    const appendixMatch = title.match(/^Appendix ([A-Z]):\s*(.+)/);
    return {
      group: 'Appendices',
      num: appendixMatch?.[1] ?? String(index),
      shortTitle: appendixMatch?.[2] ?? title.replace(/^Appendix [A-Z]:\s*/, ''),
    };
  }
  if (title.includes('Acknowledgements') || title.includes('Deployment')) {
    return { group: 'Back Matter', num: String(index).padStart(2, '0'), shortTitle: title };
  }
  return { group: 'Reference', num: String(index).padStart(2, '0'), shortTitle: title };
};

const pageMarkdownPath = process.cwd() + '/src/assets/content/page.md';
const rawMarkdown = fs.readFileSync(pageMarkdownPath, 'utf-8');

const rawChunks = rawMarkdown.split(
  /(?=^## (?:Chapter \d+:|Appendix|My Notes on Deployment & Release|Acknowledgements|Introduction|Concept of Operations))/m
);

const chapters: ChapterEntry[] = [
  {
    title: 'Cover',
    content: '',
    group: 'Front Matter',
    num: '',
    shortTitle: 'Cover',
  },
];

rawChunks.forEach((chunk, chunkIndex) => {
  const trimmed = chunk.trim();
  if (!trimmed) return;

  const lines = trimmed.split('\n');
  const firstLine = lines[0];
  const title = firstLine.startsWith('## ')
    ? firstLine.replace('## ', '').trim()
    : 'Introduction';
  const meta = getChapterMeta(title, chunkIndex + 1);

  chapters.push({
    title,
    content: marked.parse(trimmed) as string,
    ...meta,
  });
});

if (chapters.length === 1 && chapters[0].title === 'Cover') {
  chapters.push({
    title: 'Book Content',
    content: marked.parse(rawMarkdown) as string,
    group: 'Reference',
    num: '01',
    shortTitle: 'Book Content',
  });
}

const sidebarGroups: ChapterGroup[] = ['Front Matter', 'Chapters', 'Appendices', 'Back Matter', 'Reference'];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="data engineering book, machine learning guide, MLOps deployment, DEML chapters, cloud run deployment"
  ogType="book"
  jsonLd={bookJsonLdPayload}
>
  <div class="dashboard-page-container dashboard-layout" id="book-app">
    <aside class="dashboard-sidebar no-print">
      <div
        class="sidebar-search sidebar-extracted-1 u-style-328aaa"
        tabindex="0"
        role="button"
        aria-label="Open search dialog"
        onclick="if(window.DemlWidgets) window.DemlWidgets.openSearch()"
      >
        <div class="search-wrapper">
          <VikingIcon name="search" size={20} class="u-style-315c1f" />
          <span class="sidebar-search-placeholder">Search...</span>
          <kbd class="search-shortcut">⌘K</kbd>
        </div>
      </div>

      <div class="sidebar-section">
        <h3 class="section-title">Table of Contents</h3>
        <div id="chapter-list">
          {sidebarGroups.map(group => {
            const groupChapters = chapters
              .map((chapter, index) => ({ chapter, index }))
              .filter(({ chapter }) => chapter.group === group);
            if (groupChapters.length === 0) return null;
            return (
              <div class="pub-sidebar-group">
                <div class="pub-sidebar-group-title">{group}</div>
                {groupChapters.map(({ chapter, index }) => (
                  <div
                    class={`pub-chapter-item ${index === 0 ? 'active' : ''}`}
                    data-index={index}
                    tabindex="0"
                    role="button"
                  >
                    <span class="pub-chapter-num">{chapter.num || '—'}</span>
                    <span class="pub-chapter-title">{chapter.shortTitle}</span>
                  </div>
                ))}
              </div>
            );
          })}
        </div>
      </div>
    </aside>

    <div class="dashboard-main dashboard-content-area u-style-ef4080" id="main-content">
      <div class="content-wrapper page-inner-wrapper">
        <div class="mobile-chapter-select no-print">
          <select id="mobile-chapter-dropdown" class="u-style-685a53">
            {chapters.map((chapter, index) => (
              <option value={index}>{chapter.title}</option>
            ))}
          </select>
        </div>

        <article class="publication-shell">
          <header class="publication-hero">
            <div class="hero-glow" aria-hidden="true"></div>
            <div class="hero-brand">
              <VikingIcon name="drakkar" size={36} color="accent" class="hero-brand-icon" />
            </div>
            <div class="section-tag-row u-style-541ffc">
              <span class="section-tag">Interactive Reference · {chapters.length - 1} Chapters</span>
            </div>
            <h1 class="hero-title">Data Engineering for Machine Learning</h1>
            <p class="hero-subtitle">
              Building High-Throughput Event Platforms for Real-Time Detection and Response
            </p>
            <p class="hero-meta">
              Interactive Guides, Working Notes, & Reference Material for Security Engineers
            </p>

            <div class="hero-meta-row no-print">
              <a href="/documentation">Integration Guides</a>
              <span class="meta-dot">•</span>
              <a href="/whitepaper">The Whitepaper</a>
              <span class="meta-dot">•</span>
              <a
                href="https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/blob/main/THEME.md"
                target="_blank"
                rel="noopener noreferrer"
              >
                THEME.md
              </a>
            </div>

            <div class="publication-progress no-print">
              <div class="progress-bar-header">
                <span>Reading Progress</span>
                <span class="progress-percentage" id="progress-text">0%</span>
              </div>
              <div class="progress-bar-container">
                <div class="progress-bar-fill" id="progress-bar"></div>
              </div>
            </div>
          </header>

          <div class="publication-body" id="chapter-contents">
            {chapters.map((chapter, index) => (
              <div
                class={`chapter-content-view${index === 0 ? ' is-visible-block' : ' is-hidden'}`}
                id={`chapter-content-${index}`}
              >
                {chapter.title === 'Cover' ? (
                  <div class="book-cover-page">
                    <div class="book-cover-card">
                      <div class="book-cover-spine"></div>
                      <div class="book-cover-binding"></div>
                      <div class="book-cover-inner">
                        <div class="book-cover-label">Interactive Guide</div>
                        <VikingIcon name="drakkar" size={72} color="accent" class="book-cover-logo" />
                        <h1 class="book-cover-title">
                          Data Engineering<br />for Machine Learning
                        </h1>
                        <p class="book-cover-subtitle">Building High-Throughput Event Platforms</p>
                        <div class="book-cover-footer">
                          <a href="https://joealongi.dev/" target="_blank" rel="noopener noreferrer">
                            Joe Alongi
                          </a>
                          <span class="book-cover-vol">VOL. I</span>
                        </div>
                      </div>
                    </div>
                  </div>
                ) : (
                  <section class="publication-section">
                    <div set:html={chapter.content}></div>
                  </section>
                )}
              </div>
            ))}
          </div>

          <nav class="publication-pagination no-print" aria-label="Chapter navigation">
            <button class="pagination-btn" id="prev-btn" disabled>
              <VikingIcon name="chevron_left" size={20} /> Previous
            </button>
            <span class="page-counter" id="page-counter-text">
              Chapter 1 of {chapters.length}
            </span>
            <button class="pagination-btn" id="next-btn">
              Next <VikingIcon name="chevron_right" size={20} />
            </button>
          </nav>
        </article>
      </div>
    </div>
  </div>
</Layout>

<style lang="scss">
#book-app {
  background:
    radial-gradient(ellipse 60% 40% at 10% 0%, color-mix(in srgb, var(--viking-teal-600) 8%, transparent), transparent),
    var(--bg-color);
}

.sidebar-section {
  padding: 16px 12px 24px;
  overflow-y: auto;

  .section-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 12px 8px;
    font-weight: 700;
  }
}

.sidebar-search {
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid var(--border);

  .search-wrapper {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid var(--border);
    padding: 8px;
    border-radius: 12px;
  }
}

.dashboard-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow-y: auto;
}

.content-wrapper {
  padding: 24px 16px;
  max-width: 820px;
  margin: 0 auto;
  width: 100%;

  @media (min-width: 768px) {
    padding: 32px 24px 48px;
  }
}
</style>

<script define:vars={{ totalChapters: chapters.length }}>
  document.addEventListener('DOMContentLoaded', () => {
    let currentIndex = 0;
    const pageItems = document.querySelectorAll('.pub-chapter-item');
    const contentViews = document.querySelectorAll('.chapter-content-view');
    const mobileSelect = document.getElementById('mobile-chapter-dropdown');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const pageCounter = document.getElementById('page-counter-text');
    const progressBar = document.getElementById('progress-bar');
    const progressText = document.getElementById('progress-text');
    const mainContent = document.getElementById('main-content');

    const updateView = () => {
      pageItems.forEach((item, idx) => {
        if (idx === currentIndex) item.classList.add('active');
        else item.classList.remove('active');
      });

      if (mobileSelect) mobileSelect.value = currentIndex;

      contentViews.forEach((view, idx) => {
        if (idx === currentIndex) {
          view.classList.add('is-visible-block');
          view.classList.remove('is-hidden');
        } else {
          view.classList.add('is-hidden');
          view.classList.remove('is-visible-block');
        }
      });

      if (prevBtn) prevBtn.disabled = currentIndex === 0;
      if (nextBtn) nextBtn.disabled = currentIndex === totalChapters - 1;
      if (pageCounter) pageCounter.textContent = `Chapter ${currentIndex + 1} of ${totalChapters}`;

      const pct = Math.round(((currentIndex + 1) / totalChapters) * 100);
      if (progressBar) progressBar.style.setProperty('--progress', `${pct}%`);
      if (progressText) progressText.textContent = pct + '%';

      if (mainContent) mainContent.scrollTo({ top: 0, behavior: 'smooth' });
    };

    pageItems.forEach(item => {
      item.addEventListener('click', e => {
        currentIndex = parseInt(e.currentTarget.getAttribute('data-index'));
        updateView();
      });
    });

    if (mobileSelect) {
      mobileSelect.addEventListener('change', e => {
        currentIndex = parseInt(e.target.value);
        updateView();
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
          currentIndex--;
          updateView();
        }
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentIndex < totalChapters - 1) {
          currentIndex++;
          updateView();
        }
      });
    }

    updateView();
  });
</script>
