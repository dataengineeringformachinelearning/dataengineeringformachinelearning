---
import Layout from '../../layouts/Layout.astro';
import VikingIcon from '../../components/VikingIcon.astro';
import { loadBookChapters, SIDEBAR_GROUPS } from '../../lib/book-chapters';
import { bookJsonLd, canonicalHref } from '../../lib/seo';
import { siteEnv } from '../../lib/site-env';

export function getStaticPaths() {
  const chapters = loadBookChapters();
  return chapters.map(chapter => ({
    params: { slug: chapter.slug },
    props: { chapter, chapters },
  }));
}

const { chapter, chapters } = Astro.props;
const { MARKETING_URL } = siteEnv();
const pageTitle = `${chapter.title} - The Book - DEML Platform`;
const pageDescription = `Chapter from Data Engineering for Machine Learning: ${chapter.title}`;
const bookJsonLdPayload = bookJsonLd(
  pageTitle,
  pageDescription,
  canonicalHref(`/book/${chapter.slug}`, MARKETING_URL),
);
const progressPct = Math.round(((chapter.index + 1) / chapters.length) * 100);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="data engineering book, ai engineering guide, cybersecurity, MLOps deployment, DEML chapters"
  ogType="article"
  jsonLd={bookJsonLdPayload}
>
  <div class="dashboard-page-container dashboard-layout" id="book-app">
    <aside class="dashboard-sidebar no-print">
      <a href="/book/" class="sidebar-search sidebar-extracted-1 book-toc-link">
        <div class="search-wrapper">
          <VikingIcon name="menu_book" size={20} />
          <span class="sidebar-search-placeholder">All chapters</span>
        </div>
      </a>

      <div class="sidebar-section">
        <h3 class="section-title">Table of Contents</h3>
        <nav aria-label="Book chapters">
          {SIDEBAR_GROUPS.map(group => {
            const groupChapters = chapters.filter(item => item.group === group);
            if (groupChapters.length === 0) return null;
            return (
              <div class="pub-sidebar-group">
                <div class="pub-sidebar-group-title">{group}</div>
                {groupChapters.map(item => (
                  <a
                    href={`/book/${item.slug}/`}
                    class:list={['pub-chapter-item', { active: item.slug === chapter.slug }]}
                  >
                    <span class="pub-chapter-num">{item.num || '—'}</span>
                    <span class="pub-chapter-title">{item.shortTitle}</span>
                  </a>
                ))}
              </div>
            );
          })}
        </nav>
      </div>
    </aside>

    <div class="dashboard-main dashboard-content-area" id="main-content">
      <div class="content-wrapper page-inner-wrapper">
        <article class="publication-shell">
          {chapter.slug !== 'cover' && (
            <header class="publication-hero book-chapter-hero">
              <div class="section-tag-row">
                <span class="section-tag">
                  {chapter.group} · {chapter.num ? `#${chapter.num}` : chapter.shortTitle}
                </span>
              </div>
              <h1 class="hero-title">{chapter.shortTitle}</h1>
              <div class="publication-progress no-print">
                <div class="progress-bar-header">
                  <span>Reading Progress</span>
                  <span class="progress-percentage">{progressPct}%</span>
                </div>
                <div class="progress-bar-container">
                  <progress
                    class="progress-bar-fill"
                    value={progressPct}
                    max="100"
                    aria-label={`Reading progress: ${progressPct}%`}
                  ></progress>
                </div>
              </div>
            </header>
          )}

          <div class="publication-body">
            {chapter.slug === 'cover' ? (
              <div class="book-cover-page">
                <div class="viking-card book-cover-card">
                  <div class="book-cover-spine"></div>
                  <div class="book-cover-binding"></div>
                  <div class="book-cover-inner">
                    <div class="book-cover-label">Interactive Guide</div>
                    <VikingIcon name="drakkar" size={72} color="accent" class="book-cover-logo" />
                    <h1 class="book-cover-title">
                      Data Engineering<br />for Machine Learning
                    </h1>
                    <p class="book-cover-subtitle">Building High-Throughput Event Platforms</p>
                    <div class="book-cover-footer">
                      <a href="https://joealongi.dev/" target="_blank" rel="noopener noreferrer">
                        Joe Alongi
                      </a>
                      <span class="book-cover-vol">VOL. I</span>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <section class="publication-section">
                <div set:html={chapter.html}></div>
              </section>
            )}
          </div>

          <nav class="publication-pagination no-print" aria-label="Chapter navigation">
            {chapter.index > 0 ? (
              <a class="pagination-btn" href={`/book/${chapters[chapter.index - 1].slug}/`}>
                <VikingIcon name="chevron_left" size={20} /> Previous
              </a>
            ) : (
              <span class="pagination-btn" aria-disabled="true">
                <VikingIcon name="chevron_left" size={20} /> Previous
              </span>
            )}
            <span class="page-counter">
              Chapter {chapter.index + 1} of {chapters.length}
            </span>
            {chapter.index < chapters.length - 1 ? (
              <a class="pagination-btn" href={`/book/${chapters[chapter.index + 1].slug}/`}>
                Next <VikingIcon name="chevron_right" size={20} />
              </a>
            ) : (
              <span class="pagination-btn" aria-disabled="true">
                Next <VikingIcon name="chevron_right" size={20} />
              </span>
            )}
          </nav>
        </article>
      </div>
    </div>
  </div>
</Layout>
