---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import DocsCta from '../components/DocsCta.astro';
import DocsCtaGroup from '../components/DocsCtaGroup.astro';
import DocsBentoCard from '../components/DocsBentoCard.astro';
import DocsBentoGrid from '../components/DocsBentoGrid.astro';
import IconHeading from '../components/IconHeading.astro';
import PageMockup from '../components/PageMockup.astro';
import { siteEnv } from '../lib/site-env';
import { techArticleJsonLd, canonicalHref } from '../lib/seo';
import { blueNoteHref, formatBlueNoteDate, getBlueNotes } from '../lib/blue-notes';

const { MARKETING_URL, BACKEND_URL } = siteEnv();
const swaggerUrl = `${BACKEND_URL.replace(/\/$/, '')}/api/v1/docs`;

// Latest field-log entries (Blue Notes) surfaced directly on the docs page.
const blueNotes = await getBlueNotes();
const recentNotes = blueNotes.slice(0, 4);
const pageTitle = 'Developer Portal — DEML Platform';
const pageDescription =
  'Hardened API gateway for the digital battlefield. First-class integration specifications for Kubernetes, TensorFlow, PyTorch, Apache Spark, Databricks, and AWS Redshift — plus telemetry ingestion and inference endpoints.';
const docsJsonLd = techArticleJsonLd(
  pageTitle,
  pageDescription,
  canonicalHref('/documentation', MARKETING_URL),
);

const { FRONTEND_URL } = siteEnv();

const integrationPlatforms = [
  {
    icon: 'kubernetes',
    name: 'Kubernetes',
    summary: 'Sidecar proxy or cluster gateway for /predict and /ingest without exposing API keys in app code.',
    exampleLabel: 'Sidecar env',
    example: `DEML_UPSTREAM_URL=https://backend.deml.app/api/v1
DEML_API_KEY=<from Secret>`,
    guide: 'docs/integrations/kubernetes.md',
    health: '/api/v1/integrations/kubernetes',
  },
  {
    icon: 'tensorflow',
    name: 'TensorFlow',
    summary: 'Stream training batches into tf.data.Dataset pipelines with prefetch and autotune.',
    exampleLabel: 'Dataset',
    example: `dataset = tf.data.Dataset.from_generator(...)
dataset.batch(32).prefetch(AUTOTUNE)`,
    guide: 'docs/integrations/tensorflow.md',
    health: '/api/v1/integrations/tensorflow',
  },
  {
    icon: 'pytorch',
    name: 'PyTorch',
    summary: 'Back custom Dataset and DataLoader classes with remote ingest. Models ship as state_dict — no pickle.',
    exampleLabel: 'DataLoader',
    example: `loader = DataLoader(DemlRemoteDataset(), batch_size=64)
for features, labels in loader: ...`,
    guide: 'docs/integrations/pytorch.md',
    health: '/api/v1/integrations/pytorch',
  },
  {
    icon: 'apache-spark',
    name: 'Apache Spark',
    summary: 'Push batch and Structured Streaming micro-batches directly to ingestion endpoints.',
    exampleLabel: 'Streaming',
    example: `payload.writeStream
  .foreachBatch(write_batch)
  .start()`,
    guide: 'docs/integrations/apache-spark.md',
    health: '/api/v1/integrations/apache-spark',
  },
  {
    icon: 'databricks',
    name: 'Databricks',
    summary: 'Store API keys in Secret Scopes, ingest from notebooks, and schedule hourly rollup jobs.',
    exampleLabel: 'Secret Scope',
    example: `api_key = dbutils.secrets.get(
  scope="deml", key="api-key")`,
    guide: 'docs/integrations/databricks.md',
    health: '/api/v1/integrations/databricks',
  },
  {
    icon: 'aws-redshift',
    name: 'AWS Redshift',
    summary: 'UNLOAD warehouse rollups to S3 or query via the Data API, then POST batches to /ingest.',
    exampleLabel: 'UNLOAD + ingest',
    example: `requests.post(INGEST_URL,
  headers={"Authorization": f"Bearer {api_key}"},
  json={"source": "aws-redshift", "records": rows})`,
    guide: 'docs/integrations/redshift.md',
    health: '/api/v1/integrations/redshift',
  },
];

const docsOutline = [
  { id: 'quick-start', label: 'Quick Start', icon: 'rocket_launch' },
  { id: 'data-ingestion', label: 'Data Ingestion', icon: 'input' },
  { id: 'platform-operations', label: 'Platform Ops', icon: 'settings_suggest' },
  { id: 'integrations-title', label: 'Integrations', icon: 'hub' },
  { id: 'health-checks', label: 'Health Checks', icon: 'monitor_heart' },
  { id: 'blue-notes', label: 'Blue Notes', icon: 'insights' },
];

const quickStartSteps = [
  {
    icon: 'person_add',
    title: 'Create an account',
    description: 'Sign up free — no credit card required for the Standard tier.',
    href: FRONTEND_URL + '/login',
    authenticatedHref: FRONTEND_URL + '/dashboard',
  },
  {
    icon: 'vpn_key',
    title: 'Generate an API key',
    description: 'One key in Settings unlocks ingest, predict, and health endpoints.',
    href: FRONTEND_URL + '/login',
    authenticatedHref: FRONTEND_URL + '/settings',
  },
  {
    icon: 'send',
    title: 'Send your first event',
    description: 'Copy a cURL snippet below and watch telemetry appear in seconds.',
    href: '#data-ingestion',
    authenticatedHref: undefined,
  },
  {
    icon: 'insights',
    title: 'Monitor & improve',
    description: 'Watch live projections and tune models from production signals.',
    href: FRONTEND_URL + '/dashboard',
    authenticatedHref: FRONTEND_URL + '/dashboard',
  },
];

const platformOpsCards = [
  {
    icon: 'shield',
    title: 'Distroless Attack Surface',
    description:
      'Multi-stage builds compile in Alpine or slim Bookworm, then copy only runtime artifacts into distroless bases. No shell, no package manager, nonroot UID — production containers cannot spawn interactive backdoors even after a boundary breach.',
  },
  {
    icon: 'schedule',
    title: 'Control-Plane Cadence',
    descriptionHtml: `Django on <strong>Fly</strong> owns identity, billing, consent, and BFF adapters. Stripe <code>sync_subscriptions</code> and DEK rotation stay DEML-local. Sealed ingest, projections, replay/DLQ, and ML run exclusively on <strong>FORJD</strong>.`,
  },
  {
    icon: 'delete_sweep',
    title: '30-Day Data Retention',
    descriptionHtml: `Sealed telemetry retention and projection/DLQ TTLs are enforced on <strong>FORJD</strong> (Supabase), not a local OLAP mesh. Tenant data erasure flows through FORJD <code>POST /api/v1/tenants/{id}/erase</code> plus the DEML account lifecycle.`,
  },
  {
    icon: 'lock',
    title: 'Tenant Isolation',
    descriptionHtml: `UUID primary keys everywhere. Django ORM queries filter by authenticated account context. API keys hash with SHA-256 at rest. FORJD calls bind <code>deml_account_id → forjd_tenant_id</code> and fail closed on mismatch. Cross-tenant reads fail closed.`,
  },
  {
    icon: 'insights',
    title: 'CES Anonymized Aggregation',
    description:
      'Countermeasure Effectiveness Standard (CES) consumes only aggregated latency, incident, and uptime vectors from FORJD projections. Individual identities and raw tenant payloads never enter the CES engine — only safe mathematical outputs contribute to Threat, SLA, and Stableness gauges.',
  },
  {
    icon: 'hub',
    title: 'FORJD Sealed Data Plane',
    descriptionHtml: `The Angular client seals envelopes end-to-end (E2EE). Django authenticates the user (Firebase JWT) and forwards the sealed payloads to FORJD with a tenant-bound <code>fjsvc_</code> token. Projections, replay/DLQ, analytics, and ML execute on FORJD Fly — no Redpanda, ClickHouse, or local stream workers.`,
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="DEML API documentation, telemetry ingestion, Kubernetes integration, TensorFlow, PyTorch, Spark, Databricks, AWS Redshift"
  ogType="article"
  jsonLd={docsJsonLd}
>
  <div class="dashboard-page-container">
    <div class="dashboard-content-area">
      <div class="page-inner-wrapper">
        <div class="docs-page-stack">
        <header class="docs-hero docs-hero-with-mockup viking-unified-hero">
          <div class="docs-hero-copy viking-unified-hero-copy">
            <div class="u-style-58adc5 viking-unified-hero-badge">
              <span class="badge-dot pulse-dot" aria-hidden="true"></span>
              <span class="u-style-486a44">Developer Portal · Secured</span>
            </div>
            <h1 class="docs-title viking-unified-hero-title">Hardened ML Pipeline Integration</h1>
            <p class="docs-subtitle viking-unified-hero-lead">
              One API key. Zero-trust authentication on every call. Stream telemetry, execute inference,
              and monitor threat posture — through the same gateway your production stack already trusts.
            </p>
            <div class="viking-unified-hero-actions">
              <DocsCtaGroup>
              <DocsCta
                href={FRONTEND_URL + '/login'}
                authenticatedHref={FRONTEND_URL + '/dashboard'}
                authenticatedLabel="Open Dashboard"
                variant="primary"
                icon="rocket_launch"
              >
                Create Free Account
              </DocsCta>
              <DocsCta href="#quick-start" variant="secondary" icon="play_circle">
                Quick Start Guide
              </DocsCta>
              <DocsCta href={swaggerUrl} variant="secondary" icon="terminal">
                Swagger UI
              </DocsCta>
              </DocsCtaGroup>
            </div>
          </div>
          <PageMockup variant="analytics" class="docs-hero-mockup viking-unified-hero-panel" />
        </header>

        <nav class="docs-outline no-print" aria-label="Documentation outline">
          {docsOutline.map(item => (
            <a href={`#${item.id}`} class="outline-link">
              <VikingIcon name={item.icon} size={18} />
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        <aside class="docs-design-system-note" aria-label="Design system">
          <VikingIcon name="auto_awesome" size={20} />
          <div>
            <strong>Viking-UI premium theme</strong>
            <p>
              All DEML surfaces share one design system — charcoal/teal/crimson
              tokens, WCAG 2.1 AA. See{' '}
              <a
                href="https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/blob/main/THEME.md"
                target="_blank"
                rel="noopener noreferrer"
              >
                THEME.md
              </a>{' '}
              for the canonical token matrix and component guidance.
            </p>
          </div>
        </aside>

        <section class="docs-quick-start" id="quick-start" aria-labelledby="docs-quick-start-title">
          <h2 id="docs-quick-start-title" class="visually-hidden">Quick start</h2>
          <ol class="docs-quick-start-steps">
            {quickStartSteps.map((step, idx) => (
              <li>
                <a
                  href={step.href}
                  class="viking-card docs-quick-start-card"
                  data-authenticated-href={step.authenticatedHref}
                >
                  <span class="step-index" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
                  <VikingIcon name={step.icon} size={20} />
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </a>
              </li>
            ))}
          </ol>
        </section>

        <aside class="docs-security-banner" aria-label="Security highlights">
          <VikingIcon name="security" size={20} />
          <div>
            <strong>Security-first by default</strong>
            <p>
              Bearer tokens are hashed with SHA-256 at rest. Every tenant is UUID-scoped. Keys are
              shown once at creation — copy them immediately.
            </p>
          </div>
        </aside>

        <DocsBentoGrid evenPairs>
          <DocsBentoCard icon="vpn_key" title="Authentication & Access" fullWidth>
            <p class="u-style-7f7d6d">
              Secure access to our high-throughput pipelines requires an API key. Register an account,
              generate a secure token in your user profile, and pass it in the Authorization header.
            </p>
            <div class="code-block-premium">
              <div class="code-header">HTTP Header</div>
              <pre><code>Authorization: Bearer YOUR_API_KEY</code></pre>
            </div>
          </DocsBentoCard>

          <DocsBentoCard icon="input" title="Data Ingestion" id="data-ingestion">
            <p class="u-style-efd290">
              High-throughput endpoint optimized for receiving batched or streaming data from
              distributed pipelines like Apache Spark or Databricks.
            </p>
            <div class="endpoint-badge">
              <span class="method">POST</span>
              <span class="path">/api/v1/ingest</span>
            </div>
            <div class="code-block-premium u-style-5ab468">
              <div class="code-header">cURL Request</div>
              <pre><code>curl -X POST https://backend.deml.app/api/v1/ingest \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123; "batch_id": "123", "records": [&#123;"feature1": 1.0&#125;] &#125;'</code></pre>
            </div>
          </DocsBentoCard>

          <DocsBentoCard icon="model_training" title="Real-time Inference">
            <p class="u-style-efd290">
              Low-latency endpoint for model inference, ideal for Kubernetes sidecars or deep learning
              services calling models directly.
            </p>
            <div class="endpoint-badge">
              <span class="method">POST</span>
              <span class="path">/api/v1/predict</span>
            </div>
            <div class="code-block-premium u-style-5ab468">
              <div class="code-header">cURL Request</div>
              <pre><code>curl -X POST https://backend.deml.app/api/v1/predict \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123; "model_version": "v2", "inputs": [0.5, 0.2] &#125;'</code></pre>
            </div>
          </DocsBentoCard>

          <DocsBentoCard icon="shield" title="Threat Monitoring">
            <p class="u-style-efd290">
              Send SIEM or EDR alerts through the same gateway. DEML correlates severity, IP
              indicators, and tenant context before surfacing actionable cases.
            </p>
            <div class="endpoint-badge">
              <span class="method">POST</span>
              <span class="path">/api/v1/ingest/security-alert</span>
            </div>
            <div class="code-block-premium u-style-5ab468">
              <div class="code-header">cURL Request</div>
              <pre><code>curl -X POST https://backend.deml.app/api/v1/ingest/security-alert \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123; "title": "Suspicious login", "severity": "High" &#125;'</code></pre>
            </div>
          </DocsBentoCard>

          <DocsBentoCard icon="security" title="Enterprise Security">
            <p class="u-style-efd290">
              All tenant data is cryptographically isolated using strict multi-tenancy rules and
              enforced via our strict 30-day data retention policy.
              <strong>API Keys</strong> can only be managed exclusively through the user interface
              under your Settings panel. For ultimate security, keys are displayed only once upon
              creation and are immediately hashed in the database using SHA-256.
            </p>
          </DocsBentoCard>
        </DocsBentoGrid>

        <section class="docs-operations-section" id="platform-operations" aria-labelledby="platform-operations-title">
          <header class="integrations-header">
            <span class="section-tag">PRODUCTION OPERATIONS</span>
            <h2 id="platform-operations-title">Railway, Distroless Runtimes & Compliance Cadence</h2>
            <p>
              DEML ships as Docker services on Railway with Google Distroless production images,
              symmetrical multi-tenant workers, and automated retention — the same controls audited
              for SOC 2 Type II and CMMC 2.0 evidence collection.
            </p>
          </header>

          <DocsBentoGrid evenPairs>
            <DocsBentoCard icon="cloud" title="Production Host Matrix" fullWidth headingLevel="h3">
              <p class="u-style-7f7d6d">
                DEML owns the user control plane. FORJD owns the sealed data plane. Railway data-plane
                services are retired; keep only optional cold standby for Django until DNS is stable.
              </p>
              <div class="code-block-premium">
                <div class="code-header">Core services</div>
                <pre><code>{`frontend/     → Vercel project deml (CSR)
backend/      → Fly deml-backend (Django BFF, Firebase identity)
FORJD         → Fly forjd-backend + forjd-engine + Dragonfly
Postgres      → Neon/Supabase deml schema (control plane only)`}</code></pre>
              </div>
            </DocsBentoCard>

            {platformOpsCards.map(card => (
              <DocsBentoCard icon={card.icon} title={card.title} headingLevel="h3">
                {card.descriptionHtml ? (
                  <p class="u-style-efd290" set:html={card.descriptionHtml} />
                ) : (
                  <p class="u-style-efd290">{card.description}</p>
                )}
              </DocsBentoCard>
            ))}
          </DocsBentoGrid>
        </section>

        <section class="integrations-section" aria-labelledby="integrations-title">
          <header class="integrations-header">
            <span class="section-tag">NATIVE INTEGRATIONS</span>
            <h2 id="integrations-title">Connect Your Stack</h2>
            <p>
              First-class guides for Kubernetes, TensorFlow, PyTorch, Apache Spark, Databricks, and
              AWS Redshift. Each integration uses the same API key and dedicated health-check endpoint.
            </p>
          </header>

          <div class="integration-cards">
            {integrationPlatforms.map(platform => (
              <article class="viking-card integration-card">
                <IconHeading icon={platform.icon} title={platform.name} headingLevel="h3" />
                <p>{platform.summary}</p>
                <div class="code-block-premium compact">
                  <div class="code-header">{platform.exampleLabel}</div>
                  <pre><code>{platform.example}</code></pre>
                </div>
                <a
                  href={`https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/blob/main/${platform.guide}`}
                  class="integration-link"
                >
                  Read {platform.name} guide →
                </a>
              </article>
            ))}
          </div>

          <div class="health-check-block" id="health-checks">
            <h3>Integration Health Checks</h3>
            <p>Verify connectivity from any environment — one GET per platform:</p>
            <div class="code-block-premium">
              <div class="code-header">Health endpoints</div>
              <pre><code>{integrationPlatforms.map(p => `GET ${p.health}`).join('\n')}</code></pre>
            </div>
          </div>
        </section>

        <section class="integrations-section" id="blue-notes" aria-labelledby="blue-notes-title">
          <header class="integrations-header">
            <span class="section-tag">FIELD LOG · BLUE NOTES</span>
            <h2 id="blue-notes-title">Engineering, in the open</h2>
            <p>
              The operating record behind the platform — releases, architecture decisions, and
              reliability work. Newest dispatches first.
            </p>
          </header>

          {recentNotes.length > 0 ? (
            <div class="blog-spotlight-grid">
              {recentNotes.map(note => (
                <article class="viking-card blog-spotlight-card">
                  <div class="blog-note-meta">
                    <span>{note.data.note}</span>
                    <time datetime={note.data.publishedAt.toISOString()}>
                      {formatBlueNoteDate(note.data.publishedAt)}
                    </time>
                  </div>
                  <h3><a href={blueNoteHref(note)}>{note.data.title}</a></h3>
                  <p>{note.data.summary}</p>
                  <a class="blog-read-cue" href={blueNoteHref(note)} aria-label={`Read ${note.data.title}`}>
                    Read the note <VikingIcon name="chevron_right" size={18} />
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <p class="u-style-efd290">No dispatches published yet.</p>
          )}

          <div class="blog-actions">
            <a class="viking-btn viking-btn-outline" href="/blog/">
              <VikingIcon name="arrow_forward" size={18} /> Browse the full archive
            </a>
            <a class="viking-btn viking-btn-ghost" href="/blog/rss.xml">
              <VikingIcon name="send" size={18} /> Follow via RSS
            </a>
          </div>
        </section>
        </div>
      </div>
    </div>
  </div>
</Layout>
