---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import { siteEnv } from '../lib/site-env';
import { techArticleJsonLd, canonicalHref } from '../lib/seo';

const { MARKETING_URL } = siteEnv();
const pageTitle = 'Documentation - DEML Platform';
const pageDescription =
  'Integration guides for Kubernetes, TensorFlow, PyTorch, Spark, Databricks, AWS Redshift, and the DEML telemetry API.';
const docsJsonLd = techArticleJsonLd(
  pageTitle,
  pageDescription,
  canonicalHref('/documentation', MARKETING_URL),
);

const { FRONTEND_URL } = siteEnv();

const integrationPlatforms = [
  {
    icon: 'hub',
    name: 'Kubernetes',
    summary: 'Sidecar proxy or cluster gateway for /predict and /ingest without exposing API keys in app code.',
    exampleLabel: 'Sidecar env',
    example: `DEML_UPSTREAM_URL=https://backend.deml.app/api/v1
DEML_API_KEY=<from Secret>`,
    guide: 'docs/integrations/kubernetes.md',
    health: '/api/v1/integrations/kubernetes',
  },
  {
    icon: 'memory',
    name: 'TensorFlow',
    summary: 'Stream training batches into tf.data.Dataset pipelines with prefetch and autotune.',
    exampleLabel: 'Dataset',
    example: `dataset = tf.data.Dataset.from_generator(...)
dataset.batch(32).prefetch(AUTOTUNE)`,
    guide: 'docs/integrations/tensorflow.md',
    health: '/api/v1/integrations/tensorflow',
  },
  {
    icon: 'psychology',
    name: 'PyTorch',
    summary: 'Back custom Dataset and DataLoader classes with remote ingest. Models ship as state_dict — no pickle.',
    exampleLabel: 'DataLoader',
    example: `loader = DataLoader(DemlRemoteDataset(), batch_size=64)
for features, labels in loader: ...`,
    guide: 'docs/integrations/pytorch.md',
    health: '/api/v1/integrations/pytorch',
  },
  {
    icon: 'bolt',
    name: 'Apache Spark',
    summary: 'Push batch and Structured Streaming micro-batches directly to ingestion endpoints.',
    exampleLabel: 'Streaming',
    example: `payload.writeStream
  .foreachBatch(write_batch)
  .start()`,
    guide: 'docs/integrations/apache-spark.md',
    health: '/api/v1/integrations/apache-spark',
  },
  {
    icon: 'cloud',
    name: 'Databricks',
    summary: 'Store API keys in Secret Scopes, ingest from notebooks, and schedule hourly rollup jobs.',
    exampleLabel: 'Secret Scope',
    example: `api_key = dbutils.secrets.get(
  scope="deml", key="api-key")`,
    guide: 'docs/integrations/databricks.md',
    health: '/api/v1/integrations/databricks',
  },
  {
    icon: 'storage',
    name: 'AWS Redshift',
    summary: 'UNLOAD warehouse rollups to S3 or query via the Data API, then POST batches to /ingest.',
    exampleLabel: 'UNLOAD + ingest',
    example: `requests.post(INGEST_URL,
  headers={"Authorization": f"Bearer {api_key}"},
  json={"source": "aws-redshift", "records": rows})`,
    guide: 'docs/integrations/redshift.md',
    health: '/api/v1/integrations/redshift',
  },
];

const docsOutline = [
  { id: 'quick-start', label: 'Quick Start', icon: 'rocket_launch' },
  { id: 'data-ingestion', label: 'Data Ingestion', icon: 'input' },
  { id: 'integrations-title', label: 'Integrations', icon: 'hub' },
  { id: 'health-checks', label: 'Health Checks', icon: 'monitor_heart' },
];

const quickStartSteps = [
  {
    icon: 'person_add',
    title: 'Create an account',
    description: 'Sign up free — no credit card required for the Standard tier.',
    href: FRONTEND_URL + '/login',
  },
  {
    icon: 'vpn_key',
    title: 'Generate an API key',
    description: 'One key in Settings unlocks ingest, predict, and health endpoints.',
    href: FRONTEND_URL + '/login',
  },
  {
    icon: 'send',
    title: 'Send your first event',
    description: 'Copy a cURL snippet below and watch telemetry appear in seconds.',
    href: '#data-ingestion',
  },
  {
    icon: 'insights',
    title: 'Monitor & improve',
    description: 'Watch live projections and tune models from production signals.',
    href: FRONTEND_URL + '/dashboard',
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="DEML API documentation, telemetry ingestion, Kubernetes integration, TensorFlow, PyTorch, Spark, Databricks, AWS Redshift"
  ogType="article"
  jsonLd={docsJsonLd}
>
  <div class="dashboard-page-container">
    <div class="dashboard-content-area">
      <div class="page-inner-wrapper">
        <header class="docs-hero">
          <div class="u-style-58adc5">
            <span class="badge-dot pulse-dot" aria-hidden="true"></span>
            <span class="u-style-486a44">Developer Portal · Secured</span>
          </div>
          <h1 class="docs-title">Build Secure ML Pipelines in Minutes</h1>
          <p class="docs-subtitle">
            One API key. Zero-trust auth on every call. Stream telemetry, run inference, and monitor
            threats — all through the same hardened gateway your production stack already trusts.
          </p>
          <div class="docs-hero-actions">
            <a href={FRONTEND_URL + '/login'} class="docs-cta primary">
              <VikingIcon name="rocket_launch" size={20} />
              <span>Create Free Account</span>
            </a>
            <a href="#quick-start" class="docs-cta secondary">
              <VikingIcon name="play_circle" size={20} />
              <span>Quick Start Guide</span>
            </a>
          </div>
        </header>

        <nav class="docs-outline no-print" aria-label="Documentation outline">
          {docsOutline.map(item => (
            <a href={`#${item.id}`} class="outline-link">
              <VikingIcon name={item.icon} size={18} />
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        <aside class="docs-design-system-note" aria-label="Design system">
          <VikingIcon name="auto_awesome" size={20} />
          <div>
            <strong>Viking-UI premium theme</strong>
            <p>
              All DEML surfaces share one design system — charcoal/teal/crimson
              tokens, WCAG 2.1 AA. See{' '}
              <a
                href="https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/blob/main/THEME.md"
                target="_blank"
                rel="noopener noreferrer"
              >
                THEME.md
              </a>{' '}
              for the canonical token matrix and component guidance.
            </p>
          </div>
        </aside>

        <section class="docs-quick-start" id="quick-start" aria-labelledby="docs-quick-start-title">
          <h2 id="docs-quick-start-title" class="visually-hidden">Quick start</h2>
          <ol class="docs-quick-start-steps">
            {quickStartSteps.map((step, idx) => (
              <li>
                <a href={step.href} class="viking-card docs-quick-start-card">
                  <span class="step-index" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
                  <VikingIcon name="{step.icon}" size={20} />
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </a>
              </li>
            ))}
          </ol>
        </section>

        <aside class="docs-security-banner" aria-label="Security highlights">
          <VikingIcon name="security" size={20} />
          <div>
            <strong>Security-first by default</strong>
            <p>
              Bearer tokens are hashed with SHA-256 at rest. Every tenant is UUID-scoped. Keys are
              shown once at creation — copy them immediately.
            </p>
          </div>
        </aside>

        <div class="docs-bento-grid">
          <div class="viking-card docs-bento-card docs-bento-full">
            <div class="bento-header">
              <VikingIcon name="vpn_key" size={20} />
              <h2>Authentication & Access</h2>
            </div>
            <p class="u-style-7f7d6d">
              Secure access to our high-throughput pipelines requires an API key. Register an account,
              generate a secure token in your user profile, and pass it in the Authorization header.
            </p>
            <div class="code-block-premium">
              <div class="code-header">HTTP Header</div>
              <pre><code>Authorization: Bearer YOUR_API_KEY</code></pre>
            </div>
          </div>

          <div class="viking-card docs-bento-card" id="data-ingestion">
            <div class="bento-header">
              <VikingIcon name="input" size={20} />
              <h2>Data Ingestion</h2>
            </div>
            <p class="u-style-efd290">
              High-throughput endpoint optimized for receiving batched or streaming data from
              distributed pipelines like Apache Spark or Databricks.
            </p>
            <div class="endpoint-badge">
              <span class="method">POST</span>
              <span class="path">/api/v1/ingest</span>
            </div>
            <div class="code-block-premium u-style-5ab468">
              <div class="code-header">cURL Request</div>
              <pre><code>curl -X POST https://backend.deml.app/api/v1/ingest \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123; "batch_id": "123", "records": [&#123;"feature1": 1.0&#125;] &#125;'</code></pre>
            </div>
          </div>

          <div class="viking-card docs-bento-card">
            <div class="bento-header">
              <VikingIcon name="model_training" size={20} />
              <h2>Real-time Inference</h2>
            </div>
            <p class="u-style-efd290">
              Low-latency endpoint for model inference, ideal for Kubernetes sidecars or deep learning
              services calling models directly.
            </p>
            <div class="endpoint-badge">
              <span class="method">POST</span>
              <span class="path">/api/v1/predict</span>
            </div>
            <div class="code-block-premium u-style-5ab468">
              <div class="code-header">cURL Request</div>
              <pre><code>curl -X POST https://backend.deml.app/api/v1/predict \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123; "model_version": "v2", "inputs": [0.5, 0.2] &#125;'</code></pre>
            </div>
          </div>

          <div class="viking-card docs-bento-card">
            <div class="bento-header">
              <VikingIcon name="shield" size={20} />
              <h2>Threat Monitoring</h2>
            </div>
            <p class="u-style-efd290">
              Send SIEM or EDR alerts through the same gateway. DEML correlates severity, IP
              indicators, and tenant context before surfacing actionable cases.
            </p>
            <div class="endpoint-badge">
              <span class="method">POST</span>
              <span class="path">/api/v1/ingest/security-alert</span>
            </div>
            <div class="code-block-premium u-style-5ab468">
              <div class="code-header">cURL Request</div>
              <pre><code>curl -X POST https://backend.deml.app/api/v1/ingest/security-alert \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123; "title": "Suspicious login", "severity": "High" &#125;'</code></pre>
            </div>
          </div>

          <div class="viking-card docs-bento-card">
            <div class="bento-header">
              <VikingIcon name="security" size={20} />
              <h2>Enterprise Security</h2>
            </div>
            <p class="u-style-efd290">
              All tenant data is cryptographically isolated using strict multi-tenancy rules and
              enforced via our strict 30-day data retention policy.
              <strong>API Keys</strong> can only be managed exclusively through the user interface
              under your Settings panel. For ultimate security, keys are displayed only once upon
              creation and are immediately hashed in the database using SHA-256.
            </p>
          </div>
        </div>

        <section class="integrations-section" aria-labelledby="integrations-title">
          <header class="integrations-header">
            <span class="section-tag">NATIVE INTEGRATIONS</span>
            <h2 id="integrations-title">Connect Your Stack</h2>
            <p>
              First-class guides for Kubernetes, TensorFlow, PyTorch, Apache Spark, Databricks, and
              AWS Redshift. Each integration uses the same API key and dedicated health-check endpoint.
            </p>
          </header>

          <div class="integration-cards">
            {integrationPlatforms.map(platform => (
              <article class="viking-card integration-card">
                <div class="integration-card-header">
                  <VikingIcon name={platform.icon} size={20} />
                  <h3>{platform.name}</h3>
                </div>
                <p>{platform.summary}</p>
                <div class="code-block-premium compact">
                  <div class="code-header">{platform.exampleLabel}</div>
                  <pre><code>{platform.example}</code></pre>
                </div>
                <a
                  href={`https://github.com/dataengineeringformachinelearning/dataengineeringformachinelearning/blob/main/${platform.guide}`}
                  class="integration-link"
                >
                  Read {platform.name} guide →
                </a>
              </article>
            ))}
          </div>

          <div class="health-check-block" id="health-checks">
            <h3>Integration Health Checks</h3>
            <p>Verify connectivity from any environment — one GET per platform:</p>
            <div class="code-block-premium">
              <div class="code-header">Health endpoints</div>
              <pre><code>{integrationPlatforms.map(p => `GET ${p.health}`).join('\n')}</code></pre>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>

<style lang="scss">
.dashboard-page-container {
  display: block;
  width: 100%;
  min-height: calc(100vh - 64px);
  background-color: var(--bg-color);
  color: var(--text-color);
  overflow: hidden;
}

.docs-hero {
  position: relative;
  margin: 0 auto 32px auto;
  text-align: center;
  padding: 48px 24px 40px;
  border-radius: 24px;
  border: 1px solid var(--border);
  background:
    radial-gradient(ellipse 70% 60% at 50% 0%, color-mix(in srgb, var(--viking-teal-600) 10%, transparent), transparent),
    var(--color-surface);
  box-shadow: var(--shadow-sm);

  .docs-title {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--hero-title-color, var(--text-color));
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .docs-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 704px;
    margin: 0 auto 28px auto;
    line-height: 1.6;
  }
}

.docs-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
  overflow: visible;
}

.docs-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--viking-space-1, 8px);
  padding: var(--viking-space-1-5, 12px) var(--viking-space-3, 24px);
  border-radius: var(--viking-radius-md, 10px);
  font-weight: 600;
  font-size: 1rem;
  text-decoration: none !important;
  transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  min-height: 48px;
  box-sizing: border-box;
  white-space: nowrap;

  .material-icons {
    font-size: 20px;
    width: 20px;
    height: 20px;
  }

  &.primary {
    background: var(--viking-teal-600);
    color: var(--white) !important;
    border: 1px solid var(--viking-teal-600);

    &:hover {
      background: var(--viking-teal-400);
      border-color: var(--viking-teal-400);
    }
  }

  &.secondary {
    background: var(--color-surface);
    color: var(--viking-teal-600) !important;
    border: 1px solid color-mix(in srgb, var(--viking-teal-600) 35%, var(--border));
    box-shadow: var(--shadow-sm);

    &:hover {
      border-color: var(--viking-teal-600);
      background: color-mix(in srgb, var(--viking-teal-600) 8%, var(--color-surface));
    }
  }
}

.pulse-dot {
  animation: pulseDot 2s ease-in-out infinite;
}

@keyframes pulseDot {
  0%,
  100% {
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--viking-teal-600) 60%, transparent);
  }
  50% {
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--viking-teal-600) 0%, transparent);
  }
}

.docs-outline {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  max-width: var(--container-max-width, 1260px);
  margin: 0 auto 32px auto;
  padding: 14px 18px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: var(--color-surface);
  position: sticky;
  top: 72px;
  z-index: 10;
  box-shadow: var(--shadow-sm);

  .outline-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none !important;
    color: var(--text-muted) !important;
    border: 1px solid transparent;
    transition: all 0.2s ease;

    &:hover {
      color: var(--viking-teal-600) !important;
      border-color: color-mix(in srgb, var(--viking-teal-600) 35%, transparent);
      background: color-mix(in srgb, var(--viking-teal-600) 8%, transparent);
    }
  }
}

.docs-quick-start {
  max-width: var(--container-max-width, 1260px);
  margin: 0 auto 40px auto;
}

.docs-quick-start-steps {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  list-style: none;
  padding: 0;
  margin: 0;

  @media (min-width: 768px) {
    grid-template-columns: repeat(2, 1fr);
  }

}

.docs-quick-start-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
  padding: 28px 24px;
  border-radius: 18px;
  background: var(--color-surface);
  border: 1px solid var(--border);
  text-decoration: none !important;
  color: inherit !important;
  position: relative;
  transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  height: 100%;

  &:hover {
    border-color: var(--viking-teal-600);
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .step-index {
    position: absolute;
    top: 14px;
    right: 16px;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--viking-teal-600);
    letter-spacing: 0.08em;
  }

  .material-icons {
    font-size: 32px;
    color: var(--viking-teal-600);
  }

  h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-color);
  }

  p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
}

.docs-design-system-note {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  max-width: var(--container-max-width, 1260px);
  margin: 0 auto 24px auto;
  padding: 24px 28px;
  border-radius: 16px;
  background: color-mix(in srgb, var(--viking-crimson-600) 6%, var(--color-surface));
  border: 1px solid color-mix(in srgb, var(--viking-crimson-600) 18%, transparent);

  strong {
    display: block;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
    color: var(--text-color);
  }

  p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
    font-size: 1rem;
  }

  a {
    color: var(--viking-teal-600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
}

.docs-security-banner {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  max-width: var(--container-max-width, 1260px);
  margin: 0 auto 40px auto;
  padding: 24px 28px;
  border-radius: 16px;
  background: color-mix(in srgb, var(--viking-teal-600) 8%, var(--color-surface));
  border: 1px solid color-mix(in srgb, var(--viking-teal-600) 22%, transparent);

  .material-icons {
    font-size: 36px;
    color: var(--viking-teal-600);
    flex-shrink: 0;
  }

  strong {
    display: block;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
    color: var(--text-color);
  }

  p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
    font-size: 1rem;
  }
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.docs-bento-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
  max-width: var(--container-max-width, 1260px);
  margin: 0 auto 56px auto;

  @media (min-width: 768px) {
    grid-template-columns: repeat(12, 1fr);
  }
}

.docs-bento-card {
  grid-column: span 1;
  background: var(--color-surface);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 24px;
  box-shadow: var(--shadow-sm);
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  overflow: hidden;
  position: relative;
  min-height: 100%;

  @media (min-width: 768px) {
    grid-column: span 6;
  }

  &:hover {
    transform: translateY(-4px);
    border-color: var(--viking-teal-600);
    box-shadow: var(--shadow-hover);
  }

  .bento-header {
    display: flex;
    align-items: center;
    gap: 16px;

    .material-icons {
      font-size: 32px;
      width: 32px;
      height: 32px;
      color: var(--viking-teal-600);
      flex-shrink: 0;
    }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0;
      color: var(--text-color);
      letter-spacing: -0.02em;
    }
  }
}

.docs-bento-full {
  @media (min-width: 768px) {
    grid-column: span 12;
  }
}

.integrations-section {
  max-width: var(--container-max-width, 1260px);
  margin: 0 auto 72px auto;
  padding-top: 32px;
  border-top: 1px solid var(--border);
}

.integrations-header {
  text-align: center;
  margin-bottom: 48px;

  .section-tag {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--viking-teal-600);
    text-transform: uppercase;
    display: block;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    margin: 0 0 16px 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  p {
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
    font-size: 1.125rem;
  }
}

.integration-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;

  @media (min-width: 768px) {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 1100px) {
    grid-template-columns: repeat(3, 1fr);
  }
