---
import Layout from '../layouts/Layout.astro';
import '../styles/landing.scss';

const MAIN_APP = import.meta.env.PUBLIC_MAIN_APP_URL ?? 'https://deml.app';
const version = '2.0.0';

const pipelineSteps = [
  {
    id: 'ingest',
    name: 'Widget Telemetry Streaming',
    icon: 'sync_alt',
    tag: 'CLIENT-SIDE EMBED',
    description:
      "The embedded status widget securely streams real-time, zero-dependency telemetry (visitor logs, anomalies) directly from the tenant's site into our ingestion pipeline.",
    codeSnippet:
      '<script src="https://platform.demo/assets/widget.js" data-page-id="tenant-id" async defer></script>',
  },
  {
    id: 'clean',
    name: 'Transformation',
    icon: 'cleaning_services',
    tag: 'DATAFORM ELT',
    description:
      'Cleanse and model raw events using Dataform. Transform raw telemetry into structured, queryable data warehouse tables.',
    codeSnippet:
      'config { type: "table" }\nSELECT\n  timestamp,\n  geo_network.country as country,\n  COUNT(DISTINCT session_id) as active_users\nFROM ${ref("raw_events")}',
  },
  {
    id: 'analyze',
    name: 'Warehouse & Analysis',
    icon: 'storage',
    tag: 'BIGQUERY ML',
    description:
      'Query massive datasets with sub-second latency. Analyze patterns and monitor SLA parameters across global instances.',
    codeSnippet:
      'SELECT\n  service_name,\n  AVG(latency_ms) as avg_latency,\n  percentile_99 as p99\nFROM `data_warehouse.telemetry_metrics`\nGROUP BY 1',
  },
  {
    id: 'predict',
    name: 'Deep Learning Pipeline',
    icon: 'psychology',
    tag: 'PYTORCH PIPELINE',
    description:
      'Orchestrate a PyTorch-based deep learning pipeline currently running two core modules (SLA and TA), designed to support additional forecasting modules in the future.',
    codeSnippet:
      'class DeepLearningPipeline(nn.Module):\n  def __init__(self):\n    super().__init__()\n    self.sla_module = SLAModule()\n    self.ta_module = TAModule()\n    self.future_extensions = nn.ModuleList()\n\n  def forward(self, x):\n    return self.sla_module(x), self.ta_module(x)',
  },
];
---

<Layout title="DEML (DATA ENGINEERING FOR MACHINE LEARNING)">
  <div class="landing-container platform-theme bento-layout page-inner-wrapper">
    <div class="ambient-ripple"></div>

    <header class="hero-section">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span class="badge-text">Version {version}</span>
      </div>

      <div class="hero-content">
        <h1 class="title" id="main-title">Data Engineering<br />for Machine Learning</h1>
        <p class="subtitle">
          An advanced architectural paradigm for streaming zero-dependency telemetry into deep
          learning pipelines. Engineered for precision, protecting infrastructure with autonomous
          anomaly forecasting and enduring excellence.
        </p>

        <div class="cta-group">
          <a href="/documentation" class="cta-button primary-btn">
            <span class="material-icons" aria-hidden="true">menu_book</span>
            <span>Explore Documentation</span>
          </a>
          <a href={MAIN_APP + '/status/platform-status'} class="cta-button secondary-btn">
            <span>View Platform Status</span>
          </a>
        </div>
      </div>
    </header>

    <section class="trusted-by-section" aria-label="Seamlessly integrates with modern infrastructure">
      <p class="trusted-label">INTEGRATES WITH MODERN INFRASTRUCTURE</p>
      <div class="trusted-logos">
        <span class="logo-placeholder">KUBERNETES</span>
        <span class="logo-placeholder">TENSORFLOW</span>
        <span class="logo-placeholder">PYTORCH</span>
        <span class="logo-placeholder">APACHE SPARK</span>
        <span class="logo-placeholder">DATABRICKS</span>
      </div>
    </section>

    <div class="bento-grid-container">
      <section class="bento-item pipeline-bento" aria-labelledby="simulator-title">
        <div class="bento-header">
          <h2 id="simulator-title">Real-time Telemetry Architecture</h2>
          <p>
            Observe high-velocity data streams passing through predictive neural models in real-time,
            built for absolute structural safety.
          </p>
        </div>

        <div class="simulator-grid">
          <div class="steps-nav" role="tablist" aria-label="Pipeline Stages">
            {pipelineSteps.map((step, idx) => (
              <button
                role="tab"
                aria-selected={idx === 0 ? "true" : "false"}
                aria-controls={`step-panel-${step.id}`}
                id={`step-tab-${step.id}`}
                class={`step-nav-item ${idx === 0 ? 'active' : ''}`}
                data-step-index={idx}
              >
                <div class="step-nav-icon">
                  <span class="material-icons" aria-hidden="true">{step.icon}</span>
                </div>
                <div class="step-nav-info">
                  <span class="step-nav-name">{step.name}</span>
                </div>
              </button>
            ))}
          </div>

          <div class="step-display-panel">
            {pipelineSteps.map((step, idx) => (
              <div
                id={`step-panel-${step.id}`}
                role="tabpanel"
                aria-labelledby={`step-tab-${step.id}`}
                class="step-content-box"
                style={idx === 0 ? "" : "display: none;"}
              >
                <div class="step-text-content">
                  <h3>{step.name}</h3>
                  <p>{step.description}</p>
                </div>
                <div class="step-code-visual">
                  <div class="code-header">
                    <span class="file-name">
                      {step.id === 'predict' ? 'threat_model.py' : step.id === 'clean' ? 'events.sqlx' : step.id === 'analyze' ? 'query.sql' : 'payload.json'}
                    </span>
                  </div>
                  <pre><code>{step.codeSnippet}</code></pre>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <div class="bento-item widget-bento">
        <div class="showcase-content">
          <div class="bento-header">
            <span class="showcase-tag">LIVE TELEMETRY WIDGET</span>
            <div class="embed-code">
              <code>&lt;script src="https://deml.app/assets/widget.js" data-page-id="platform-status"&gt;&lt;/script&gt;</code>
            </div>
          </div>
          <div class="widget-mount-point" id="hero-widget-mount">
            <script src="https://deml.app/assets/widget.js" data-page-id="platform-status" async defer></script>
          </div>
        </div>
      </div>

      <section class="bento-item features-bento" aria-labelledby="features-title">
        <div class="bento-header">
          <span class="section-tag">CAPABILITIES</span>
          <h2 id="features-title">Engineered for Reliability</h2>
        </div>

        <div class="bento-features-grid">
          <div class="feature-card">
            <span class="material-icons primary-icon" aria-hidden="true">explore</span>
            <h3>Data Discovery</h3>
            <p>
              Traverse massive databanks and identify key metrics with surgical precision, fueled by
              modern paradigms.
            </p>
          </div>
          <div class="feature-card">
            <span class="material-icons primary-icon" aria-hidden="true">analytics</span>
            <h3>Telemetry Analytics</h3>
            <p>
              Monitor real-time health and isolate anomalies before they compound, ensuring
              uncompromised quality.
            </p>
          </div>
          <div class="feature-card">
            <span class="material-icons primary-icon" aria-hidden="true">security</span>
            <h3>Threat Mitigation</h3>
            <p>
              Detect rogue models and scan for infrastructure flaws autonomously with mathematically
              rigorous assessments.
            </p>
          </div>
        </div>
      </section>

      <section class="bento-item whitepaper-cta-bento" aria-labelledby="whitepaper-cta-title">
        <div class="bento-header">
          <span class="section-tag">RESEARCH & ARCHITECTURE</span>
          <h2 id="whitepaper-cta-title">The Whitepaper</h2>
          <p>
            Review the comprehensive architecture, scalable telemetry patterns, and automated threat
            mitigation strategies powering the platform.
          </p>
        </div>
        <div class="cta-group u-style-9150aa" >
          <a href="/whitepaper" class="cta-button primary-btn whitepaper-btn">
            <span class="material-icons" aria-hidden="true">description</span>
            <span>Read Whitepaper</span>
          </a>
        </div>
      </section>

      <section class="bento-item pricing-bento" aria-labelledby="pricing-title">
        <div class="bento-header">
          <span class="section-tag">API ACCESS</span>
          <h2 id="pricing-title">Simple, Transparent Pricing</h2>
          <p>Choose the tier that fits your telemetry throughput needs.</p>
        </div>
        <div class="pricing-cards-container">
          <div class="pricing-card standard-tier">
            <h3>Standard Tier</h3>
            <div class="price">Free</div>
            <ul class="features-list">
              <li><span class="material-icons" aria-hidden="true">check</span> 60 requests / minute</li>
              <li><span class="material-icons" aria-hidden="true">check</span> Core Analytics</li>
              <li><span class="material-icons" aria-hidden="true">check</span> Community Support</li>
            </ul>
            <a href={MAIN_APP + '/login'} class="cta-button secondary-btn">Get Started</a>
          </div>

          <div class="pricing-card pro-tier">
            <div class="recommended-badge">RECOMMENDED</div>
            <h3>Pro Tier</h3>
            <div class="price">$39<span>/mo</span></div>
            <ul class="features-list">
              <li><span class="material-icons" aria-hidden="true">check</span> 1,000 requests / minute</li>
              <li><span class="material-icons" aria-hidden="true">check</span> Advanced Threat Detection</li>
              <li><span class="material-icons" aria-hidden="true">check</span> Priority Support</li>
            </ul>
            <a href={MAIN_APP + '/login?action=checkout'} class="cta-button primary-btn pro-btn">
              Upgrade to Pro
            </a>
          </div>
        </div>
      </section>
    </div>

    <section class="transparency-atmospheric" aria-labelledby="transparency-title">
      <div class="atmospheric-header">
        <span class="section-tag">COMPLIANCE PROTOCOL</span>
        <h2 id="transparency-title">Rigorous Transparency</h2>
        <p>Guarantees the integrity of the underlying infrastructure.</p>
      </div>
      <ul class="purpose-list">
        <li>
          <span class="material-icons" aria-hidden="true">shield</span>
          <div class="purpose-text">
            <strong>System Telemetry</strong>
            Aggregates anonymized parameters.
          </div>
        </li>
        <li>
          <span class="material-icons" aria-hidden="true">vpn_key</span>
          <div class="purpose-text">
            <strong>Data Tenancy</strong>
            Enforces strict isolation across pipeline boundaries.
          </div>
        </li>
      </ul>
    </section>
  </div>
</Layout>

<script>
  // Handle Interactive Pipeline Steps
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.step-nav-item');
    const panels = document.querySelectorAll('.step-content-box');
    let activeIndex = 0;
    let intervalId = null;

    function setStep(index) {
      activeIndex = index;

      tabs.forEach((tab, i) => {
        if (i === index) {
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
        } else {
          tab.classList.remove('active');
          tab.setAttribute('aria-selected', 'false');
        }
      });

      panels.forEach((panel, i) => {
        if (i === index) {
          panel.style.display = 'block';
        } else {
          panel.style.display = 'none';
        }
      });

      startCycle();
    }

    function startCycle() {
      if (intervalId) clearInterval(intervalId);
      intervalId = setInterval(() => {
        setStep((activeIndex + 1) % tabs.length);
      }, 4500);
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        setStep(index);
      });
    });

    startCycle();
  });
</script>
