---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import WhitepaperCta from '../components/WhitepaperCta.astro';
import PageMockup from '../components/PageMockup.astro';
import vikingUiPackage from '@dataengineeringformachinelearning/viking-ui/package.json';
import { siteEnv } from '../lib/site-env';
import {
  DEFAULT_KEYWORDS,
  organizationJsonLd,
  webSiteJsonLd,
  softwareApplicationJsonLd,
} from '../lib/seo';

const { FRONTEND_URL, BACKEND_URL, MARKETING_URL } = siteEnv();
const pageTitle = 'DEML — Operational Intelligence for the Digital Battlefield';
const pageDescription =
  'Operational intelligence for resilient AI systems. See service health in real time, forecast reliability risks before impact, and protect every customer workspace by design.';
const homeJsonLd = [
  organizationJsonLd(MARKETING_URL),
  webSiteJsonLd(MARKETING_URL),
  softwareApplicationJsonLd(FRONTEND_URL),
];
const WIDGET_PAGE_ID = 'platform-status';
const WIDGET_SCRIPT_PATH = '/assets/widgets/widget.js';
const widgetEmbedAttrs = `data-backend-url="${BACKEND_URL}" data-frontend-url="${FRONTEND_URL}" data-page-id="${WIDGET_PAGE_ID}"`;
const widgetEmbedSnippet = `<script src="${WIDGET_SCRIPT_PATH}" ${widgetEmbedAttrs} async defer></script>`;
const widgetEmbedSnippetHtml = widgetEmbedSnippet
  .replaceAll('<', '&lt;')
  .replaceAll('>', '&gt;');
const version = vikingUiPackage.version;

const capabilities = [
  {
    tag: 'TELEMETRY',
    title: 'Operational Visibility',
    description:
      'See performance, availability, and emerging risk in one live operational view. Fast updates turn subtle drift into an early warning before customers feel the impact.',
    icon: 'analytics',
    metrics: [
      { label: 'P99 Latency', value: '42ms', trend: 'down' },
      { label: 'Uptime', value: '99.97%', trend: 'stable' },
      { label: 'Requests/min', value: '12.4K', trend: 'up' },
    ],
    link: {
      href: '/documentation',
      label: 'Review integration specifications →',
      authenticatedHref: undefined,
      authenticatedLabel: undefined,
      muted: false,
    },
  },
  {
    tag: 'SECURITY',
    title: 'Threat Intelligence',
    description:
      'ML models score anomalies at ingress. Semgrep and Trivy findings consolidate into a unified triage board; high-confidence indicators serialize to STIX 2.1 for downstream SOAR and TAXII federation.',
    icon: 'security',
    metrics: [
      { label: 'Threat Score', value: '12%', trend: 'down' },
      { label: 'Open CVEs', value: '3', trend: 'down' },
      { label: 'Blocked', value: '847', trend: 'up' },
    ],
    link: {
      href: FRONTEND_URL + '/login',
      label: 'Activate threat monitoring →',
      authenticatedHref: FRONTEND_URL + '/vulnerabilities',
      authenticatedLabel: 'Open threat operations →',
      muted: true,
    },
  },
  {
    tag: 'PIPELINE',
    title: 'Event Projections',
    description:
      'Every operational change is durable, replayable, and reflected across live views without losing history. The same reliable path protects every customer workspace.',
    icon: 'layers',
    metrics: [
      { label: 'Events/sec', value: '8.2K', trend: 'up' },
      { label: 'DLQ Rate', value: '0.01%', trend: 'down' },
      { label: 'Tenants', value: 'Symmetrical', trend: 'stable' },
    ],
    link: {
      href: FRONTEND_URL + '/status/platform-status',
      label: 'Observe live projections →',
      authenticatedHref: undefined,
      authenticatedLabel: undefined,
      muted: true,
    },
  },
];

const quickStartSteps = [
  {
    step: '01',
    title: 'Connect',
    description: 'Deploy one script tag or API key. No agent fleet to maintain.',
    icon: 'link',
  },
  {
    step: '02',
    title: 'Observe',
    description: 'Telemetry, threat scores, and CVE posture surface in real time.',
    icon: 'visibility',
  },
  {
    step: '03',
    title: 'Act',
    description: 'Triage incidents, contain anomalies, and sustain operational tempo.',
    icon: 'shield',
  },
  {
    step: '04',
    title: 'Scale',
    description: 'Symmetrical pipelines for every tenant. Zero per-customer overhead.',
    icon: 'trending_up',
  },
];

const securityPillars = [
  { icon: 'lock', label: 'AES-256-GCM at rest', detail: 'Field-level encryption with KMS rotation every 90 days' },
  { icon: 'fingerprint', label: 'UUID isolation', detail: 'No sequential identifiers. No cross-tenant data paths.' },
  { icon: 'gpp_maybe', label: 'Behavioral enrichment', detail: 'ASN, ISP, and biometric signals at ingress' },
  { icon: 'verified_user', label: 'Zero-trust perimeter', detail: 'Verified identity and policy checks on every protected action' },
];

const integrations = [
  { name: 'Kubernetes', icon: 'kubernetes' },
  { name: 'TensorFlow', icon: 'tensorflow' },
  { name: 'PyTorch', icon: 'pytorch' },
  { name: 'Apache Spark', icon: 'apache-spark' },
  { name: 'Databricks', icon: 'databricks' },
  { name: 'AWS Redshift', icon: 'aws-redshift' },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={`${DEFAULT_KEYWORDS}, observability, SLA forecasting, STIX threat intelligence`}
  jsonLd={homeJsonLd}
>
  <div class="page-inner-wrapper landing-container showcase-layout">

    <!-- Hero: split layout with mock dashboard -->
    <section class="hero-showcase" aria-labelledby="main-title">
      <div class="hero-copy">
        <div class="hero-badge">
          <span class="badge-dot pulse-dot"></span>
          <span class="badge-text">Field Grade · Version {version}</span>
        </div>
        <h1 class="title" id="main-title">Operational intelligence for resilient AI systems</h1>
        <p class="subtitle">
          DEML fuses data engineering, AI engineering, and intelligence-driven cybersecurity defense
          into one multi-tenant operational fabric. Ingest telemetry at scale, forecast SLA breach
          before it manifests, and federate threat indicators with production-grade reliability.
        </p>
        <div class="hero-stats" aria-label="Platform highlights">
          <div class="hero-stat-pill">
            <VikingIcon name="shield" size={20} />
            <span>847 threats interdicted</span>
          </div>
          <div class="hero-stat-pill">
            <VikingIcon name="speed" size={20} />
            <span>42ms P99 command loop</span>
          </div>
          <div class="hero-stat-pill">
            <VikingIcon name="verified_user" size={20} />
            <span>Zero-trust by default</span>
          </div>
          <div class="hero-stat-pill">
            <VikingIcon name="hub" size={20} />
            <span>Symmetric tenant doctrine</span>
          </div>
        </div>
        <div class="cta-group">
          <a href="/documentation" class="cta-button viking-btn viking-btn-primary">
            <span class="cta-content">
              <VikingIcon name="rocket_launch" size={20} class="cta-icon" />
              <span class="cta-label">Engage in 5 Minutes</span>
            </span>
          </a>
          <a href={FRONTEND_URL + '/status/platform-status'} class="cta-button viking-btn viking-btn-outline">
            <span class="cta-content">
              <VikingIcon name="insights" size={20} class="cta-icon" />
              <span class="cta-label">See Live Security Posture</span>
            </span>
          </a>
        </div>
      </div>

      <PageMockup variant="security-ops" />
    </section>

    <!-- Quick start -->
    <section class="quick-start-band" aria-labelledby="quick-start-title">
      <header class="quick-start-header">
        <span class="section-tag">DEPLOYMENT SEQUENCE</span>
        <h2 id="quick-start-title">Operational Onboarding in Four Steps</h2>
        <p>Connect, observe, and act. The platform sustains projections, enrichment, and threat scoring autonomously.</p>
      </header>
      <ol class="quick-start-steps">
        {quickStartSteps.map((item) => (
          <li class="quick-start-step">
            <span class="step-number" aria-hidden="true">{item.step}</span>
            <VikingIcon name={item.icon} size={20} class="step-icon" />
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </li>
        ))}
      </ol>
      <div class="quick-start-code viking-card" aria-label="Quick start code example">
        <div class="quick-start-code-copy">
          <span class="section-tag">ONE-SCRIPT START</span>
          <h3>Project live operational status anywhere.</h3>
          <p>Use the public Tenant0 projection first, then replace the page identifier with your registered tenant scope.</p>
        </div>
        <pre><code set:html={widgetEmbedSnippetHtml} /></pre>
      </div>
    </section>

    <!-- Integrations strip -->
    <section class="integrations-strip" aria-label="Integrates with modern infrastructure">
      <p class="strip-label">INTEGRATES WITH</p>
      <div class="integration-logos">
        {integrations.map((item) => (
          <a href="/documentation" class="integration-logo-item">
            <VikingIcon name={item.icon} size={20} />
            <span>{item.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Wide capability showcases -->
    {capabilities.map((cap, idx) => (
      <section class={`showcase-band ${idx % 2 === 1 ? 'reversed' : ''}`} aria-labelledby={`cap-${idx}`}>
        <div class="showcase-band-copy">
          <span class="section-tag">{cap.tag}</span>
          <h2 id={`cap-${idx}`}>{cap.title}</h2>
          <p>{cap.description}</p>
          <a
            href={cap.link.href}
            class={`showcase-link ${cap.link.muted ? 'muted-link' : ''}`}
            data-authenticated-href={cap.link.authenticatedHref}
            data-authenticated-label={cap.link.authenticatedLabel}
            data-auth-label
          >
            {cap.link.label}
          </a>
        </div>
        <div class="showcase-band-visual" aria-hidden="true">
          <div class="visual-panel">
            <div class="visual-panel-header">
              <VikingIcon name={cap.icon} size={20} />
              <span>{cap.title}</span>
            </div>
            <div class="visual-metrics">
              {cap.metrics.map((m) => (
                <div class="visual-metric">
                  <span class="metric-label">{m.label}</span>
                  <span class="metric-value">{m.value}</span>
                  <span class={`metric-trend trend-${m.trend}`} aria-hidden="true">
                    {m.trend === 'up' ? '↑' : m.trend === 'down' ? '↓' : '—'}
                  </span>
                </div>
              ))}
            </div>
            <div class="visual-sparkline">
              <svg viewBox="0 0 200 48" preserveAspectRatio="none" aria-hidden="true">
                <polyline
                  points="0,40 25,32 50,36 75,20 100,28 125,12 150,18 175,8 200,14"
                  fill="none"
                  stroke="var(--viking-accent)"
                  stroke-width="2"
                />
              </svg>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Live widget — full width -->
    <section class="widget-showcase" aria-labelledby="widget-title">
      <div class="widget-showcase-inner">
        <div class="widget-copy">
          <span class="section-tag">EMBED ANYWHERE</span>
          <h2 id="widget-title">Live Status Widget</h2>
          <p>
            One script tag brings live service health to any surface. Zero runtime dependencies,
            privacy-aware operational context, and automatic workspace isolation at every boundary.
          </p>
          <div class="embed-code">
            <code set:html={widgetEmbedSnippetHtml} />
          </div>
        </div>
        <div class="widget-mount-point" id="hero-widget-mount">
          <script
            src={WIDGET_SCRIPT_PATH}
            data-backend-url={BACKEND_URL}
            data-frontend-url={FRONTEND_URL}
            data-page-id={WIDGET_PAGE_ID}
            async
            defer
          ></script>
        </div>
      </div>
    </section>

    <!-- Security pillars -->
    <section class="security-pillars-band" aria-labelledby="security-pillars-title">
      <header class="security-pillars-header">
        <span class="section-tag">DEFENSE IN DEPTH</span>
        <h2 id="security-pillars-title">Perimeter Security Without Operational Friction</h2>
        <p>
          Every layer — from command ingress to projection materialization — is encrypted, isolated,
          and audited. Operators focus on models; the platform sustains the perimeter.
        </p>
      </header>
      <ul class="security-pillars-grid">
        {securityPillars.map((pillar) => (
          <li class="security-pillar">
            <VikingIcon name={pillar.icon} size={20} />
            <strong>{pillar.label}</strong>
            <span>{pillar.detail}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Pricing — wide cards -->
    <section class="pricing-showcase" aria-labelledby="pricing-title">
      <header class="pricing-header">
        <span class="section-tag">API ACCESS</span>
        <h2 id="pricing-title">Transparent Throughput Tiers</h2>
        <p>Select the operational tier aligned with your telemetry volume and threat-analytics requirements.</p>
      </header>
      <div class="pricing-cards-container">
        <div class="viking-card pricing-card standard-tier">
          <h3>Standard Tier</h3>
          <div class="price">Free</div>
          <ul class="features-list">
            <li><VikingIcon name="check" size={20} /> 60 requests / minute</li>
            <li><VikingIcon name="check" size={20} /> Core Analytics</li>
            <li><VikingIcon name="check" size={20} /> Community Support</li>
          </ul>
          <a
            href={FRONTEND_URL + '/login'}
            class="viking-btn viking-btn-subtle cta-button secondary-btn"
            data-authenticated-href={FRONTEND_URL + '/dashboard'}
            data-authenticated-label="Open Dashboard"
            data-auth-label
          >Get Started</a>
        </div>
        <div class="viking-card pricing-card pro-tier">
          <div class="recommended-badge">RECOMMENDED</div>
          <h3>Pro Tier</h3>
          <div class="price">$39<span>/mo</span></div>
          <ul class="features-list">
            <li><VikingIcon name="check" size={20} /> 1,000 requests / minute</li>
            <li><VikingIcon name="check" size={20} /> Advanced Threat Detection</li>
            <li><VikingIcon name="check" size={20} /> Priority Support</li>
          </ul>
          <a
            href={FRONTEND_URL + '/login?action=checkout'}
            class="viking-btn viking-btn-primary cta-button cta-primary pro-btn"
            data-authenticated-href={FRONTEND_URL + '/account'}
            data-authenticated-label="Manage Subscription"
            data-auth-label
          >
            Upgrade to Pro
          </a>
        </div>
      </div>
    </section>

    <WhitepaperCta />

    <!-- Compliance -->
    <section class="transparency-atmospheric" aria-labelledby="transparency-title">
      <div class="atmospheric-header">
        <span class="section-tag">COMPLIANCE PROTOCOL</span>
        <h2 id="transparency-title">Audit-Ready by Architectural Default</h2>
        <p>Transparent telemetry, strict tenancy, and automated retention — no opaque control planes.</p>
      </div>
      <ul class="purpose-list">
        <li>
          <VikingIcon name="shield" size={20} />
          <div class="purpose-text">
            <strong>System Telemetry</strong>
            Aggregates anonymized parameters with full audit trails.
          </div>
        </li>
        <li>
          <VikingIcon name="vpn_key" size={20} />
          <div class="purpose-text">
            <strong>Data Tenancy</strong>
            UUID-scoped isolation across every pipeline boundary.
          </div>
        </li>
        <li>
          <VikingIcon name="policy" size={20} />
          <div class="purpose-text">
            <strong>30-Day Retention</strong>
            Automated purge policies keep you compliant by default.
          </div>
        </li>
        <li>
          <VikingIcon name="bug_report" size={20} />
          <div class="purpose-text">
            <strong>Vuln Triage</strong>
            Semgrep and Trivy findings auto-ticketed to your Kanban.
          </div>
        </li>
      </ul>
    </section>
  </div>
</Layout>
