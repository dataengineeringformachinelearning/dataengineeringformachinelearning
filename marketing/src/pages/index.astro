---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import WhitepaperCta from '../components/WhitepaperCta.astro';
import '../styles/landing.scss';
import { siteEnv } from '../lib/site-env';

const { FRONTEND_URL, BACKEND_URL } = siteEnv();
const WIDGET_PAGE_ID = 'platform-status';
const WIDGET_SCRIPT_PATH = '/assets/widgets/widget.js';
const widgetEmbedAttrs = `data-backend-url="${BACKEND_URL}" data-frontend-url="${FRONTEND_URL}" data-page-id="${WIDGET_PAGE_ID}"`;
const widgetEmbedSnippet = `<script src="${WIDGET_SCRIPT_PATH}" ${widgetEmbedAttrs} async defer></script>`;
const widgetEmbedSnippetHtml = widgetEmbedSnippet
  .replaceAll('<', '&lt;')
  .replaceAll('>', '&gt;');
const version = '2.0.0';

const capabilities = [
  {
    tag: 'TELEMETRY',
    title: 'Real-Time Analytics',
    description:
      'Every request is traced, enriched, and projected in under a second. OpenTelemetry flows into ClickHouse rollups and Firestore dashboards — so you spot drift before it becomes downtime.',
    icon: 'analytics',
    metrics: [
      { label: 'P99 Latency', value: '42ms', trend: 'down' },
      { label: 'Uptime', value: '99.97%', trend: 'stable' },
      { label: 'Requests/min', value: '12.4K', trend: 'up' },
    ],
    link: { href: '/documentation', label: 'View integration docs →', muted: false },
  },
  {
    tag: 'SECURITY',
    title: 'Threat Intelligence',
    description:
      'ML models score anomalies the moment they appear. Semgrep and Trivy findings land in a unified triage board — no more chasing alerts across five different tools.',
    icon: 'security',
    metrics: [
      { label: 'Threat Score', value: '12%', trend: 'down' },
      { label: 'Open CVEs', value: '3', trend: 'down' },
      { label: 'Blocked', value: '847', trend: 'up' },
    ],
    link: { href: FRONTEND_URL + '/login', label: 'Start threat monitoring →', muted: true },
  },
  {
    tag: 'PIPELINE',
    title: 'Event Projections',
    description:
      'Commands enter through Firebase, commit to a transactional Outbox, and stream to Redpanda. Idempotent workers materialize live views in Firestore — reliable by design, not by hope.',
    icon: 'hub',
    metrics: [
      { label: 'Events/sec', value: '8.2K', trend: 'up' },
      { label: 'DLQ Rate', value: '0.01%', trend: 'down' },
      { label: 'Tenants', value: 'Symmetrical', trend: 'stable' },
    ],
    link: { href: FRONTEND_URL + '/status/platform-status', label: 'See live projections →', muted: true },
  },
];

const quickStartSteps = [
  {
    step: '01',
    title: 'Connect',
    description: 'Drop in one script tag or API key. No agents to babysit.',
    icon: 'link',
  },
  {
    step: '02',
    title: 'Observe',
    description: 'Telemetry, threat scores, and CVEs surface in real time.',
    icon: 'visibility',
  },
  {
    step: '03',
    title: 'Act',
    description: 'Triage incidents, block anomalies, and ship with confidence.',
    icon: 'shield',
  },
  {
    step: '04',
    title: 'Scale',
    description: 'Symmetrical for every tenant. Zero extra work per customer.',
    icon: 'trending_up',
  },
];

const securityPillars = [
  { icon: 'lock', label: 'AES-256-GCM at rest', detail: 'Field-level encryption with KMS rotation' },
  { icon: 'fingerprint', label: 'UUID isolation', detail: 'No sequential IDs, no cross-tenant leaks' },
  { icon: 'gpp_maybe', label: 'Behavioral intel', detail: 'ASN, ISP, and biometrics enrichment' },
  { icon: 'verified_user', label: 'Zero-trust auth', detail: 'Firebase JWT + ABAC on every endpoint' },
];

const integrations = [
  { name: 'Kubernetes', icon: 'hub' },
  { name: 'TensorFlow', icon: 'memory' },
  { name: 'PyTorch', icon: 'psychology' },
  { name: 'Apache Spark', icon: 'bolt' },
  { name: 'Databricks', icon: 'cloud' },
  { name: 'Redpanda', icon: 'lan' },
];
---

<Layout
  title="DEML (DATA ENGINEERING FOR MACHINE LEARNING)"
  description="Secure your data pipeline and ship ML faster. Real-time telemetry, threat intelligence, and tenant-safe event projections for modern data teams."
>
  <div class="landing-container showcase-layout">

    <!-- Hero: split layout with mock dashboard -->
    <section class="hero-showcase" aria-labelledby="main-title">
      <div class="hero-copy">
        <div class="hero-badge">
          <span class="badge-dot pulse-dot"></span>
          <span class="badge-text">Secured · Version {version}</span>
        </div>
        <h1 class="title" id="main-title">Secure Your Data<br />Pipeline. Ship ML Faster.</h1>
        <p class="subtitle">
          DEML fuses rigorous data engineering with predictive security. Stream telemetry, catch
          threats in real time, and keep every tenant isolated — without slowing your team down.
        </p>
        <div class="hero-stats" aria-label="Platform highlights">
          <div class="hero-stat-pill">
            <VikingIcon name="shield" size={20} />
            <span>847 threats blocked today</span>
          </div>
          <div class="hero-stat-pill">
            <VikingIcon name="speed" size={20} />
            <span>42ms P99 latency</span>
          </div>
          <div class="hero-stat-pill">
            <VikingIcon name="verified_user" size={20} />
            <span>Zero-trust by default</span>
          </div>
          <div class="hero-stat-pill">
            <VikingIcon name="hub" size={20} />
            <span>Tenant-safe routing</span>
          </div>
        </div>
        <div class="cta-group">
          <a href="/documentation" class="cta-button primary-btn viking-btn viking-btn-primary">
            <span class="cta-content">
              <VikingIcon name="rocket_launch" size={20} class="cta-icon" />
              <span class="cta-label">Get Started in 5 Minutes</span>
            </span>
          </a>
          <a href={FRONTEND_URL + '/status/platform-status'} class="cta-button secondary-btn viking-btn viking-btn-subtle">
            <span class="cta-content">
              <VikingIcon name="insights" size={20} class="cta-icon" />
              <span class="cta-label">See Live Security Posture</span>
            </span>
          </a>
        </div>
      </div>

      <div class="hero-mockup" aria-hidden="true">
        <div class="mockup-window">
          <div class="mockup-titlebar">
            <span class="mockup-dot"></span>
            <span class="mockup-dot"></span>
            <span class="mockup-dot"></span>
            <span class="mockup-title">deml.app / security-ops</span>
          </div>
          <div class="mockup-body">
            <div class="mockup-sidebar">
              <span class="mockup-nav-item active"></span>
              <span class="mockup-nav-item"></span>
              <span class="mockup-nav-item"></span>
            </div>
            <div class="mockup-main">
              <div class="mockup-gauges">
                <div class="mockup-gauge"><span class="gauge-label">Threat</span><span class="gauge-val">12%</span></div>
                <div class="mockup-gauge primary"><span class="gauge-label">CES</span><span class="gauge-val">94</span></div>
                <div class="mockup-gauge"><span class="gauge-label">Stability</span><span class="gauge-val">99%</span></div>
              </div>
              <div class="mockup-chart">
                <div class="chart-bar" data-height="45"></div>
                <div class="chart-bar" data-height="72"></div>
                <div class="chart-bar" data-height="58"></div>
                <div class="chart-bar" data-height="85"></div>
                <div class="chart-bar" data-height="63"></div>
                <div class="chart-bar" data-height="91"></div>
                <div class="chart-bar" data-height="78"></div>
                <div class="chart-bar" data-height="55"></div>
              </div>
              <div class="mockup-stats-row">
                <div class="mockup-stat"><span>P99</span><strong>42ms</strong></div>
                <div class="mockup-stat"><span>Requests</span><strong>12.4K</strong></div>
                <div class="mockup-stat"><span>Incidents</span><strong>0</strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick start -->
    <section class="quick-start-band" aria-labelledby="quick-start-title">
      <header class="quick-start-header">
        <span class="section-tag">SIMPLE BY DESIGN</span>
        <h2 id="quick-start-title">Up and Running in Four Steps</h2>
        <p>No sprawling setup guides. Connect, observe, and act — the platform handles the rest.</p>
      </header>
      <ol class="quick-start-steps">
        {quickStartSteps.map((item) => (
          <li class="quick-start-step">
            <span class="step-number" aria-hidden="true">{item.step}</span>
            <VikingIcon name="{item.icon}" size={20} class="step-icon" />
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </li>
        ))}
      </ol>
    </section>

    <!-- Integrations strip -->
    <section class="integrations-strip" aria-label="Integrates with modern infrastructure">
      <p class="strip-label">INTEGRATES WITH</p>
      <div class="integration-logos">
        {integrations.map((item) => (
          <a href="/documentation" class="integration-logo-item">
            <VikingIcon name="{item.icon}" size={20} />
            <span>{item.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Wide capability showcases -->
    {capabilities.map((cap, idx) => (
      <section class={`showcase-band ${idx % 2 === 1 ? 'reversed' : ''}`} aria-labelledby={`cap-${idx}`}>
        <div class="showcase-band-copy">
          <span class="section-tag">{cap.tag}</span>
          <h2 id={`cap-${idx}`}>{cap.title}</h2>
          <p>{cap.description}</p>
          <a
            href={cap.link.href}
            class={`showcase-link ${cap.link.muted ? 'muted-link' : ''}`}
          >
            {cap.link.label}
          </a>
        </div>
        <div class="showcase-band-visual" aria-hidden="true">
          <div class="visual-panel">
            <div class="visual-panel-header">
              <VikingIcon name="{cap.icon}" size={20} />
              <span>{cap.title}</span>
            </div>
            <div class="visual-metrics">
              {cap.metrics.map((m) => (
                <div class="visual-metric">
                  <span class="metric-label">{m.label}</span>
                  <span class="metric-value">{m.value}</span>
                  <span class={`metric-trend trend-${m.trend}`} aria-hidden="true">
                    {m.trend === 'up' ? '↑' : m.trend === 'down' ? '↓' : '—'}
                  </span>
                </div>
              ))}
            </div>
            <div class="visual-sparkline">
              <svg viewBox="0 0 200 48" preserveAspectRatio="none" aria-hidden="true">
                <polyline
                  points="0,40 25,32 50,36 75,20 100,28 125,12 150,18 175,8 200,14"
                  fill="none"
                  stroke="var(--crayola-blue)"
                  stroke-width="2"
                />
              </svg>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Live widget — full width -->
    <section class="widget-showcase" aria-labelledby="widget-title">
      <div class="widget-showcase-inner">
        <div class="widget-copy">
          <span class="section-tag">EMBED ANYWHERE</span>
          <h2 id="widget-title">Live Status Widget</h2>
          <p>
            One script tag streams real-time telemetry from any site. Zero dependencies, full
            OpenTelemetry enrichment, and automatic tenant isolation.
          </p>
          <div class="embed-code">
            <code set:html={widgetEmbedSnippetHtml} />
          </div>
        </div>
        <div class="widget-mount-point" id="hero-widget-mount">
          <script
            src={WIDGET_SCRIPT_PATH}
            data-backend-url={BACKEND_URL}
            data-frontend-url={FRONTEND_URL}
            data-page-id={WIDGET_PAGE_ID}
            async
            defer
          ></script>
        </div>
      </div>
    </section>

    <!-- Security pillars -->
    <section class="security-pillars-band" aria-labelledby="security-pillars-title">
      <header class="security-pillars-header">
        <span class="section-tag">DEFENSE IN DEPTH</span>
        <h2 id="security-pillars-title">Security That Works While You Sleep</h2>
        <p>
          Every layer — from ingestion to projection — is encrypted, isolated, and audited. You
          focus on models; we guard the perimeter.
        </p>
      </header>
      <ul class="security-pillars-grid">
        {securityPillars.map((pillar) => (
          <li class="security-pillar">
            <VikingIcon name="{pillar.icon}" size={20} />
            <strong>{pillar.label}</strong>
            <span>{pillar.detail}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Pricing — wide cards -->
    <section class="pricing-showcase" aria-labelledby="pricing-title">
      <header class="pricing-header">
        <span class="section-tag">API ACCESS</span>
        <h2 id="pricing-title">Simple, Transparent Pricing</h2>
        <p>Choose the tier that fits your telemetry throughput needs.</p>
      </header>
      <div class="pricing-cards-container">
        <div class="pricing-card standard-tier">
          <h3>Standard Tier</h3>
          <div class="price">Free</div>
          <ul class="features-list">
            <li><VikingIcon name="check" size={20} /> 60 requests / minute</li>
            <li><VikingIcon name="check" size={20} /> Core Analytics</li>
            <li><VikingIcon name="check" size={20} /> Community Support</li>
          </ul>
          <a href={FRONTEND_URL + '/login'} class="cta-button secondary-btn">Get Started</a>
        </div>
        <div class="pricing-card pro-tier">
          <div class="recommended-badge">RECOMMENDED</div>
          <h3>Pro Tier</h3>
          <div class="price">$39<span>/mo</span></div>
          <ul class="features-list">
            <li><VikingIcon name="check" size={20} /> 1,000 requests / minute</li>
            <li><VikingIcon name="check" size={20} /> Advanced Threat Detection</li>
            <li><VikingIcon name="check" size={20} /> Priority Support</li>
          </ul>
          <a href={FRONTEND_URL + '/login?action=checkout'} class="cta-button primary-btn pro-btn">
            Upgrade to Pro
          </a>
        </div>
      </div>
    </section>

    <WhitepaperCta />

    <!-- Compliance -->
    <section class="transparency-atmospheric" aria-labelledby="transparency-title">
      <div class="atmospheric-header">
        <span class="section-tag">COMPLIANCE PROTOCOL</span>
        <h2 id="transparency-title">Built for Auditors and Engineers Alike</h2>
        <p>Transparent telemetry, strict tenancy, and automated retention — no black boxes.</p>
      </div>
      <ul class="purpose-list">
        <li>
          <VikingIcon name="shield" size={20} />
          <div class="purpose-text">
            <strong>System Telemetry</strong>
            Aggregates anonymized parameters with full audit trails.
          </div>
        </li>
        <li>
          <VikingIcon name="vpn_key" size={20} />
          <div class="purpose-text">
            <strong>Data Tenancy</strong>
            UUID-scoped isolation across every pipeline boundary.
          </div>
        </li>
        <li>
          <VikingIcon name="policy" size={20} />
          <div class="purpose-text">
            <strong>30-Day Retention</strong>
            Automated purge policies keep you compliant by default.
          </div>
        </li>
        <li>
          <VikingIcon name="bug_report" size={20} />
          <div class="purpose-text">
            <strong>Vuln Triage</strong>
            Semgrep and Trivy findings auto-ticketed to your Kanban.
          </div>
        </li>
      </ul>
    </section>
  </div>
</Layout>
