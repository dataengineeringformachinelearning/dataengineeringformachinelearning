---
import Layout from '../layouts/Layout.astro';
import VikingIcon from '../components/VikingIcon.astro';
import fs from 'node:fs';
import { marked } from 'marked';
import { siteEnv } from '../lib/site-env';
import { techArticleJsonLd, canonicalHref } from '../lib/seo';
import '../styles/publication.scss';

const { MARKETING_URL } = siteEnv();
const pageTitle = 'The Whitepaper - DEML Platform';
const pageDescription =
  'Architecture diagrams, event projection patterns, and automated threat mitigation strategies powering DEML.';
const whitepaperJsonLd = techArticleJsonLd(
  pageTitle,
  pageDescription,
  canonicalHref('/whitepaper', MARKETING_URL),
);

const whitepaperPath = process.cwd() + '/src/assets/content/whitepaper.md';
const rawMarkdown = fs.existsSync(whitepaperPath)
  ? fs.readFileSync(whitepaperPath, 'utf-8')
  : '# Whitepaper\n\nContent syncing from WHITEPAPER.md…';

const rawSections = rawMarkdown.split(/(?=^## )/m).filter(Boolean);

interface WhitepaperSection {
  title: string;
  html: string;
  num: string;
  label: string;
  anchor: string;
}

const sections: WhitepaperSection[] = rawSections.map(chunk => {
  const trimmed = chunk.trim();
  const lines = trimmed.split('\n');
  const titleLine = lines[0] ?? '';
  const title = titleLine.startsWith('## ')
    ? titleLine.replace(/^##\s+/, '').trim()
    : 'Overview';
  const numMatch = title.match(/^(\d+)\.\s*/);
  const num = numMatch?.[1] ?? '';
  const label = title.replace(/^\d+\.\s*/, '');
  const anchor = `section-${title.replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}`;
  return { title, html: marked.parse(trimmed) as string, num, label, anchor };
});

const integrationPlatforms = [
  'Kubernetes',
  'TensorFlow',
  'PyTorch',
  'Apache Spark',
  'Databricks',
  'AWS Redshift',
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="DEML whitepaper, event projections, threat mitigation, multi-tenant architecture, Kubernetes, PyTorch, AWS Redshift"
  ogType="article"
  jsonLd={whitepaperJsonLd}
>
  <div class="dashboard-page-container whitepaper-page">
    <div class="dashboard-content-area">
      <div class="page-inner-wrapper whitepaper-wrapper">
        <article class="publication-shell">
          <header class="publication-hero">
            <div class="hero-brand">
              <VikingIcon name="drakkar" size={36} color="accent" class="hero-brand-icon" />
            </div>
            <div class="section-tag-row">
              <span class="section-tag">Research · Architecture</span>
            </div>
            <h1 class="hero-title">Scalable Telemetry, Predictive SLAs, &amp; Automated Threat Mitigation</h1>
            <p class="hero-subtitle">
              Architecting the DEML platform: high-throughput event pipelines, ML-forecasted service
              levels, automated STIX 2.1 threat sharing, and integrated vulnerability management.
            </p>

            <div class="hero-meta">
              <span>Published: July 2026</span>
              <span class="meta-dot">•</span>
              <span>
                Author:&nbsp;<a href="https://joealongi.dev/" target="_blank" rel="noopener noreferrer">Joe Alongi</a>
              </span>
              <span class="meta-dot">•</span>
              <a
                href="https://orcid.org/0009-0007-2401-2603"
                target="_blank"
                rel="me noopener noreferrer"
              >
                ORCID 0009-0007-2401-2603
              </a>
              <span class="meta-dot">•</span>
              <a
                href="https://doi.org/10.5281/zenodo.20778532"
                target="_blank"
                rel="noopener noreferrer"
              >
                DOI 10.5281/zenodo.20778532
              </a>
            </div>

            <div class="hero-actions no-print">
              <button class="hero-btn primary" id="download-pdf-btn" type="button">
                <VikingIcon name="download" size={20} />
                Download PDF
              </button>
              <a href="/documentation" class="hero-btn secondary">
                <VikingIcon name="menu_book" size={20} />
                Integration Guides
              </a>
            </div>

            <aside class="integration-strip" aria-label="Supported integrations">
              {integrationPlatforms.map(name => (
                <span class="integration-pill">{name}</span>
              ))}
            </aside>

            <aside class="arxiv-banner no-print">
              <VikingIcon name="info" size={20} />
              <div>
                <strong>arXiv Endorsement Request:</strong> We are seeking an arXiv endorsement to
                publish this whitepaper to <code>cs.CR</code>. Qualified authors may endorse using code{' '}
                <strong>ZISEYL</strong>{' '}
                <a href="https://arxiv.org/auth/endorse?x=ZISEYL" target="_blank" rel="noopener noreferrer">
                  here
                </a>.
              </div>
            </aside>
          </header>

          <nav class="publication-toc no-print" aria-label="Whitepaper sections">
            <h2 class="toc-heading">Contents</h2>
            <ol class="toc-list">
              {sections.map(section => (
                <li>
                  <a href={`#${section.anchor}`} class="toc-item">
                    <span class="toc-num">{section.num || '—'}</span>
                    <span class="toc-label">{section.label}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>

          <div class="publication-body">
            {sections.map(section => (
              <section class="publication-section" id={section.anchor}>
                <div set:html={section.html}></div>
              </section>
            ))}
          </div>
        </article>
      </div>
    </div>
  </div>
</Layout>

<style lang="scss">
.whitepaper-page {
  min-height: calc(100vh - 64px);
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, color-mix(in srgb, var(--viking-teal-600) 10%, transparent), transparent),
    var(--bg-color);
}

.whitepaper-wrapper {
  max-width: 860px;
  margin: 0 auto;
  padding: 32px 16px 80px;

  @media (min-width: 768px) {
    padding: 40px 24px 80px;
  }
}

.publication-hero {
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;

    a {
      color: var(--viking-teal-600);
      text-decoration: none;
      &:hover { text-decoration: underline; }
    }

    .meta-dot { opacity: 0.4; }
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none !important;
    cursor: pointer;
    transition: all 0.2s ease;

    &.primary {
      background: var(--viking-teal-600);
      color: var(--white) !important;
      border: 1px solid var(--viking-teal-600);
      &:hover {
        background: var(--viking-teal-400);
        border-color: var(--viking-teal-400);
      }
    }

    &.secondary {
      background: transparent;
      color: var(--viking-teal-600) !important;
      border: 1px solid color-mix(in srgb, var(--viking-teal-600) 40%, var(--border));
      &:hover {
        background: color-mix(in srgb, var(--viking-teal-600) 10%, transparent);
      }
    }
  }

  .integration-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .integration-pill {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--viking-teal-600) 30%, var(--border));
    background: color-mix(in srgb, var(--viking-teal-600) 8%, var(--color-surface));
    color: var(--text-color);
  }

  .arxiv-banner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    text-align: left;
    padding: 14px 18px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--viking-teal-600) 25%, transparent);
    background: color-mix(in srgb, var(--viking-teal-600) 6%, var(--color-surface));
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 680px;
    margin: 0 auto;

    code {
      padding: 1px 5px;
      border-radius: 4px;
      background: var(--bg-color);
      border: 1px solid var(--border);
      font-size: 0.84em;
    }

    a {
      color: var(--viking-teal-600);
      font-weight: 600;
    }
  }
}

.publication-toc .toc-list {
  list-style: none;
}

@media print {
  .no-print {
    display: none !important;
  }

  .publication-section {
    break-inside: avoid;
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('download-pdf-btn');
    btn?.addEventListener('click', () => window.print());
  });
</script>
