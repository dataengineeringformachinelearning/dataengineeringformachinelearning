{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DEML FluxUI Tailwind-to-SASS Mapping Schema",
  "description": "Reference schema describing how Tailwind/Flux patterns map to DEML tokens (THEME.md only). Not a build transform.",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "rules": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "allowed": { "type": "array", "items": { "type": "string" } },
            "disallowed": { "type": "string" }
          }
        },
        "spacing": {
          "type": "object",
          "properties": {
            "grid": { "type": "string", "const": "9px" },
            "tokens": { "type": "array", "items": { "type": "string" } }
          }
        },
        "typography": {
          "type": "object",
          "properties": {
            "minFontSize": { "type": "string", "const": "18px" },
            "family": { "type": "string", "const": "Inter" }
          }
        }
      }
    },
    "componentMappings": {
      "type": "object"
    }
  },
  "required": ["name", "version", "rules"]
}
