# Exactly one production role per service: relay, scheduler, probe, normalizer, ingest, cpe.
DEML_ROLE=relay
DATABASE_URL=postgresql://user:password@postgres:5432/deml?sslmode=verify-full # pragma: allowlist secret
PORT=8080
STRUCTURED_LOGS=true
RUST_LOG=deml_daemon=info,warn

# relay / scheduler / normalizer
REDPANDA_BROKERS=redpanda:9092
REDPANDA_SECURITY_PROTOCOL=SSL
REDPANDA_SSL_CA_B64=base64-of-ca-pem
REDPANDA_SSL_CERT_B64=base64-of-client-certificate-pem
REDPANDA_SSL_KEY_B64=base64-of-client-private-key-pem

# Transport plus authenticated durable-message encryption (production: required).
DEML_TRANSPORT_SECURITY=required
DEML_INTERNODE_ENCRYPTION=required
DEML_INTERNODE_ACTIVE_KID=2026-07
DEML_INTERNODE_KEYS={"2026-07":"replace-with-43-character-base64url-key"}
DEML_NODE_ID=deml-relay

# relay
BATCH_SIZE=100
POLL_INTERVAL_SECS=1
MAX_ATTEMPTS=5
MAX_CONCURRENCY=64

# probe
PINGER_INTERVAL_SECS=30
HEALTH_PINGER_SKIP_TLS_VERIFY=false

# normalizer
NORMALIZER_GROUP_ID=deml-rust-telemetry-normalizer-v1

# ingest (required; fail closed when unavailable)
REDIS_URL=rediss://dragonfly.example.net:6379
REDIS_SSL_CA_B64=base64-of-dragonfly-ca-pem

# cpe (dictionary is populated by the pinned offline importer job)
CPE_REDIS_URL=rediss://dragonfly.example.net:6379/8

# optional OTLP/HTTP exporter; service name defaults from DEML_ROLE
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.net
OTEL_SERVICE_NAME=deml-relay
