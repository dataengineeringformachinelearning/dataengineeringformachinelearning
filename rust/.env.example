# Exactly one production role per service: relay, scheduler, probe, normalizer, ingest, cpe.
DEML_ROLE=relay
DATABASE_URL=postgresql://user:password@postgres:5432/deml # pragma: allowlist secret
PORT=8080
STRUCTURED_LOGS=true
RUST_LOG=deml_daemon=info,warn

# relay / scheduler / normalizer
REDPANDA_BROKERS=redpanda:9092
REDPANDA_SASL_USERNAME=
REDPANDA_SASL_PASSWORD=
REDPANDA_SSL=false

# relay
BATCH_SIZE=100
POLL_INTERVAL_SECS=1
MAX_ATTEMPTS=5
MAX_CONCURRENCY=64

# probe
PINGER_INTERVAL_SECS=30
HEALTH_PINGER_SKIP_TLS_VERIFY=false

# normalizer
NORMALIZER_GROUP_ID=deml-rust-telemetry-normalizer-v1

# ingest (required; fail closed when unavailable)
REDIS_URL=redis://dragonfly:6379

# cpe (dictionary is populated by the pinned offline importer job)
CPE_REDIS_URL=redis://dragonfly:6379/8

# optional OTLP/HTTP exporter; service name defaults from DEML_ROLE
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=deml-relay
