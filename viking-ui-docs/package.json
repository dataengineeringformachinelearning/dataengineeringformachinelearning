{
  "name": "viking-ui-docs",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Viking-UI documentation showcase (Astro) for the DEML design system.",
  "scripts": {
    "prebuild": "npm run build:static-css",
    "predev": "npm run build:static-css",
    "build:static-css": "node scripts/build-static-css.mjs",
    "dev": "astro dev --port 4300",
    "start": "astro dev --port 4300",
    "build": "astro build",
    "embed:storybook": "node scripts/embed-storybook.mjs",
    "preview": "astro preview --port 4300",
    "test:visual": "playwright test --config=playwright.config.ts",
    "test:visual:update": "playwright test --config=playwright.config.ts --update-snapshots"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@dataengineeringformachinelearning/viking-ui": "^6.3.0",
    "@sentry/browser": "^9.47.1",
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "esbuild": "^0.25.12",
    "sass": "^1.89.2",
    "typescript": "~6.0.3"
  }
}
