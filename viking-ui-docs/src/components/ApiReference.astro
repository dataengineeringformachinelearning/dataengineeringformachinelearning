---
import type { ComponentApi } from '../lib/component-api';

export interface Props {
  api: ComponentApi;
  selector?: string;
  wcSelector?: string;
}

const { api, selector, wcSelector } = Astro.props;

const hasInputs = api.inputs && api.inputs.length > 0;
const hasOutputs = api.outputs && api.outputs.length > 0;
const hasAttributes = api.attributes && api.attributes.length > 0;
const hasEvents = api.events && api.events.length > 0;
const hasCss = api.cssClasses && api.cssClasses.length > 0;
---

<section class="api-reference" aria-label="Component API reference">
  <header class="api-reference-header">
    <h4 class="viking-heading viking-heading-sm">API reference</h4>
    {(selector || wcSelector) && (
      <div class="api-selectors">
        {selector && (
          <span class="api-selector-chip">
            Angular <code>{selector}</code>
          </span>
        )}
        {wcSelector && (
          <span class="api-selector-chip">
            WC <code>{wcSelector}</code>
          </span>
        )}
      </div>
    )}
  </header>

  {hasInputs && (
    <div class="api-prop-group">
      <h5 class="viking-label api-prop-group-label">Inputs (Angular)</h5>
      <div class="api-prop-grid">
        {api.inputs!.map((prop) => (
          <div class="api-prop-card viking-card viking-card-compact">
            <div class="api-prop-name">
              <code>{prop.name}</code>
              <span class="api-prop-type">{prop.type}</span>
            </div>
            {prop.default && (
              <p class="api-prop-default">
                Default: <code>{prop.default}</code>
              </p>
            )}
            <p class="viking-text-muted api-prop-desc">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  {hasOutputs && (
    <div class="api-prop-group">
      <h5 class="viking-label api-prop-group-label">Outputs (Angular)</h5>
      <div class="api-prop-grid">
        {api.outputs!.map((prop) => (
          <div class="api-prop-card viking-card viking-card-compact">
            <div class="api-prop-name">
              <code>{prop.name}</code>
              <span class="api-prop-type">{prop.type}</span>
            </div>
            <p class="viking-text-muted api-prop-desc">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  {hasAttributes && (
    <div class="api-prop-group">
      <h5 class="viking-label api-prop-group-label">Attributes (Web Component)</h5>
      <div class="api-prop-grid">
        {api.attributes!.map((prop) => (
          <div class="api-prop-card viking-card viking-card-compact">
            <div class="api-prop-name">
              <code>{prop.name}</code>
              <span class="api-prop-type">{prop.type}</span>
            </div>
            {prop.default && (
              <p class="api-prop-default">
                Default: <code>{prop.default}</code>
              </p>
            )}
            <p class="viking-text-muted api-prop-desc">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  {hasEvents && (
    <div class="api-prop-group">
      <h5 class="viking-label api-prop-group-label">Events (Web Component)</h5>
      <div class="api-prop-grid">
        {api.events!.map((prop) => (
          <div class="api-prop-card viking-card viking-card-compact">
            <div class="api-prop-name">
              <code>{prop.name}</code>
              <span class="api-prop-type">{prop.type}</span>
            </div>
            <p class="viking-text-muted api-prop-desc">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  {hasCss && (
    <div class="api-prop-group">
      <h5 class="viking-label api-prop-group-label">CSS classes (static HTML)</h5>
      <div class="api-prop-grid">
        {api.cssClasses!.map((prop) => (
          <div class="api-prop-card viking-card viking-card-compact">
            <div class="api-prop-name">
              <code>{prop.name}</code>
            </div>
            <p class="viking-text-muted api-prop-desc">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}
</section>
