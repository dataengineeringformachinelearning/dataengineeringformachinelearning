---
import type { FrameworkTab } from '../lib/site';
import { FRAMEWORK_TABS } from '../lib/site';

export interface Props {
  snippets: Record<FrameworkTab, string>;
  defaultTab?: FrameworkTab;
}

const { snippets, defaultTab = 'angular' } = Astro.props;
const uid = `code-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="code-block" data-code-block={uid}>
  <div class="code-block-tabs">
    <div class="code-block-tab-list" role="tablist" aria-label="Framework code examples">
      {FRAMEWORK_TABS.map((tab) => (
        <button
          type="button"
          class:list={['code-block-tab', { 'is-active': tab.id === defaultTab }]}
          role="tab"
          aria-selected={tab.id === defaultTab}
          data-tab={tab.id}
        >
          {tab.label}
        </button>
      ))}
    </div>
    <button type="button" class="code-block-copy" data-copy-btn aria-label="Copy code to clipboard">
      <span data-viking-icon="copy" data-viking-icon-size="16" aria-hidden="true"></span>
      <span class="code-block-copy-label">Copy</span>
    </button>
  </div>
  {FRAMEWORK_TABS.map((tab) => (
    <pre
      class:list={['code-block-panel', { 'is-active': tab.id === defaultTab }]}
      role="tabpanel"
      data-panel={tab.id}
      hidden={tab.id !== defaultTab}
    ><code>{snippets[tab.id]}</code></pre>
  ))}
</div>

<script define:vars={{ uid }}>
  const root = document.querySelector(`[data-code-block="${uid}"]`);
  if (!root) throw new Error('Code block root missing');

  const tabs = root.querySelectorAll('[data-tab]');
  const panels = root.querySelectorAll('[data-panel]');
  const copyBtn = root.querySelector('[data-copy-btn]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        const active = t.getAttribute('data-tab') === id;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', String(active));
      });
      panels.forEach((p) => {
        const active = p.getAttribute('data-panel') === id;
        p.classList.toggle('is-active', active);
        p.hidden = !active;
      });
    });
  });

  copyBtn?.addEventListener('click', async () => {
    const active = root.querySelector('[data-panel].is-active code');
    if (!active) return;
    try {
      await navigator.clipboard.writeText(active.textContent ?? '');
      const label = copyBtn.querySelector('.code-block-copy-label');
      if (label) {
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy'; }, 2000);
      }
    } catch {
      /* clipboard blocked */
    }
  });
</script>
