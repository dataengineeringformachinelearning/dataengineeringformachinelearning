---
import CodeBlock from './CodeBlock.astro';
import ApiReference from './ApiReference.astro';
import { getComponentApi } from '../lib/component-api';
import { FRAMEWORK_TABS } from '../lib/site';
import type { ShowcaseComponent } from '../lib/component-registry';

export interface Props {
  component: ShowcaseComponent;
  /** Show inline API reference */
  showApi?: boolean;
  /** Hide card header (used on detail pages where header is separate) */
  hideHeader?: boolean;
  /** Category id for gallery filtering */
  categoryId?: string;
  /** compact = gallery grid card; full = detail page with code + API */
  variant?: 'compact' | 'full';
}

const {
  component,
  showApi = true,
  hideHeader = false,
  categoryId,
  variant = 'compact',
} = Astro.props;
const api = component.api ?? getComponentApi(component.id);
const isCompact = variant === 'compact';
---

<article
  class:list={['component-showcase-card', 'viking-card', { 'component-showcase-card-compact': isCompact }]}
  id={component.id}
  data-component-id={component.id}
  data-component-name={component.name}
  data-component-description={component.description}
  data-component-tags={component.tags?.join(' ') ?? ''}
  data-component-category={categoryId ?? ''}
>
  {!hideHeader && (
    <header class="component-showcase-header">
      <div class="component-showcase-title-block">
        <h3 class="viking-heading viking-heading-sm">
          <a href={`/components/${component.id}`} class="component-showcase-link">
            {component.name}
          </a>
        </h3>
        <p class="viking-text-muted component-showcase-desc">{component.description}</p>
      </div>
      {component.tags && component.tags.length > 0 && (
        <div class="component-showcase-tags">
          {component.tags.map((tag) => (
            <span class="viking-badge viking-badge-subtle">{tag}</span>
          ))}
        </div>
      )}
    </header>
  )}

  <div class="component-showcase-preview" aria-label={`${component.name} preview`}>
    <Fragment set:html={component.preview} />
  </div>

  {isCompact ? (
    <footer class="component-showcase-footer">
      <div class="component-showcase-frameworks" aria-label="Supported frameworks">
        {FRAMEWORK_TABS.map((tab) => (
          <span class="component-framework-chip">{tab.label}</span>
        ))}
      </div>
      <a href={`/components/${component.id}`} class="component-showcase-cta">
        View details
        <span data-viking-icon="arrow-right" data-viking-icon-size="14" aria-hidden="true"></span>
      </a>
    </footer>
  ) : (
    <>
      <div class="component-showcase-code">
        <p class="viking-label component-showcase-code-label">Multi-framework usage</p>
        <CodeBlock snippets={component.snippets} />
      </div>
      {showApi && api && (
        <div class="component-showcase-api">
          <ApiReference
            api={api}
            selector={component.selector}
            wcSelector={component.wcSelector}
          />
        </div>
      )}
    </>
  )}
</article>
