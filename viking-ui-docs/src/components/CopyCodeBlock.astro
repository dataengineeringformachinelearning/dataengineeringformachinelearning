---
export interface Props {
  code: string;
  label: string;
}

const { code, label } = Astro.props;
const uid = `copy-code-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="code-block" data-copy-code-block={uid}>
  <div class="code-block-tabs" role="presentation">
    <span class="code-block-tab is-active" role="presentation">{label}</span>
    <button type="button" class="code-block-copy" data-copy-btn aria-label={`Copy ${label} code`}>
      <span data-viking-icon="copy" data-viking-icon-size="16" aria-hidden="true"></span>
      <span class="code-block-copy-label">Copy</span>
    </button>
  </div>
  <pre class="code-block-panel is-active"><code>{code}</code></pre>
</div>

<script define:vars={{ uid }}>
  const root = document.querySelector(`[data-copy-code-block="${uid}"]`);
  const copyButton = root?.querySelector('[data-copy-btn]');

  copyButton?.addEventListener('click', async () => {
    const codeElement = root?.querySelector('code');
    if (!codeElement) return;

    try {
      await navigator.clipboard.writeText(codeElement.textContent ?? '');
      const label = copyButton.querySelector('.code-block-copy-label');
      if (label) {
        label.textContent = 'Copied!';
        window.setTimeout(() => {
          label.textContent = 'Copy';
        }, 2000);
      }
    } catch {
      /* Clipboard access can be blocked by browser policy. */
    }
  });
</script>
