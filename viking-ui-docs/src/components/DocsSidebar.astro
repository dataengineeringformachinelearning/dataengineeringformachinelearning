---
import { SITE } from '../lib/site';
import { SHOWCASE_CATEGORIES } from '../lib/component-registry';

export interface Props {
  variant?: 'components' | 'docs';
}

const { variant = 'docs' } = Astro.props;

const DOC_LINKS = [
  { href: '/', label: 'Overview' },
  { href: '/components', label: 'Component gallery' },
  { href: '/playground', label: 'Playground' },
  { href: '/#cdn-usage', label: 'Use via jsDelivr CDN' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/tokens', label: 'Design tokens' },
  { href: '/theming', label: 'Theming' },
  { href: '/frameworks', label: 'Framework guides' },
  { href: '/contributing', label: 'Contributing' },
] as const;
---

<aside class="docs-sidebar" aria-label="Section navigation">
  <div class="docs-sidebar-inner">
    {variant === 'components' ? (
      <>
        <p class="docs-sidebar-heading">Components</p>
        <nav class="docs-sidebar-nav">
          {SHOWCASE_CATEGORIES.map((cat) => (
            <div class="docs-sidebar-group">
              <a href={`/components#${cat.id}`} class="docs-sidebar-group-link">{cat.label}</a>
              <ul class="docs-sidebar-list">
                {cat.components.map((comp) => (
                  <li>
                    <a href={`/components/${comp.id}`} class="docs-sidebar-link">{comp.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </>
    ) : (
      <>
        <p class="docs-sidebar-heading">Documentation</p>
        <nav class="docs-sidebar-nav">
          {DOC_LINKS.map((link) => (
            <a href={link.href} class="docs-sidebar-link">{link.label}</a>
          ))}
        </nav>
        <p class="docs-sidebar-heading">Resources</p>
        <nav class="docs-sidebar-nav">
          <a href={SITE.github} class="docs-sidebar-link" target="_blank" rel="noopener">GitHub repository</a>
          <a href={`${SITE.github}/blob/main/CONTRIBUTING.md`} class="docs-sidebar-link" target="_blank" rel="noopener">CONTRIBUTING.md</a>
          <a href={`${SITE.github}/blob/main/THEME.md`} class="docs-sidebar-link" target="_blank" rel="noopener">THEME.md</a>
          <a href={SITE.app} class="docs-sidebar-link" target="_blank" rel="noopener">Live app (deml.app)</a>
        </nav>
      </>
    )}
  </div>
</aside>

<script>
  const hashLinks = document.querySelectorAll('.docs-sidebar a[href*="#"]');
  hashLinks.forEach((link) => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href') ?? '';
      const hashIndex = href.indexOf('#');
      if (hashIndex === -1) return;
      const path = href.slice(0, hashIndex);
      const id = href.slice(hashIndex + 1);
      if (path && path !== window.location.pathname) return;
      e.preventDefault();
      const target = document.getElementById(id);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', `${path || window.location.pathname}#${id}`);
      }
    });
  });
</script>
