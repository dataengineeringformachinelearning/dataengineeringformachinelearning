---
import { SITE } from '../lib/site';

const year = new Date().getFullYear();
---

{/* Canonical DEML theme footer (viking-site-footer WC) — same as marketing/app. */}
<viking-site-footer
  context="docs"
  app-url={SITE.app}
  marketing-url={SITE.marketing}
  backend-url="https://backend.deml.app"
  year={year}
/>
