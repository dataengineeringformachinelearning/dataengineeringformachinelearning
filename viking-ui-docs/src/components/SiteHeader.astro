---
import { SITE, NAV_LINKS, DOCS_PAGE_SEARCH_ITEMS } from '../lib/site';
import { COMPONENT_SEARCH_ITEMS } from '../lib/component-registry';

const currentPath = Astro.url.pathname;
const searchItemsJson = JSON.stringify([...DOCS_PAGE_SEARCH_ITEMS, ...COMPONENT_SEARCH_ITEMS]);
---

<header class="docs-header">
  <div class="docs-header-inner page-inner-wrapper">
    <a href="/" class="docs-brand" aria-label="Viking-UI home">
      <svg class="docs-brand-mark" width="28" height="28" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M4 18 L12 4 L20 18 Z M8 14 h8" stroke="currentColor" stroke-width="1.5" fill="none" />
      </svg>
      <span class="docs-brand-text">
        <span class="docs-brand-name">Viking-UI</span>
        <span class="docs-brand-tag">DEML Design System</span>
      </span>
    </a>

    <nav class="docs-nav" aria-label="Documentation">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={['docs-nav-link', { 'is-active': currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="docs-header-actions">
      <button
        type="button"
        class="docs-search-trigger viking-btn viking-btn-outline viking-btn-compact"
        id="docs-search-trigger"
        aria-label="Search documentation (⌘K)"
      >
        <span class="docs-search-trigger-icon" aria-hidden="true">⌕</span>
        <span class="docs-search-trigger-label">Search</span>
        <span class="docs-search-trigger-kbd" aria-hidden="true"><span class="viking-kbd-static">⌘K</span></span>
      </button>
      <a
        href={SITE.github}
        class="docs-github-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View source on GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="docs-github-label">GitHub</span>
      </a>
      <viking-theme-toggle-wc aria-label="Toggle light and dark theme"></viking-theme-toggle-wc>
    </div>
  </div>
</header>

<viking-search-palette-wc
  id="docs-search-palette"
  global-shortcut
  placeholder="Search Viking-UI documentation…"
  items={searchItemsJson}
></viking-search-palette-wc>

<script>
  const initDocsSearch = (): void => {
    const palette = document.getElementById('docs-search-palette');
    const trigger = document.getElementById('docs-search-trigger');
    if (!palette || trigger?.hasAttribute('data-search-bound')) return;
    trigger?.setAttribute('data-search-bound', 'true');
    trigger?.addEventListener('click', () => palette.setAttribute('open', ''));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDocsSearch);
  } else {
    initDocsSearch();
  }
</script>

<style>
  .docs-search-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--viking-space-1);
    min-width: 0;
  }

  .docs-search-trigger-icon {
    color: var(--viking-text-muted);
    font-size: var(--viking-font-size-lg);
    line-height: 1;
  }

  .docs-search-trigger-label {
    font-size: var(--viking-font-size-sm);
  }

  .docs-search-trigger-kbd {
    display: none;
  }

  @media (min-width: 960px) {
    .docs-search-trigger {
      min-width: 12rem;
      justify-content: flex-start;
    }

    .docs-search-trigger-kbd {
      display: inline-flex;
      margin-left: auto;
    }
  }

  @media (max-width: 640px) {
    .docs-search-trigger-label {
      display: none;
    }
  }
</style>
