---
import '../styles/global.scss';
import { SITE } from '../lib/site';

export interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  bodyClass = '',
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} · ${SITE.name}`;
---

<!doctype html>
<html lang="en" data-deml-context="docs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="light dark" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link
      rel="preload"
      href="/assets/fonts/inter/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <style is:inline>
      :root {
        --viking-teal-700: #0a5c5f;
        --viking-teal-600: #0d7377;
        --viking-teal-400: #14a3a8;
        --viking-crimson-500: #a83344;
        --viking-charcoal-900: #111111;
        --viking-white: #f5f5f5;
        --viking-white-pure: #ffffff;
      }
      html[data-theme='dark'] {
        --color-primary: var(--viking-teal-600);
        --bg-color: var(--viking-charcoal-900);
        --text-color: var(--viking-white);
      }
      html[data-theme='light'] {
        --color-primary: var(--viking-teal-700);
        --bg-color: var(--viking-white-pure);
        --text-color: var(--viking-charcoal-900);
      }
    </style>

    <link rel="stylesheet" href="/assets/design-tokens.css" />
    <link rel="stylesheet" href="/assets/deml-components.css" />
    <link rel="stylesheet" href="/assets/viking-components.css" />
    <link rel="stylesheet" href="/assets/viking-ui.css" />

    <script type="module" src="/assets/viking-ui-elements.js"></script>
    <script is:inline src="/assets/widgets/command-palette.js" defer></script>

    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var theme = 'dark';
        if (saved === 'light' || saved === 'dark') theme = saved;
        else theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
  </head>
  <body class={`viking-ui-body docs-body ${bodyClass}`.trim()}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot name="header" />
    <slot />
  </body>
</html>
