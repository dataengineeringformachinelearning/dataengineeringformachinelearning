---
import DocLayout from '../layouts/DocLayout.astro';
import { SITE } from '../lib/site';
import { LIBRARY_COMPONENT_COUNT } from '../lib/library-stats';
import { API_CONVENTIONS } from '../lib/component-api';
---

<DocLayout
  title="Architecture"
  description="How Viking-UI's universal three-layer architecture works — tokens, CSS, Web Components, and Angular."
>
  <div class="page-inner-wrapper">
    <header class="viking-page-header-static">
      <p class="viking-label">Viking-UI design system</p>
      <h1 class="viking-heading viking-heading-xl">Architecture</h1>
      <p class="viking-text-muted">
        Viking-UI ships one package across Angular, Astro, Django, and vanilla HTML.
        <code>packages/viking-ui/</code> is the single source of truth for tokens, static CSS,
        Web Components, Angular wrappers, and framework-neutral utility exports.
      </p>
      <viking-callout-wc tone="accent" heading="Single-source discipline" class="viking-story-footer-space">
        All styling originates in <code>packages/viking-ui/</code>. Never add app-local CSS, SCSS, or <code>--viking-*</code> tokens elsewhere. After token or component changes, run the sync script to propagate built artifacts.
      </viking-callout-wc>
    </header>

    <section class="showcase-category" aria-labelledby="layers-heading">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="layers-heading">Three consumption layers</h2>
        <p class="viking-text-muted">
          Pick the layer that matches your stack. All layers compile from the same SCSS source in
          <code>packages/viking-ui/src/styles/</code>.
        </p>
      </header>

      <div class="architecture-layer-grid">
        <article class="viking-card architecture-layer">
          <span class="viking-label">Layer 1 — Tokens</span>
          <h3 class="viking-heading viking-heading-sm">CSS custom properties</h3>
          <p class="viking-text-muted">
            <code>design-tokens.css</code> exports semantic aliases:
            <code>--viking-bg</code>, <code>--viking-accent</code>, <code>--viking-space-*</code>.
            Set <code>data-theme="dark|light"</code> on <code>&lt;html&gt;</code>.
          </p>
          <p class="viking-text-muted">
            <strong>Best for:</strong> custom layouts, marketing pages, any surface that needs colors
            and spacing without interactive primitives.
          </p>
        </article>

        <article class="viking-card architecture-layer">
          <span class="viking-label">Layer 2 — CSS classes</span>
          <h3 class="viking-heading viking-heading-sm">Static primitives</h3>
          <p class="viking-text-muted">
            <code>viking-components.css</code> / <code>viking-ui.css</code> provide
            <code>.viking-btn</code>, <code>.viking-card</code>, <code>.viking-input-shell</code>, and
            form field stacks — no JavaScript required.
          </p>
          <p class="viking-text-muted">
            <strong>Best for:</strong> Django templates, Swagger overlays, server-rendered HTML.
          </p>
        </article>

        <article class="viking-card architecture-layer">
          <span class="viking-label">Layer 3 — Components</span>
          <h3 class="viking-heading viking-heading-sm">Web Components + Angular</h3>
          <p class="viking-text-muted">
            Interactive elements — <code>viking-button-wc</code>, <code>viking-input-wc</code>,
            <code>viking-badge-wc</code>, <code>viking-theme-toggle-wc</code> — use Shadow DOM with
            injected token styles. Angular apps import thin wrappers (<code>viking-button</code>) that
            delegate to the same Web Components where applicable — {LIBRARY_COMPONENT_COUNT}+ Angular
            primitives today.
          </p>
          <p class="viking-text-muted">
            <strong>Best for:</strong> deml.app, interactive forms, charts, modals, and auth flows.
          </p>
        </article>
      </div>
    </section>

    <section class="showcase-category" aria-labelledby="flow-heading">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="flow-heading">Build and sync pipeline</h2>
      </header>
      <pre class="code-block-panel is-active architecture-flow" aria-label="Build pipeline diagram"><code>packages/viking-ui/
├── src/styles/_variables.scss       ← single source of truth (edit tokens here)
        │
        ├── tokens-export.scss        → design-tokens.css
        ├── components-bundle.scss    → viking-components.css
        └── viking-ui-bundle.scss     → viking-ui.css (full bundle)

├── src/web/index.ts                  → web-components.js / viking-ui-elements.js
├── src/core/icons.public.ts          → icons.js
├── src/lib/site-drakkar/*.ts         → site-drakkar.js
└── src/public-api.ts                 → Angular/root package barrel

npm run build:viking-ui:package         (ng-packagr + package scripts)
python scripts/sync_design_system.py    → frontend, backend, marketing assets

npm run pack:viking-ui                  → external-style npm package check</code></pre>
    </section>

    <section class="showcase-category" aria-labelledby="wc-heading">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="wc-heading">Web Component pattern (v2)</h2>
        <p class="viking-text-muted">
          New interactive primitives follow a package-first architecture. Framework-neutral code,
          public exports, and Angular wrappers live together in <code>packages/viking-ui/</code>.
        </p>
      </header>

      <div class="architecture-pattern">
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">1. Token-only SCSS</h3>
          <p class="viking-text-muted">
            Base classes in <code>_buttons.scss</code>, <code>_input.scss</code> — shared by static
            CSS and Shadow DOM injection.
          </p>
        </div>
        <div class="architecture-arrow" aria-hidden="true">→</div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">2. Web Component</h3>
          <p class="viking-text-muted">
            <code>{'viking-{name}-wc'}</code> in <code>src/web/</code> — Shadow DOM, observed attributes,
            custom events (<code>viking-press</code>).
          </p>
        </div>
        <div class="architecture-arrow" aria-hidden="true">→</div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">3. Angular wrapper</h3>
          <p class="viking-text-muted">
            <code>{'viking-{name}'}</code> — signal <code>input()</code> / <code>output()</code>, OnPush,
            delegates rendering to the WC.
          </p>
        </div>
      </div>
    </section>

    <section class="showcase-category" aria-labelledby="api-heading">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="api-heading">Consistent component API</h2>
        <p class="viking-text-muted">
          All Angular components use signal inputs and outputs. Shared types and framework-neutral
          registries are exported through public package entrypoints such as <code>/icons</code>,
          <code>/site-drakkar</code>, and <code>/tokens.json</code>.
        </p>
      </header>
      <div class="showcase-table-wrap">
        <table class="token-table">
          <thead>
            <tr>
              <th scope="col">Convention</th>
              <th scope="col">Type</th>
              <th scope="col">Default</th>
              <th scope="col">Usage</th>
            </tr>
          </thead>
          <tbody>
            {API_CONVENTIONS.map((prop) => (
              <tr>
                <td><code>{prop.name}</code></td>
                <td><code>{prop.type}</code></td>
                <td>{prop.default ? <code>{prop.default}</code> : '—'}</td>
                <td>{prop.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="showcase-category" aria-labelledby="compose-heading">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="compose-heading">Composition patterns</h2>
      </header>
      <div class="landing-feature-grid">
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Form field stack</h3>
          <p class="viking-text-muted">
            Always compose inputs through <code>viking-field</code> → control. Label, description,
            error, and required indicator are handled by the field wrapper.
          </p>
        </div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Card surfaces</h3>
          <p class="viking-text-muted">
            Use <code>viking-card</code>, <code>viking-metric-card</code>, or
            <code>viking-hud-panel</code> — never raw <code>&lt;div class="card"&gt;</code>.
          </p>
        </div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Settings sections</h3>
          <p class="viking-text-muted">
            Group billing and configuration forms with <code>viking-form-section</code> for consistent
            title rhythm and spacing.
          </p>
        </div>
      </div>
    </section>

    <section class="showcase-category" aria-labelledby="next-heading">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="next-heading">Next steps</h2>
      </header>
      <div class="viking-demo-row">
        <viking-button-wc variant="primary" href="/frameworks">Framework setup guides</viking-button-wc>
        <viking-button-wc variant="secondary" href="/theming">Theming guide</viking-button-wc>
        <viking-button-wc variant="outline" href="/contributing">Contributing</viking-button-wc>
        <viking-button-wc variant="ghost" href={SITE.github} target="_blank">GitHub</viking-button-wc>
      </div>
    </section>
  </div>
</DocLayout>
