---
import DocLayout from '../../layouts/DocLayout.astro';
import ComponentCard from '../../components/ComponentCard.astro';
import ShowcaseCategoryBar from '../../components/ShowcaseCategoryBar.astro';
import ApiReference from '../../components/ApiReference.astro';
import { ALL_COMPONENTS, SHOWCASE_CATEGORIES, findComponent } from '../../lib/component-registry';
import { getComponentApi } from '../../lib/component-api';

export const getStaticPaths = () =>
  ALL_COMPONENTS.map((component) => ({
    params: { slug: component.id },
    props: { component },
  }));

const { component } = Astro.props;
const category = SHOWCASE_CATEGORIES.find((c) => c.components.some((comp) => comp.id === component.id));
const api = component.api ?? getComponentApi(component.id);
const related = (component.related ?? [])
  .map((id) => findComponent(id))
  .filter(Boolean);
const jsdelivrTag = component.wcSelector ?? 'viking-card-wc';
const hasWebComponentTag = Boolean(component.wcSelector);
---

<DocLayout
  title={component.name}
  description={component.description}
>
  <ShowcaseCategoryBar activeCategory={category?.id} />

  <div class="page-inner-wrapper showcase-page component-detail-page">
    <nav class="component-breadcrumb" aria-label="Breadcrumb">
      <a href="/components">Components</a>
      {category && (
        <>
          <span aria-hidden="true">/</span>
          <a href={`/components#${category.id}`}>{category.label}</a>
        </>
      )}
      <span aria-hidden="true">/</span>
      <span aria-current="page">{component.name}</span>
    </nav>

    <header class="showcase-detail-header">
      <span class="section-tag">{category?.label ?? 'Component'}</span>
      <h1 class="showcase-hero-title">{component.name}</h1>
      <p class="showcase-hero-lead">{component.description}</p>
      {component.tags && (
        <div class="component-showcase-tags">
          {component.tags.map((tag) => (
            <span class="viking-badge viking-badge-subtle">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <ComponentCard component={component} variant="full" showApi={false} hideHeader />

    <section class="showcase-category">
      <header class="showcase-section-header">
        <h2 class="showcase-section-title">Use this component via jsDelivr CDN</h2>
      </header>
      <p class="viking-text-muted">
        Copy-paste these patterns on any static page, internal dashboard, or external site.
      </p>
      <div class="viking-card viking-stack viking-stack--loose">
        <div>
          <p class="viking-label">1) CSS only</p>
          <pre><code>{`<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/viking-ui.css" />`}</code></pre>
        </div>
        {hasWebComponentTag && (
          <div>
            <p class="viking-label">2) Web Component only</p>
            <pre><code>{`<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/web-components.js"></script>`}</code></pre>
          </div>
        )}
        {hasWebComponentTag && (
          <div>
            <p class="viking-label">3) CSS + Web Components together</p>
            <pre><code>{`<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/viking-ui.css" />
<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/web-components.js"></script>`}</code></pre>
          </div>
        )}
        <div>
          <p class="viking-label">4) Version pinning</p>
          <pre><code>{`<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/viking-ui.css" />
<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/web-components.js"></script>`}</code></pre>
        </div>
        {hasWebComponentTag && (
          <div>
            <p class="viking-label">5) Full minimal HTML</p>
            <pre><code>{`<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>${component.name} CDN example</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/viking-ui.css" />
    <script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@9.3.0/dist/web-components.js"></script>
  </head>
  <body>
    <main class="page-inner-wrapper">
      <${jsdelivrTag}>${component.name} via CDN</${jsdelivrTag}>
    </main>
  </body>
</html>`}</code></pre>
          </div>
        )}
      </div>
    </section>

    {api && (
      <div class="viking-card component-api-panel">
        <ApiReference
          api={api}
          selector={component.selector}
          wcSelector={component.wcSelector}
        />
      </div>
    )}

    {related.length > 0 && (
      <section class="showcase-section showcase-section-compact" aria-labelledby="related-heading">
        <header class="showcase-section-header">
          <h2 class="showcase-section-title" id="related-heading">Related components</h2>
        </header>
        <div class="showcase-related-grid">
          {related.map((rel) => (
            <a href={`/components/${rel!.id}`} class="showcase-related-card viking-card">
              <span class="viking-heading viking-heading-sm">{rel!.name}</span>
              <span class="viking-text-muted">{rel!.description}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="showcase-detail-actions">
      <viking-button-wc variant="primary" href="/playground">Open playground</viking-button-wc>
      <viking-button-wc variant="outline" href="/components">Back to gallery</viking-button-wc>
    </div>
  </div>
</DocLayout>
