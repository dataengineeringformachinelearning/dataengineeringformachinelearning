---
import DocLayout from '../../layouts/DocLayout.astro';
import ComponentCard from '../../components/ComponentCard.astro';
import ShowcaseCategoryBar from '../../components/ShowcaseCategoryBar.astro';
import { SHOWCASE_CATEGORIES, COMPONENT_COUNT } from '../../lib/component-registry';
---

<DocLayout
  title="Components"
  description="Interactive gallery of Viking-UI primitives with multi-framework code snippets."
>
  <div class="page-inner-wrapper showcase-page">
    <header class="showcase-hero viking-unified-hero">
      <div class="showcase-hero-copy viking-unified-hero-copy">
        <div class="showcase-hero-badge viking-unified-hero-badge">
          <span class="showcase-hero-badge-dot pulse-dot" aria-hidden="true"></span>
          <span class="section-tag">Component gallery</span>
        </div>
        <h1 class="showcase-hero-title viking-unified-hero-title">Precision-built primitives</h1>
        <p class="showcase-hero-lead viking-unified-hero-lead">
          Live previews and copy-ready snippets for Angular, Astro, Django, and Web Components.
          <strong id="component-search-count">{COMPONENT_COUNT} components</strong> — each with a dedicated detail page and API reference.
        </p>
        <div class="showcase-hero-actions viking-unified-hero-actions">
          <viking-button-wc variant="primary" href="/playground">Open playground</viking-button-wc>
          <viking-button-wc variant="outline" href="/architecture">Architecture</viking-button-wc>
        </div>
      </div>
      <div class="showcase-hero-panel viking-card viking-unified-hero-panel" aria-label="Live component preview">
        <span class="viking-label">Live preview</span>
        <div class="showcase-hero-preview-grid">
          <div class="showcase-hero-preview-row">
            <viking-button-wc variant="primary">Deploy</viking-button-wc>
            <viking-button-wc variant="outline">Cancel</viking-button-wc>
          </div>
          <viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>
          <div class="showcase-hero-preview-row">
            <viking-badge-wc tone="success">Healthy</viking-badge-wc>
            <viking-badge-wc tone="warning">Degraded</viking-badge-wc>
            <viking-badge-wc tone="danger">Critical</viking-badge-wc>
          </div>
          <div class="showcase-hero-preview-row">
            <div class="viking-progress" role="progressbar" aria-label="Deployment progress" aria-valuenow="72" aria-valuemin="0" aria-valuemax="100">
              <div class="viking-progress-bar viking-progress-value-72"></div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="showcase-toolbar viking-card" aria-label="Gallery filters">
      <div class="showcase-toolbar-row">
        <label class="viking-field showcase-search-field" for="component-search">
          <span class="viking-field-label">Search components</span>
          <div class="viking-input-shell">
            <input
              id="component-search"
              class="viking-input-native"
              type="search"
              placeholder="Search by name, tag, or description…"
              autocomplete="off"
              spellcheck="false"
            />
          </div>
        </label>
        <label class="viking-field showcase-category-field" for="component-category-filter">
          <span class="viking-field-label">Category</span>
          <select id="component-category-filter" class="viking-select-native">
            <option value="all">All categories</option>
            {SHOWCASE_CATEGORIES.map((category) => (
              <option value={category.id}>{category.label}</option>
            ))}
          </select>
        </label>
      </div>
    </section>
  </div>

  <ShowcaseCategoryBar />

  <div class="page-inner-wrapper showcase-page">
    {SHOWCASE_CATEGORIES.map((category) => (
      <section
        class="showcase-section"
        id={category.id}
        data-category-id={category.id}
        aria-labelledby={`${category.id}-heading`}
      >
        <header class="showcase-section-header viking-unified-section-header">
          <span class="section-tag">{category.label}</span>
          <h2 class="showcase-section-title" id={`${category.id}-heading`}>
            {category.label}
          </h2>
          <p class="viking-text-muted showcase-section-desc">{category.description}</p>
        </header>
        <div class="showcase-component-grid">
          {category.components.map((component) => (
            <ComponentCard component={component} categoryId={category.id} variant="compact" />
          ))}
        </div>
      </section>
    ))}
  </div>
</DocLayout>

<script src="../../scripts/showcase-filter.ts"></script>
