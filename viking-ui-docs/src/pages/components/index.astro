---
import DocLayout from '../../layouts/DocLayout.astro';
import ComponentCard from '../../components/ComponentCard.astro';
import { SHOWCASE_CATEGORIES, COMPONENT_COUNT } from '../../lib/component-registry';
import '../../styles/showcase.scss';
---

<DocLayout
  title="Components"
  description="Interactive gallery of Viking-UI primitives with multi-framework code snippets."
  sidebar="components"
>
  <div class="page-inner-wrapper viking-showcase">
    <header class="viking-page-header-static">
      <p class="viking-label">Component gallery</p>
      <h1 class="viking-heading viking-heading-xl">Components</h1>
      <p class="viking-text-muted">
        Live previews and copy-ready snippets for Angular, Astro, Django, and Web Components.
        {COMPONENT_COUNT} documented demos — each with a dedicated detail page and API reference.
      </p>
      <div class="viking-demo-row">
        <viking-button-wc variant="primary" href="/playground">Open playground</viking-button-wc>
        <viking-button-wc variant="outline" href="/architecture">Architecture</viking-button-wc>
      </div>
    </header>

    {SHOWCASE_CATEGORIES.map((category) => (
      <section class="showcase-category" id={category.id} aria-labelledby={`${category.id}-heading`}>
        <header class="showcase-category-header">
          <h2 class="viking-heading viking-heading-sm" id={`${category.id}-heading`}>
            {category.label}
          </h2>
          <p class="viking-text-muted">{category.description}</p>
        </header>
        <div class="showcase-component-list">
          {category.components.map((component) => (
            <ComponentCard component={component} />
          ))}
        </div>
      </section>
    ))}
  </div>
</DocLayout>

<style>
  .viking-showcase {
    display: flex;
    flex-direction: column;
    gap: var(--viking-space-2);
  }
</style>
