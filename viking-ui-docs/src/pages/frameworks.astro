---
import DocLayout from '../layouts/DocLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import CopyCodeBlock from '../components/CopyCodeBlock.astro';
import { SITE } from '../lib/site';

const cdnCss = `<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/viking-ui.css"
/>`;

const cdnWebComponents = `<script
  type="module"
  src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/web-components.js"
></script>`;

const cdnBundle = `${cdnCss}
${cdnWebComponents}`;

const cdnPinned = `<!-- Continuously updated -->
<script
  type="module"
  src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/web-components.js"
></script>

<!-- Deterministic release -->
<script
  type="module"
  src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/web-components.js"
></script>

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/viking-ui.css"
/>`;

const cdnDocument = `<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/viking-ui.css"
    />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/web-components.js"
    ></script>
  </head>
  <body>
    <main class="page-inner-wrapper viking-stack viking-stack--loose">
      <h1 class="viking-heading viking-heading-lg">Operational widget</h1>
      <viking-card-wc compact>
        <h2 class="viking-heading viking-heading-sm">External site ready</h2>
        <p class="viking-text-muted">Embed this HTML directly into any marketing or dashboard page.</p>
      </viking-card-wc>
      <viking-button-wc variant="primary">Launch operation</viking-button-wc>
    </main>
  </body>
</html>`;
---

<DocLayout
  title="Framework Guides"
  description="Use Viking-UI in Angular, Astro, Django templates, and vanilla Web Components."
>
  <div class="page-inner-wrapper">
    <header class="viking-page-header-static">
      <p class="viking-label">Integration</p>
      <h1 class="viking-heading viking-heading-xl">Usage in different frameworks</h1>
      <p class="viking-text-muted">
        Viking-UI is one npm package with multiple public entrypoints. Choose the consumption mode
        that fits your stack — Angular wrappers, Web Components, static CSS, and utility subpaths all
        share the same <code>--viking-*</code> variables.
      </p>
      <viking-callout-wc tone="accent" heading="Single source of truth" class="viking-story-footer-space">
        All styling, tokens, and components originate in <code>packages/viking-ui/</code>. Consume via npm or jsDelivr CDN — never create app-local alternatives.
      </viking-callout-wc>
    </header>

    <div class="framework-grid">
      <article class="framework-card">
        <h2 class="viking-heading viking-heading-sm">Angular</h2>
        <p class="viking-text-muted">
          Full component library with signals, OnPush, and standalone wrappers. Used by deml.app.
        </p>
        <ul class="viking-text-muted">
          <li>Import from <code>{SITE.npm}</code> or <code>{SITE.npm}/angular</code></li>
          <li>Compose via <code>viking-field</code> stacks</li>
          <li>Charts, auth, kanban — full API</li>
        </ul>
      </article>
      <article class="framework-card">
        <h2 class="viking-heading viking-heading-sm">Astro</h2>
        <p class="viking-text-muted">
          Static CSS + Web Components for documentation and marketing surfaces. This site is built
          with Astro.
        </p>
        <ul class="viking-text-muted">
          <li>Load synced <code>viking-ui.css</code> or jsDelivr CDN</li>
          <li>Use <code>&lt;viking-button-wc&gt;</code> in .astro files</li>
          <li>Use <code>{SITE.npm}/icons</code> and <code>{SITE.npm}/site-drakkar</code> for prerender-safe utilities</li>
          <li>Token-only SCSS for custom layouts</li>
        </ul>
      </article>
      <article class="framework-card">
        <h2 class="viking-heading viking-heading-sm">Django / HTML</h2>
        <p class="viking-text-muted">
          CSS-only primitives for Swagger, admin templates, and backend-rendered pages.
        </p>
        <ul class="viking-text-muted">
          <li>Load synced <code>viking-ui.css</code> or jsDelivr CDN</li>
          <li><code>viking-btn</code>, <code>viking-input-shell</code> classes</li>
          <li>Set <code>data-theme</code> on <code>&lt;html&gt;</code></li>
        </ul>
      </article>
      <article class="framework-card">
        <h2 class="viking-heading viking-heading-sm">Web Components</h2>
        <p class="viking-text-muted">
          Framework-agnostic custom elements with Shadow DOM and token injection.
        </p>
        <ul class="viking-text-muted">
          <li><code>web-components.js</code> auto-registers tags as an ESM bundle</li>
          <li><code>viking-ui-elements.js</code> remains available as an IIFE compatibility bundle</li>
          <li>Prefer jsDelivr <code>web-components.js</code> for external or unmanaged pages</li>
          <li><code>viking-button-wc</code>, <code>viking-input-wc</code> today</li>
          <li>More primitives shipping incrementally</li>
        </ul>
      </article>
    </div>

    <section class="showcase-category" aria-labelledby="cdn-usage">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="cdn-usage">Use via jsDelivr CDN</h2>
      </header>
      <p class="viking-text-muted">
        Copy these blocks for any project that can serve HTML. Use <code>@latest</code> for continuous
        updates or pin to a release for deterministic rollouts.
      </p>
      <p class="viking-label">1) CSS only</p>
      <CopyCodeBlock label="CSS only" code={cdnCss} />

      <p class="viking-label">2) Web Components only</p>
      <CopyCodeBlock label="Web Components only" code={cdnWebComponents} />

      <p class="viking-label">3) CSS + Web Components</p>
      <CopyCodeBlock label="CSS + Web Components" code={cdnBundle} />

      <p class="viking-label">4) Version pinning</p>
      <CopyCodeBlock label="Version pinning" code={cdnPinned} />

      <p class="viking-label">5) Full minimal HTML</p>
      <CopyCodeBlock label="Full minimal HTML" code={cdnDocument} />
    </section>

    <section class="showcase-category" aria-labelledby="angular-setup">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="angular-setup">Angular setup</h2>
      </header>
      <CodeBlock
        snippets={{
          angular: `npm install ${SITE.npm}

// app.config.ts or standalone component
import { VikingButton, VikingField, VikingInput } from '${SITE.npm}';

@Component({
  imports: [VikingButton, VikingField, VikingInput],
  template: \`
    <viking-field label="Email" [required]="true">
      <viking-input type="email" placeholder="you@company.com" />
    </viking-field>
    <viking-button variant="primary">Save</viking-button>
  \`,
})`,
          astro: '',
          django: '',
          javascript: '',
        }}
        defaultTab="angular"
      />
    </section>

    <section class="showcase-category" aria-labelledby="astro-setup">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="astro-setup">Astro setup</h2>
      </header>
      <CodeBlock
        snippets={{
          angular: '',
          astro: `---
// Layout.astro — load once globally
import '${SITE.npm}/viking-ui.css';
---

<script>
  import '${SITE.npm}/web-components.js';
</script>

// prerender-safe utilities
import { resolveVikingIcon } from '${SITE.npm}/icons';
import { SITE_NAV_LINKS } from '${SITE.npm}/site-drakkar';

<viking-button-wc variant="primary">Launch</viking-button-wc>
<viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>`,
          django: '',
          javascript: `<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/viking-ui.css"
/>
<script
  type="module"
  src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/web-components.js"
></script>

<viking-button-wc variant="primary">Launch</viking-button-wc>
<viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>`,
        }}
        defaultTab="astro"
      />
    </section>

    <section class="showcase-category" aria-labelledby="django-setup">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="django-setup">Django / static HTML</h2>
      </header>
      <CodeBlock
        snippets={{
          angular: '',
          astro: '',
django: `{# base.html #}
<link rel="stylesheet" href="{% static 'viking-ui.css' %}" />
<!-- or CDN alternative -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/viking-ui.css" />

<html data-theme="dark">
  <button type="button" class="viking-btn viking-btn-primary">Deploy</button>
  <div class="viking-input-shell">
    <input class="viking-input-native" type="email" placeholder="you@company.com" />
  </div>
</html>`,
          javascript: '',
        }}
        defaultTab="django"
      />
    </section>

    <section class="showcase-category" aria-labelledby="wc-setup">
      <header class="showcase-category-header">
        <h2 class="viking-heading viking-heading-sm" id="wc-setup">Web Components (vanilla JS)</h2>
      </header>
      <CodeBlock
        snippets={{
          angular: '',
          astro: '',
          django: '',
          javascript: `<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/viking-ui.css"
/>
<script
  type="module"
  src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@6.0.0/dist/web-components.js"
></script>

<viking-button-wc variant="primary">Launch</viking-button-wc>
<viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>
<viking-badge-wc tone="success">Healthy</viking-badge-wc>
<viking-theme-toggle-wc aria-label="Toggle theme"></viking-theme-toggle-wc>`,
        }}
        defaultTab="javascript"
      />
    </section>
  </div>
</DocLayout>
