---
import DocLayout from '../layouts/DocLayout.astro';
import { SITE } from '../lib/site';
import { COMPONENT_COUNT } from '../lib/component-registry';
import { LIBRARY_COMPONENT_COUNT } from '../lib/library-stats';
import '../styles/showcase.scss';
---

<DocLayout title="Viking-UI — Precision Design System" hideSubnav={false}>
  <div class="page-inner-wrapper">
    <section class="landing-hero">
      <div class="landing-hero-copy">
        <div class="landing-hero-badge">
          <span class="landing-hero-badge-dot" aria-hidden="true"></span>
          <span>Universal design system · v2 · Apache-2.0</span>
        </div>
        <h1 class="viking-heading viking-heading-xl">
          Stop fighting your component library.
        </h1>
        <p class="viking-text-muted">
          Viking-UI delivers precision-engineered primitives for Angular, Astro, Django, and plain
          Web Components. Token-driven styling, WCAG 2.1 AA by construction, zero third-party UI
          runtime dependencies.
        </p>
        <div class="landing-framework-strip" aria-label="Supported frameworks">
          <span class="landing-framework-chip"><code>Angular</code> thin wrappers</span>
          <span class="landing-framework-chip"><code>Astro</code> Web Components</span>
          <span class="landing-framework-chip"><code>Django</code> CSS classes</span>
          <span class="landing-framework-chip"><code>Vanilla</code> custom elements</span>
        </div>
        <div class="landing-hero-actions">
          <viking-button-wc variant="primary" href="/components">Browse components</viking-button-wc>
          <viking-button-wc variant="secondary" href="/playground">Live playground</viking-button-wc>
          <viking-button-wc variant="outline" href="/architecture">Architecture</viking-button-wc>
        </div>
        <p class="viking-text-muted">
          Published as <code>{SITE.npm}</code> — see <a href="/contributing">contributing guide</a>.
        </p>
        <div class="landing-stats" aria-label="Library stats">
          <div class="landing-stat">
            <span class="viking-label">Library primitives</span>
            <strong class="viking-metric">{LIBRARY_COMPONENT_COUNT}</strong>
          </div>
          <div class="landing-stat">
            <span class="viking-label">Documented demos</span>
            <strong class="viking-metric">{COMPONENT_COUNT}</strong>
          </div>
          <div class="landing-stat">
            <span class="viking-label">Frameworks</span>
            <strong class="viking-metric">4</strong>
          </div>
          <div class="landing-stat">
            <span class="viking-label">Accessibility</span>
            <strong class="viking-metric">AA</strong>
          </div>
        </div>
      </div>

      <div class="landing-preview-panel" aria-label="Live component preview">
        <span class="viking-label">Live preview</span>
        <div class="viking-demo-row">
          <viking-button-wc variant="primary">Deploy</viking-button-wc>
          <viking-button-wc variant="outline">Cancel</viking-button-wc>
        </div>
        <viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>
        <viking-card-wc compact>
          <span class="viking-label">Event throughput</span>
          <strong class="viking-metric">8.2K/s</strong>
          <viking-badge-wc tone="success">Healthy</viking-badge-wc>
        </viking-card-wc>
      </div>
    </section>

    <section aria-labelledby="features-heading">
      <h2 class="viking-heading viking-heading-sm" id="features-heading">
        Built for precision engineering
      </h2>
      <div class="landing-feature-grid">
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Framework-agnostic</h3>
          <p class="viking-text-muted">
            One token matrix powers CSS classes, Web Components, and Angular thin wrappers.
            Ship the same visual language everywhere.
          </p>
          <a href="/architecture" class="component-detail-link">Read architecture →</a>
        </div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Zero UI runtime deps</h3>
          <p class="viking-text-muted">
            Native SVG charts, inline icon registry, platform dialog elements. No Material, no CDK
            bloat.
          </p>
        </div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Open for contributions</h3>
          <p class="viking-text-muted">
            Extend the kit in <code>frontend/projects/viking-ui/</code>. Quality gates enforce tokens,
            a11y, and tests automatically.
          </p>
          <a href="/contributing" class="component-detail-link">Contributing guide →</a>
        </div>
      </div>
    </section>

    <section class="showcase-category" aria-labelledby="quickstart-heading">
      <header class="showcase-section-header">
        <h2 class="showcase-section-title" id="quickstart-heading">Quick start</h2>
        <p class="viking-text-muted">Install tokens, load components, compose primitives.</p>
      </header>
      <pre class="code-block-panel is-active" style="border:1px solid var(--viking-border);border-radius:var(--viking-radius-lg);background:var(--viking-charcoal-950,#0a0a0a);padding:var(--viking-space-2);margin:0;"><code># npm
npm install {SITE.npm}

# Static CSS (Astro / Django)
link design-tokens.css + viking-components.css + viking-ui-elements.js

# Angular
import &#123; VikingButton, VikingField, VikingInput &#125; from '{SITE.npm}';</code></pre>
      <p class="viking-text-muted">
        See <a href="/frameworks">framework guides</a> and <a href="/theming">theming guide</a> for
        complete setup paths.
      </p>
    </section>
  </div>
</DocLayout>

<style>
  .component-detail-link {
    display: inline-block;
    margin-top: var(--viking-space-1);
    font-size: var(--viking-font-size-sm);
    color: var(--viking-accent);
    text-decoration: none;
  }

  .component-detail-link:hover {
    text-decoration: underline;
  }
</style>
