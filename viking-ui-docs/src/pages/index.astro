---
import DocLayout from '../layouts/DocLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { SITE } from '../lib/site';
import { COMPONENT_COUNT, SHOWCASE_CATEGORIES } from '../lib/component-registry';
import { LIBRARY_COMPONENT_COUNT } from '../lib/library-stats';
import type { ComponentSnippet } from '../lib/component-registry';

const featuredComponents = SHOWCASE_CATEGORIES.flatMap((category) =>
  category.components.map((component) => ({ ...component, category: category.label }))
).slice(0, 6);

const aestheticPillars = [
  {
    label: 'Aerospace precision',
    title: 'Machined hierarchy',
    body: 'Clean command structure, deterministic rhythm, high-contrast reads, and metallic seams that feel engineered rather than decorated.',
  },
  {
    label: 'Operational restraint',
    title: 'Restrained command presence',
    body: 'Subtle geometric linework, strong silhouettes, and disciplined presence without fantasy illustration, ornament, or theatrical clutter.',
  },
  {
    label: 'Tactile depth',
    title: 'Cards and controls with mass',
    body: 'Deep navy surfaces, etched borders, top-edge highlights, and measured elevation for panels, buttons, and telemetry cards.',
  },
  {
    label: 'Generous precision',
    title: 'Breathing room on the grid',
    body: 'Spacing is generous but exact: every gap resolves to Viking tokens, avoiding both Spartan compression and loose marketing sprawl.',
  },
];

const quickStartSnippets: ComponentSnippet = {
  angular: `npm install @dataengineeringformachinelearning/viking-ui

import { VikingButton, VikingField, VikingInput } from '@dataengineeringformachinelearning/viking-ui';

<viking-field label="Mission ID" [required]="true">
  <viking-input placeholder="DEML-2049" />
</viking-field>
<viking-button variant="primary">Deploy</viking-button>`,
  astro: `npm install @dataengineeringformachinelearning/viking-ui

import "@dataengineeringformachinelearning/viking-ui/viking-ui.css";
import "@dataengineeringformachinelearning/viking-ui/web-components.js";

<viking-button-wc variant="primary">Deploy</viking-button-wc>
<viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>`,
  django: `python scripts/sync_design_system.py

{% load static %}
<link rel="stylesheet" href="{% static 'viking-ui.css' %}" />

<button type="button" class="viking-btn viking-btn-primary">Deploy</button>`,
  javascript: `<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/viking-ui.css" />
<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/web-components.js"></script>

<viking-button-wc variant="primary">Deploy</viking-button-wc>`,
};
---

<DocLayout title="Viking-UI — Precision Design System" hideSubnav={false}>
  <div class="page-inner-wrapper landing-showcase">
    <section class="landing-hero">
      <div class="landing-hero-copy">
        <div class="landing-hero-badge">
          <span class="landing-hero-badge-dot" aria-hidden="true"></span>
          <span>Universal design system / v4 / Apache-2.0</span>
        </div>
        <h1 class="viking-heading viking-heading-xl">
          Precision-engineered UI for operational intelligence.
        </h1>
        <p class="viking-text-muted">
          Viking-UI delivers one consolidated package for Angular, Astro, Django, and plain
          Web Components: machined hierarchy, token-driven spacing, restrained teal/crimson
          accents, WCAG 2.1 AA by construction, and zero third-party UI runtime dependencies.
        </p>
        <div class="landing-framework-strip" aria-label="Supported frameworks">
          <span class="landing-framework-chip"><code>Angular</code> thin wrappers</span>
          <span class="landing-framework-chip"><code>Astro</code> Web Components</span>
          <span class="landing-framework-chip"><code>Django</code> CSS classes</span>
          <span class="landing-framework-chip"><code>Vanilla</code> custom elements</span>
        </div>
        <div class="landing-hero-actions">
          <viking-button-wc variant="primary" href="/components">Browse components</viking-button-wc>
          <viking-button-wc variant="secondary" href="/playground">Live playground</viking-button-wc>
          <viking-button-wc variant="outline" href="/architecture">Architecture</viking-button-wc>
        </div>
        <p class="viking-text-muted">
          Published as <code>{SITE.npm}</code> — see <a href="/contributing">contributing guide</a>.
        </p>
        <div class="landing-stats" aria-label="Library stats">
          <div class="landing-stat">
            <span class="viking-label">Library primitives</span>
            <strong class="viking-metric">{LIBRARY_COMPONENT_COUNT}</strong>
          </div>
          <div class="landing-stat">
            <span class="viking-label">Documented demos</span>
            <strong class="viking-metric">{COMPONENT_COUNT}</strong>
          </div>
          <div class="landing-stat">
            <span class="viking-label">Frameworks</span>
            <strong class="viking-metric">4</strong>
          </div>
          <div class="landing-stat">
            <span class="viking-label">Accessibility</span>
            <strong class="viking-metric">AA</strong>
          </div>
        </div>
      </div>

      <div class="landing-preview-panel" aria-label="Live component preview">
        <div class="landing-preview-runelock" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="landing-preview-toolbar">
          <span class="viking-label">Operational surface</span>
          <viking-badge-wc tone="success">Production ready</viking-badge-wc>
        </div>
        <div class="landing-preview-grid">
          <viking-card-wc compact>
            <span class="viking-label">Event throughput</span>
            <strong class="viking-metric">8.2K/s</strong>
            <viking-badge-wc tone="success">Healthy</viking-badge-wc>
          </viking-card-wc>
          <viking-card-wc compact>
            <span class="viking-label">Token drift</span>
            <strong class="viking-metric">0</strong>
            <viking-badge-wc tone="accent">Guarded</viking-badge-wc>
          </viking-card-wc>
        </div>
        <div class="landing-preview-form">
          <viking-input-wc placeholder="Mission ID" clearable></viking-input-wc>
          <div class="viking-demo-row">
            <viking-button-wc variant="primary">Deploy</viking-button-wc>
            <viking-button-wc variant="outline">Review</viking-button-wc>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-visual-lock" aria-labelledby="visual-lock-heading">
      <header class="landing-section-header">
        <span class="section-tag">Visual lock</span>
        <h2 class="showcase-section-title" id="visual-lock-heading">
          Machined precision. Restrained operational presence.
        </h2>
        <p class="viking-text-muted showcase-section-desc">
          The final Viking-UI direction is deep navy/charcoal command hardware with machined
          metallic borders, subtle top-edge highlights, restrained teal and crimson accents, and
          generous tokenized spacing.
        </p>
      </header>
      <div class="landing-doctrine-grid">
        {
          aestheticPillars.map((pillar) => (
            <viking-card-wc compact class="landing-doctrine-card">
              <span class="viking-label">{pillar.label}</span>
              <h3 class="viking-heading viking-heading-sm">{pillar.title}</h3>
              <p class="viking-text-muted">{pillar.body}</p>
            </viking-card-wc>
          ))
        }
      </div>
    </section>

    <section class="landing-section landing-quickstart" aria-labelledby="quickstart-heading">
      <header class="landing-section-header">
        <span class="section-tag">Quick start</span>
        <h2 class="showcase-section-title" id="quickstart-heading">Install once. Compose everywhere.</h2>
        <p class="viking-text-muted showcase-section-desc">
          The same package powers Angular wrappers, static CSS, Web Components, and framework-neutral utilities.
        </p>
      </header>
      <div class="landing-quickstart-grid">
        <div class="landing-quickstart-steps viking-card">
          <span class="viking-label">Recommended path</span>
          <ol class="landing-step-list viking-text-muted">
            <li>Use npm for app-first surfaces: <code>npm install @dataengineeringformachinelearning/viking-ui</code>.</li>
            <li>Use jsDelivr CDN for widgets, quick embeds, and external integrations.</li>
            <li>Use sync script only for Django/non-npm surfaces when static assets are required.</li>
            <li>Load the full <code>viking-ui.css</code> bundle globally.</li>
            <li>Compose forms through field stacks and actions through Viking buttons.</li>
            <li>Use the registry-backed gallery to copy framework-specific examples.</li>
          </ol>
        </div>
        <div class="landing-quickstart-code">
          <CodeBlock snippets={quickStartSnippets} defaultTab="angular" />
        </div>
      </div>
      <div class="landing-quickstart-steps viking-card">
        <span class="viking-label">Delivery decision</span>
        <p class="viking-text-muted">
          Primary recommendation: npm for apps and SPAs. CDN for widgets and quick embeds.
          Use sync script when Django or other non-npm surfaces must consume synced static CSS.
        </p>
        <ul class="landing-step-list viking-text-muted">
          <li>
            <strong>npm usage</strong>: strongest version control for code-first apps and build-time surfaces.
          </li>
          <li>
            <strong>jsDelivr CDN</strong>: fastest way to ship assets for widgets, static docs, and
            status widgets.
          </li>
          <li>
            <strong>sync_design_system.py</strong>: use for Django and legacy HTML pipelines that must
            consume synced static assets.
          </li>
        </ul>
      </div>
    </section>

    <section class="landing-section" aria-labelledby="release-heading">
      <header class="landing-section-header">
        <span class="section-tag">Publishing workflow</span>
        <h2 class="showcase-section-title" id="release-heading">Release the package with visual proof.</h2>
        <p class="viking-text-muted showcase-section-desc">
          The polished <code>4.1.5</code> package moves through package build, npm dry run,
          Storybook, Chromatic, npm publish, asset sync, and showcase deploy from the same
          canonical source.
        </p>
      </header>
      <div class="landing-doctrine-grid">
        <viking-card-wc compact>
          <span class="viking-label">1. Package gate</span>
          <h3 class="viking-heading viking-heading-sm">Build, test, pack</h3>
          <p class="viking-text-muted">
            Run <code>npm run test:viking-ui:package</code> and <code>npm run pack:viking-ui</code>
            to verify exports, files, CSS bundles, Web Components, and Angular wrappers.
          </p>
        </viking-card-wc>
        <viking-card-wc compact>
          <span class="viking-label">2. Visual gate</span>
          <h3 class="viking-heading viking-heading-sm">Storybook + Chromatic</h3>
          <p class="viking-text-muted">
            Build <code>packages/viking-ui/storybook-static</code>, then publish Chromatic
            snapshots with <code>CHROMATIC_PROJECT_TOKEN</code> for mobile, tablet, and desktop.
          </p>
        </viking-card-wc>
        <viking-card-wc compact>
          <span class="viking-label">3. Distribution</span>
          <h3 class="viking-heading viking-heading-sm">npm, CDN, sync</h3>
          <p class="viking-text-muted">
            Publish through Changesets, consume with npm or jsDelivr, and reserve
            <code>sync_design_system.py</code> for Django/static surfaces that need copied assets.
          </p>
        </viking-card-wc>
      </div>
    </section>

    <section class="landing-section" aria-labelledby="cdn-usage">
      <header class="landing-section-header">
        <span class="section-tag">Distribution</span>
        <h2 class="showcase-section-title" id="cdn-usage">Use via jsDelivr CDN</h2>
      </header>
      <p class="viking-text-muted showcase-section-desc">
        Copy-ready CDN snippets for every scenario. Use <code>@latest</code> for automatic updates,
        or pin to a specific version for reproducible releases.
      </p>

      <p class="viking-label">1) CSS only</p>
      <div class="code-block" data-code-block="cdn-css-only">
        <div class="code-block-tabs" role="presentation">
          <span class="code-block-tab is-active" role="presentation">CSS only</span>
          <button type="button" class="code-block-copy" data-copy-btn aria-label="Copy code to clipboard">
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            <span class="code-block-copy-label">Copy</span>
          </button>
        </div>
        <pre class="code-block-panel is-active"><code>{`<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/viking-ui.css" />`}</code></pre>
      </div>

      <p class="viking-label">2) Web Components only</p>
      <div class="code-block" data-code-block="cdn-wc-only">
        <div class="code-block-tabs" role="presentation">
          <span class="code-block-tab is-active" role="presentation">Web Components only</span>
          <button type="button" class="code-block-copy" data-copy-btn aria-label="Copy code to clipboard">
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            <span class="code-block-copy-label">Copy</span>
          </button>
        </div>
        <pre class="code-block-panel is-active"><code>{`<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/web-components.js"></script>`}</code></pre>
      </div>

      <p class="viking-label">3) CSS + Web Components</p>
      <div class="code-block" data-code-block="cdn-css-wc">
        <div class="code-block-tabs" role="presentation">
          <span class="code-block-tab is-active" role="presentation">CSS + Web Components</span>
          <button type="button" class="code-block-copy" data-copy-btn aria-label="Copy code to clipboard">
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            <span class="code-block-copy-label">Copy</span>
          </button>
        </div>
        <pre class="code-block-panel is-active"><code>{`<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/viking-ui.css" />
<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/web-components.js"></script>`}</code></pre>
      </div>

      <p class="viking-label">4) Version pinning</p>
      <p class="viking-text-muted">
        Prefer pinned versions for immutable environments:
      </p>
      <div class="code-block" data-code-block="cdn-version-pinning">
        <div class="code-block-tabs" role="presentation">
          <span class="code-block-tab is-active" role="presentation">Version pinning</span>
          <button type="button" class="code-block-copy" data-copy-btn aria-label="Copy code to clipboard">
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            <span class="code-block-copy-label">Copy</span>
          </button>
        </div>
        <pre class="code-block-panel is-active"><code>{`<!-- Latest behavior -->
<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/web-components.js"></script>

<!-- Deterministic release -->
<script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@4.1.19/dist/web-components.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@4.1.19/dist/viking-ui.css" />`}</code></pre>
      </div>

      <p class="viking-label">5) Full minimal HTML for external sites</p>
      <div class="code-block" data-code-block="cdn-minimal-html">
        <div class="code-block-tabs" role="presentation">
          <span class="code-block-tab is-active" role="presentation">Minimal HTML</span>
          <button type="button" class="code-block-copy" data-copy-btn aria-label="Copy code to clipboard">
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            <span class="code-block-copy-label">Copy</span>
          </button>
        </div>
        <pre class="code-block-panel is-active"><code>{`<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DEML Widget Embed</title>
    <meta name="description" content="DEML status widget via jsDelivr" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/viking-ui.css" />
    <script type="module" src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/web-components.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@dataengineeringformachinelearning/viking-ui@latest/dist/widget.js" async defer
      data-page-id="platform-status"
      data-backend-url="https://api.example.com"
      data-frontend-url="https://deml.app"
    ></script>
  </head>
  <body>
    <main class="page-inner-wrapper">
      <viking-card-wc compact>
        <h1 class="viking-heading viking-heading-lg">Platform status</h1>
        <p class="viking-text-muted">Drop this file into a marketing page or partner dashboard.</p>
      </viking-card-wc>
    </main>
  </body>
</html>`}</code></pre>
      </div>
    </section>

    <section class="landing-section" aria-labelledby="gallery-heading">
      <header class="landing-section-header landing-section-header-row">
        <div>
          <span class="section-tag">Component gallery</span>
          <h2 class="showcase-section-title" id="gallery-heading">Registry-backed primitives</h2>
          <p class="viking-text-muted showcase-section-desc">
            The gallery is generated from <code>src/lib/component-registry.ts</code>, so demos,
            snippets, and detail pages stay aligned.
          </p>
        </div>
        <viking-button-wc variant="outline" href="/components">View all {COMPONENT_COUNT}</viking-button-wc>
      </header>
      <div class="landing-component-grid">
        {featuredComponents.map((component) => (
          <a class="landing-component-card viking-card" href={`/components/${component.id}`}>
            <span class="viking-label">{component.category}</span>
            <h3 class="viking-heading viking-heading-sm">{component.name}</h3>
            <p class="viking-text-muted">{component.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="landing-section landing-playground-band" aria-labelledby="playground-heading">
      <div class="landing-playground-copy">
        <span class="section-tag">Live playground</span>
        <h2 class="showcase-section-title" id="playground-heading">Tune props. See the component. Copy the code.</h2>
        <p class="viking-text-muted showcase-section-desc">
          Use the playground for quick decisions across button, input, badge, and card primitives.
          It updates previews and generated snippets without leaving the docs.
        </p>
        <div class="viking-demo-row">
          <viking-button-wc variant="primary" href="/playground">Open playground</viking-button-wc>
          <viking-button-wc variant="secondary" href="/components/button">Inspect button API</viking-button-wc>
        </div>
      </div>
      <div class="landing-playground-preview viking-card" aria-label="Playground sample">
        <span class="viking-label">Variant sample</span>
        <div class="viking-demo-row">
          <viking-button-wc variant="primary">Primary</viking-button-wc>
          <viking-button-wc variant="secondary">Secondary</viking-button-wc>
          <viking-badge-wc tone="warning">Degraded</viking-badge-wc>
        </div>
      </div>
    </section>

    <section class="landing-section" aria-labelledby="frameworks-heading">
      <header class="landing-section-header">
        <span class="section-tag">Framework usage</span>
        <h2 class="showcase-section-title" id="frameworks-heading">One visual system, four consumption paths</h2>
      </header>
      <div class="landing-framework-grid">
        <a class="landing-framework-card viking-card" href="/frameworks#angular-setup">
          <span class="viking-label">Angular</span>
          <strong>Signals, OnPush, typed inputs</strong>
          <span class="viking-text-muted">Full package imports for deml.app surfaces.</span>
        </a>
        <a class="landing-framework-card viking-card" href="/frameworks#astro-setup">
          <span class="viking-label">Astro</span>
          <strong>Static CSS + custom elements</strong>
          <span class="viking-text-muted">Docs and marketing pages stay framework-light.</span>
        </a>
        <a class="landing-framework-card viking-card" href="/frameworks#django-setup">
          <span class="viking-label">Django / HTML</span>
          <strong>Server-rendered classes</strong>
          <span class="viking-text-muted">Swagger, admin, and backend templates share tokens.</span>
        </a>
        <a class="landing-framework-card viking-card" href="/frameworks#wc-setup">
          <span class="viking-label">Web Components</span>
          <strong>Framework-neutral primitives</strong>
          <span class="viking-text-muted">Auto-registered tags for portable UI.</span>
        </a>
      </div>
    </section>

    <section class="landing-section" aria-labelledby="docs-heading">
      <header class="landing-section-header">
        <span class="section-tag">Architecture & theming</span>
        <h2 class="showcase-section-title" id="docs-heading">Governed like production infrastructure</h2>
      </header>
      <div class="landing-feature-grid">
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Token pipeline</h3>
          <p class="viking-text-muted">
            Edit canonical SCSS once, build static CSS, and sync to Angular, Astro, Django, and
            backend assets.
          </p>
          <a href="/theming" class="component-detail-link">Read theming</a>
        </div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Layered architecture</h3>
          <p class="viking-text-muted">
            Tokens, CSS primitives, Web Components, and Angular wrappers share one contract.
          </p>
          <a href="/architecture" class="component-detail-link">Read architecture</a>
        </div>
        <div class="viking-card">
          <h3 class="viking-heading viking-heading-sm">Contribution workflow</h3>
          <p class="viking-text-muted">
            New UI lands in the library first, then gets documented through the registry.
          </p>
          <a href="/contributing" class="component-detail-link">Contributing guide</a>
        </div>
      </div>
    </section>
  </div>
</DocLayout>
